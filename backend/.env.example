# =============================================================================
# Mello Backend — Local Development Environment
# =============================================================================
# Only NAKAMA_HTTP_KEY is required for local dev.
# Social login credentials are optional — the backend only advertises
# providers whose env vars are set. Without them, auth falls back to
# email/password only.

# --- Nakama ---
NAKAMA_HTTP_KEY=mello_http_key_dev

# --- Steam (P0) ---
STEAM_PUBLISHER_KEY=
STEAM_APP_ID=480

# --- Google (P0) ---
GOOGLE_CLIENT_ID=

# --- Twitch (P0) ---
TWITCH_CLIENT_ID=

# --- Discord (P1) ---
DISCORD_CLIENT_ID=

# --- Apple (P1) ---
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# --- TURN server ---
TURN_SECRET=mello_turn_secret_dev
TURN_HOST=localhost

# --- SFU integration (optional in local dev) ---
# JWT private key used by Nakama to sign short-lived SFU tokens (RS256).
SFU_JWT_PRIVATE_KEY=

# SFU websocket endpoints returned by `voice_join` / `start_stream`.
# For desktop+mobile LAN testing, use a LAN-reachable host (not localhost), e.g.:
# SFU_ENDPOINT_EU=ws://192.168.1.67:8443/ws
SFU_ENDPOINT_EU=ws://localhost:8443/ws
SFU_ENDPOINT_US=

# SFU admin APIs used by backend-side reconcile/oracle pulls.
SFU_ADMIN_BASE_EU=http://host.docker.internal:8080
SFU_ADMIN_BASE_US=
SFU_ADMIN_PASSWORD=

# Dev/test-only fault injection RPC guard (`dev_fault`).
MELLO_ENABLE_DEV_FAULT=0
