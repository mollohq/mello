#!/bin/sh
# Pre-push: clippy + tests (matches pr-checks.yml).
# Install: git config core.hooksPath .githooks

if ! command -v cargo >/dev/null 2>&1; then
    exit 0
fi

# Skip hardware-dependent tests (screen capture, etc.) that also skip on CI
export CI=true

echo "━━━ pre-push checks ━━━"
echo ""

# ── 1. Clippy ──
STEP_START=$(date +%s)
echo "▸ [1/2] clippy..."
cargo clippy --all-targets -- -D warnings 2>&1
CLIPPY_EXIT=$?
ELAPSED=$(( $(date +%s) - STEP_START ))
if [ $CLIPPY_EXIT -ne 0 ]; then
    echo "✗ clippy failed (${ELAPSED}s). Push rejected."
    exit 1
fi
echo "✓ clippy passed (${ELAPSED}s)"
echo ""

# ── 2. Tests ──
STEP_START=$(date +%s)
echo "▸ [2/2] tests..."
cargo test --workspace 2>&1
TEST_EXIT=$?
ELAPSED=$(( $(date +%s) - STEP_START ))
if [ $TEST_EXIT -ne 0 ]; then
    echo "✗ tests failed (${ELAPSED}s). Push rejected."
    exit 1
fi
echo "✓ tests passed (${ELAPSED}s)"
echo ""
echo "━━━ all checks passed ━━━"
