#!/bin/sh
# Pre-commit: fast format check only.
# Heavier checks (clippy, tests) run in pre-push.
# Install: git config core.hooksPath .githooks

if ! command -v cargo >/dev/null 2>&1; then
    exit 0
fi

cargo fmt --all -- --check 2>/dev/null
if [ $? -ne 0 ]; then
    echo "Running cargo fmt..."
    cargo fmt --all
    echo "Formatted. Re-add changed files and commit again."
    exit 1
fi
