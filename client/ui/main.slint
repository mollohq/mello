import { Theme } from "theme.slint";
import { CrewData, MemberData, ChatMessageData, AudioDeviceData, VoiceChannelData, VoiceChannelMember } from "types.slint";
import { CrewPanel } from "panels/crew_panel.slint";
import { StreamView } from "panels/stream_view.slint";
import { VoiceChannelView } from "panels/voice_channel_view.slint";
import { ChatPanel } from "panels/chat_panel.slint";
import { ControlBar } from "panels/control_bar.slint";
import { SettingsModal } from "panels/settings_modal.slint";
import { DebugPanel } from "panels/debug_panel.slint";
import { Onboarding } from "panels/onboarding.slint";
import { SignInPanel } from "panels/sign_in.slint";
import { UpdateToast } from "panels/update_banner.slint";


export { CrewData, MemberData, ChatMessageData, AudioDeviceData, VoiceChannelData, VoiceChannelMember, Theme }

export component MainWindow inherits Window {
    title: "Mello";
    min-width: 1024px;
    min-height: 768px;
    preferred-width: 1440px;
    preferred-height: 900px;
    background: Theme.bg-app;
    default-font-family: Theme.font-sans;

    // --- Auth state ---
    in property <bool> logged-in: false;
    in property <string> login-error: "";
    in property <bool> login-loading: false;

    // --- Onboarding (0 = show onboarding, 1-3 = step, 4+ = done) ---
    in-out property <int> onboarding-step: 0;
    in property <[CrewData]> discover-crews: [];
    in property <string> link-error: "";
    in property <bool> is-returning-user: false;
    out property <string> onboarding-nickname;
    out property <int> selected-avatar;
    in-out property <bool> show-sign-in: false;

    // --- User ---
    in property <string> user-id: "";
    in property <string> user-name: "";
    in property <string> user-tag: "";

    // --- Crews ---
    in property <[CrewData]> crews: [];
    in property <string> active-crew-id: "";

    // --- Members / chat ---
    in property <[MemberData]> members: [];
    in property <[ChatMessageData]> messages: [];

    // --- Voice ---
    in-out property <bool> mic-muted: false;
    in-out property <bool> deafened: false;
    in-out property <bool> in-voice: false;
    in property <[VoiceChannelData]> voice-channels: [];

    // --- Settings ---
    in-out property <bool> settings-open: false;
    in property <[AudioDeviceData]> capture-devices: [];
    in property <[AudioDeviceData]> playback-devices: [];
    in-out property <string> selected-capture-id: "";
    in-out property <string> selected-playback-id: "";
    in-out property <string> selected-capture-name: "System Default";
    in-out property <string> selected-playback-name: "System Default";
    in-out property <bool> mic-testing: false;
    in-out property <float> mic-level: 0.0;
    // General settings
    in-out property <bool> settings-start-on-boot: false;
    in-out property <bool> settings-start-minimized: false;
    in-out property <bool> settings-close-to-tray: true;
    in-out property <bool> settings-auto-connect: false;
    in-out property <bool> settings-minimize-on-join: false;
    in-out property <bool> settings-hw-acceleration: true;
    // Audio settings
    in-out property <float> settings-input-volume: 1.0;
    in-out property <float> settings-output-volume: 1.0;
    in-out property <bool> settings-noise-suppression: true;
    in-out property <bool> settings-echo-cancellation: true;
    in-out property <bool> settings-ptt-mode: false;
    in property <string> settings-ptt-key-label: "Unassigned";
    in-out property <float> settings-vad-threshold: -40.0;
    in property <string> settings-build-version: "v0.1.0";
    in-out property <bool> settings-show-saved: false;

    // --- Presence (0=online, 1=idle, 2=dnd, 3=invisible) ---
    in-out property <int> presence-status: 0;

    // --- Debug panel ---
    in-out property <bool> debug-open: false;
    in property <float> dbg-input-level: 0.0;
    in property <float> dbg-silero-prob: 0.0;
    in property <float> dbg-rnnoise-prob: 0.0;
    in property <bool> dbg-speaking: false;
    in property <bool> dbg-capturing: false;
    in property <bool> dbg-muted: false;
    in property <bool> dbg-deafened: false;
    in property <int> dbg-packets: 0;
    // Level history (ring buffer, 30 entries)
    in property <float> lh0;  in property <float> lh1;  in property <float> lh2;  in property <float> lh3;  in property <float> lh4;
    in property <float> lh5;  in property <float> lh6;  in property <float> lh7;  in property <float> lh8;  in property <float> lh9;
    in property <float> lh10; in property <float> lh11; in property <float> lh12; in property <float> lh13; in property <float> lh14;
    in property <float> lh15; in property <float> lh16; in property <float> lh17; in property <float> lh18; in property <float> lh19;
    in property <float> lh20; in property <float> lh21; in property <float> lh22; in property <float> lh23; in property <float> lh24;
    in property <float> lh25; in property <float> lh26; in property <float> lh27; in property <float> lh28; in property <float> lh29;
    // Speaking state per bar
    in property <bool> sh0;  in property <bool> sh1;  in property <bool> sh2;  in property <bool> sh3;  in property <bool> sh4;
    in property <bool> sh5;  in property <bool> sh6;  in property <bool> sh7;  in property <bool> sh8;  in property <bool> sh9;
    in property <bool> sh10; in property <bool> sh11; in property <bool> sh12; in property <bool> sh13; in property <bool> sh14;
    in property <bool> sh15; in property <bool> sh16; in property <bool> sh17; in property <bool> sh18; in property <bool> sh19;
    in property <bool> sh20; in property <bool> sh21; in property <bool> sh22; in property <bool> sh23; in property <bool> sh24;
    in property <bool> sh25; in property <bool> sh26; in property <bool> sh27; in property <bool> sh28; in property <bool> sh29;

    // --- Update toast ---
    in property <bool> update-available: false;
    in property <string> update-version: "";
    in property <float> update-download-progress: -1.0;
    in property <string> protocol-warning: "";

    // --- Callbacks ---
    callback update-now-clicked();
    callback update-dismiss-clicked();
    callback login(string, string);
    callback logout();
    callback create-crew(string);
    callback select-crew(string);
    callback send-message(string);
    callback mic-toggle();
    callback deafen-toggle();
    callback voice-toggle();
    callback presence-changed(int);
    callback theme-toggled();
    callback settings-requested();
    callback capture-device-selected(string);
    callback playback-device-selected(string);
    callback mic-test-toggled();
    callback debug-toggled();
    // Voice channel callbacks
    callback join-voice-channel(string);
    callback toggle-voice-channel(string);
    // Settings change callbacks
    callback setting-changed-start-on-boot(bool);
    callback setting-changed-start-minimized(bool);
    callback setting-changed-close-to-tray(bool);
    callback setting-changed-auto-connect(bool);
    callback setting-changed-minimize-on-join(bool);
    callback setting-changed-hw-acceleration(bool);
    callback setting-changed-input-volume(float);
    callback setting-changed-output-volume(float);
    callback setting-changed-noise-suppression(bool);
    callback setting-changed-echo-cancellation(bool);
    callback setting-changed-input-mode(bool);
    callback setting-changed-vad-threshold(float);
    callback settings-ptt-key-captured(/* key_text */ string, /* ctrl */ bool, /* alt */ bool, /* shift */ bool, /* meta */ bool);
    callback settings-reset-defaults();

    // --- Onboarding callbacks ---
    callback onboarding-crew-selected(string);
    callback onboarding-create-crew(string);
    callback onboarding-continue(int);
    callback onboarding-login-requested();
    callback onboarding-link-email(string, string);
    callback onboarding-skip-identity();
    callback onboarding-capture-device-selected(string);
    callback onboarding-playback-device-selected(string);

    // --- Social auth callbacks (onboarding link) ---
    callback onboarding-auth-steam();
    callback onboarding-auth-google();
    callback onboarding-auth-twitch();
    callback onboarding-auth-discord();
    callback onboarding-auth-apple();

    // --- Sign-in callbacks (returning user) ---
    callback signin-steam();
    callback signin-google();
    callback signin-twitch();
    callback signin-discord();
    callback signin-apple();

    // ===================== ONBOARDING =====================
    if onboarding-step >= 1 && onboarding-step <= 3 && !show-sign-in: Onboarding {
        step: root.onboarding-step;
        discover-crews: root.discover-crews;
        link-error: root.link-error;
        device-user-name: root.user-name;
        is-returning-user: root.is-returning-user;
        capture-devices: root.capture-devices;
        playback-devices: root.playback-devices;
        selected-capture-id: root.selected-capture-id;
        selected-playback-id: root.selected-playback-id;
        selected-capture-name <=> root.selected-capture-name;
        selected-playback-name <=> root.selected-playback-name;
        nickname <=> root.onboarding-nickname;
        selected-avatar <=> root.selected-avatar;
        crew-selected(id) => { root.onboarding-crew-selected(id); }
        create-crew-requested(name) => { root.onboarding-create-crew(name); }
        continue-to-step(s) => { root.onboarding-continue(s); }
        login-requested => { root.onboarding-login-requested(); }
        open-sign-in => { root.show-sign-in = true; }
        link-email(email, pw) => { root.onboarding-link-email(email, pw); }
        skip-identity => { root.onboarding-skip-identity(); }
        capture-device-selected(id) => { root.onboarding-capture-device-selected(id); }
        playback-device-selected(id) => { root.onboarding-playback-device-selected(id); }
        auth-steam => { root.onboarding-auth-steam(); }
        auth-google => { root.onboarding-auth-google(); }
        auth-twitch => { root.onboarding-auth-twitch(); }
        auth-discord => { root.onboarding-auth-discord(); }
        auth-apple => { root.onboarding-auth-apple(); }
    }

    // ===================== SIGN-IN PANEL (from onboarding "Sign in" link) =====================
    if show-sign-in && !logged-in: SignInPanel {
        error: root.login-error;
        loading: root.login-loading;
        back => { root.show-sign-in = false; }
        signin-steam => { root.signin-steam(); }
        signin-google => { root.signin-google(); }
        signin-twitch => { root.signin-twitch(); }
        signin-discord => { root.signin-discord(); }
        signin-apple => { root.signin-apple(); }
        signin-email(email, pw) => { root.login(email, pw); }
    }

    // ===================== MAIN APP =====================
    if logged-in && (onboarding-step == 0 || onboarding-step > 3): Rectangle {
        background: Theme.bg-app;

        HorizontalLayout {
            padding: Theme.gap;
            spacing: Theme.gap;

            // LEFT: Crew sidebar
            CrewPanel {
                width: 280px;
                crews: root.crews;
                active-crew-id: root.active-crew-id;
                crew-selected(id) => { root.select-crew(id); }
                crew-create-requested(name) => { root.create-crew(name); }
            }

            // CENTER: stage area + controls bar
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: Theme.gap;

                StreamView {
                    vertical-stretch: 1;
                    members: root.members;
                }

                VoiceChannelView {
                    voice-channels: root.voice-channels;
                    join-voice-channel(id) => { root.join-voice-channel(id); }
                    toggle-channel(id) => { root.toggle-voice-channel(id); }
                }

                ControlBar {
                    height: 92px;
                    user-name: root.user-name;
                    user-tag: root.user-tag;
                    mic-muted <=> root.mic-muted;
                    deafened <=> root.deafened;
                    in-voice: root.in-voice;
                    presence-status <=> root.presence-status;
                    mic-toggled => { root.mic-toggle(); }
                    deafen-toggled => { root.deafen-toggle(); }
                    voice-toggled => { root.voice-toggle(); }
                    logout-clicked => { root.logout(); }
                    presence-changed(status) => { root.presence-changed(status); }
                    theme-toggled => { root.theme-toggled(); }
                    settings-clicked => { root.settings-requested(); }
                    debug-toggled => {
                        root.debug-open = !root.debug-open;
                        root.debug-toggled();
                    }
                }
            }

            // RIGHT: Chat panel
            ChatPanel {
                width: 340px;
                messages: root.messages;
                user-name: root.user-name;
                message-submitted(text) => { root.send-message(text); }
            }
        }
    }

    // ===================== UPDATE TOAST =====================
    if logged-in && (onboarding-step == 0 || onboarding-step > 3): UpdateToast {
        x: (root.width - self.width) / 2;
        y: 5px;
        update-available: root.update-available;
        version: root.update-version;
        download-progress: root.update-download-progress;
        protocol-warning: root.protocol-warning;
        update-clicked => { root.update-now-clicked(); }
        dismiss-clicked => { root.update-dismiss-clicked(); }
    }

    // ===================== DEBUG OVERLAY =====================
    if debug-open && logged-in: Rectangle {
        // Position top-right, floating over content
        x: root.width - 332px;
        y: 50px;
        width: 320px;

        DebugPanel {
            input-level: root.dbg-input-level;
            silero-vad-prob: root.dbg-silero-prob;
            rnnoise-prob: root.dbg-rnnoise-prob;
            is-speaking: root.dbg-speaking;
            is-capturing: root.dbg-capturing;
            is-muted: root.dbg-muted;
            is-deafened: root.dbg-deafened;
            packets-encoded: root.dbg-packets;
            lh0:  root.lh0;  lh1:  root.lh1;  lh2:  root.lh2;  lh3:  root.lh3;  lh4:  root.lh4;
            lh5:  root.lh5;  lh6:  root.lh6;  lh7:  root.lh7;  lh8:  root.lh8;  lh9:  root.lh9;
            lh10: root.lh10; lh11: root.lh11; lh12: root.lh12; lh13: root.lh13; lh14: root.lh14;
            lh15: root.lh15; lh16: root.lh16; lh17: root.lh17; lh18: root.lh18; lh19: root.lh19;
            lh20: root.lh20; lh21: root.lh21; lh22: root.lh22; lh23: root.lh23; lh24: root.lh24;
            lh25: root.lh25; lh26: root.lh26; lh27: root.lh27; lh28: root.lh28; lh29: root.lh29;
            sh0:  root.sh0;  sh1:  root.sh1;  sh2:  root.sh2;  sh3:  root.sh3;  sh4:  root.sh4;
            sh5:  root.sh5;  sh6:  root.sh6;  sh7:  root.sh7;  sh8:  root.sh8;  sh9:  root.sh9;
            sh10: root.sh10; sh11: root.sh11; sh12: root.sh12; sh13: root.sh13; sh14: root.sh14;
            sh15: root.sh15; sh16: root.sh16; sh17: root.sh17; sh18: root.sh18; sh19: root.sh19;
            sh20: root.sh20; sh21: root.sh21; sh22: root.sh22; sh23: root.sh23; sh24: root.sh24;
            sh25: root.sh25; sh26: root.sh26; sh27: root.sh27; sh28: root.sh28; sh29: root.sh29;
            close-requested => {
                root.debug-open = false;
                root.debug-toggled();
            }
        }
    }

    // ===================== SETTINGS OVERLAY =====================
    if settings-open: SettingsModal {
        // Audio devices
        capture-devices: root.capture-devices;
        playback-devices: root.playback-devices;
        selected-capture-id: root.selected-capture-id;
        selected-playback-id: root.selected-playback-id;
        selected-capture-name <=> root.selected-capture-name;
        selected-playback-name <=> root.selected-playback-name;
        mic-testing <=> root.mic-testing;
        mic-level: root.mic-level;
        // General
        start-on-boot <=> root.settings-start-on-boot;
        start-minimized <=> root.settings-start-minimized;
        close-to-tray <=> root.settings-close-to-tray;
        auto-connect <=> root.settings-auto-connect;
        minimize-on-join <=> root.settings-minimize-on-join;
        hw-acceleration <=> root.settings-hw-acceleration;
        // Audio
        input-volume <=> root.settings-input-volume;
        output-volume <=> root.settings-output-volume;
        noise-suppression <=> root.settings-noise-suppression;
        echo-cancellation <=> root.settings-echo-cancellation;
        ptt-mode <=> root.settings-ptt-mode;
        ptt-key-label: root.settings-ptt-key-label;
        vad-threshold <=> root.settings-vad-threshold;
        build-version: root.settings-build-version;
        show-saved <=> root.settings-show-saved;
        // Callbacks
        close-requested => {
            root.settings-open = false;
            if root.mic-testing {
                root.mic-testing = false;
                root.mic-test-toggled();
            }
        }
        capture-device-selected(id) => {
            root.selected-capture-id = id;
            root.capture-device-selected(id);
        }
        playback-device-selected(id) => {
            root.selected-playback-id = id;
            root.playback-device-selected(id);
        }
        mic-test-toggled => {
            root.mic-testing = !root.mic-testing;
            root.mic-test-toggled();
        }
        // Settings change callbacks — flash "Saved ✓" on each
        setting-changed-start-on-boot(v) => { root.settings-show-saved = true; root.setting-changed-start-on-boot(v); }
        setting-changed-start-minimized(v) => { root.settings-show-saved = true; root.setting-changed-start-minimized(v); }
        setting-changed-close-to-tray(v) => { root.settings-show-saved = true; root.setting-changed-close-to-tray(v); }
        setting-changed-auto-connect(v) => { root.settings-show-saved = true; root.setting-changed-auto-connect(v); }
        setting-changed-minimize-on-join(v) => { root.settings-show-saved = true; root.setting-changed-minimize-on-join(v); }
        setting-changed-hw-acceleration(v) => { root.settings-show-saved = true; root.setting-changed-hw-acceleration(v); }
        setting-changed-input-volume(v) => { root.settings-show-saved = true; root.setting-changed-input-volume(v); }
        setting-changed-output-volume(v) => { root.settings-show-saved = true; root.setting-changed-output-volume(v); }
        setting-changed-noise-suppression(v) => { root.settings-show-saved = true; root.setting-changed-noise-suppression(v); }
        setting-changed-echo-cancellation(v) => { root.settings-show-saved = true; root.setting-changed-echo-cancellation(v); }
        setting-changed-input-mode(v) => { root.settings-show-saved = true; root.setting-changed-input-mode(v); }
        setting-changed-vad-threshold(v) => { root.settings-show-saved = true; root.setting-changed-vad-threshold(v); }
        ptt-key-captured(key, ctrl, alt, shift, meta) => { root.settings-show-saved = true; root.settings-ptt-key-captured(key, ctrl, alt, shift, meta); }
        reset-defaults => { root.settings-show-saved = true; root.settings-reset-defaults(); }
    }
}
