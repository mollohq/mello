import { Theme } from "theme.slint";
import {
    CrewData,
    MemberData,
    ChatMessageData,
    GifItemData,
    AudioDeviceData,
    VoiceChannelData,
    VoiceChannelMember,
    CaptureSourceData,
    DiscoverCrewData,
    SearchUserData,
    FeedCardData,
    StreamCardData,
} from "types.slint";
import { CrewPanel } from "panels/crew_panel.slint";
import { StreamSourcePicker } from "panels/stream_source_picker.slint";
import { VoiceChannelView } from "panels/voice_channel_view.slint";
import { ChatPanel } from "panels/chat_panel.slint";
import { ControlBar } from "panels/control_bar.slint";
import { CrewFeed } from "panels/crew_feed.slint";
import { SettingsModal } from "panels/settings_modal.slint";
import { NewCrewModal } from "panels/new_crew_modal.slint";
import { DebugPanel } from "panels/debug_panel.slint";
import { Onboarding } from "panels/onboarding.slint";
import { SignInPanel } from "panels/sign_in.slint";
import { UpdateToast } from "panels/update_banner.slint";
import { DiscoverPanel } from "panels/discover_panel.slint";
import { JoinCrewModal } from "panels/join_crew_modal.slint";
import { InviteShareModal } from "panels/invite_share_modal.slint";


export { CrewData, MemberData, ChatMessageData, AudioDeviceData, VoiceChannelData, VoiceChannelMember, CaptureSourceData, DiscoverCrewData, SearchUserData, FeedCardData, StreamCardData, Theme }

export component MainWindow inherits Window {
    title: "Mello";
    min-width: 1024px;
    min-height: 768px;
    preferred-width: 1440px;
    preferred-height: 900px;
    background: Theme.bg-app;
    default-font-family: Theme.font-sans;

    // --- Auth state ---
    in property <bool> logged-in: false;
    in property <string> login-error: "";
    in property <bool> login-loading: false;

    // --- Onboarding (0 = show onboarding, 1-3 = step, 4+ = done) ---
    in-out property <int> onboarding-step: 0;
    in property <[CrewData]> discover-crews: [];
    in property <[int]> onboarding-bento-bases: [];
    in property <string> link-error: "";
    in property <bool> is-returning-user: false;
    out property <string> onboarding-nickname;
    in-out property <int> selected-avatar: -1;
    in-out property <bool> show-sign-in: false;

    // Avatar grid (Step 2)
    in property <image> avatar-img-0;
    in property <image> avatar-img-1;
    in property <image> avatar-img-2;
    in property <image> avatar-img-3;
    in property <image> avatar-img-4;
    in property <image> avatar-img-5;
    in property <image> avatar-img-6;
    in property <image> avatar-back-0;
    in property <image> avatar-back-1;
    in property <image> avatar-back-2;
    in property <image> avatar-back-3;
    in property <image> avatar-back-4;
    in property <image> avatar-back-5;
    in property <image> avatar-back-6;
    in property <bool> avatar-loaded-0: false;
    in property <bool> avatar-loaded-1: false;
    in property <bool> avatar-loaded-2: false;
    in property <bool> avatar-loaded-3: false;
    in property <bool> avatar-loaded-4: false;
    in property <bool> avatar-loaded-5: false;
    in property <bool> avatar-loaded-6: false;
    in property <bool> avatar-deal-0: false;
    in property <bool> avatar-deal-1: false;
    in property <bool> avatar-deal-2: false;
    in property <bool> avatar-deal-3: false;
    in property <bool> avatar-deal-4: false;
    in property <bool> avatar-deal-5: false;
    in property <bool> avatar-deal-6: false;
    in property <bool> avatar-deal-upload: false;
    in-out property <bool> avatar-flip-0: false;
    in-out property <bool> avatar-flip-1: false;
    in-out property <bool> avatar-flip-2: false;
    in-out property <bool> avatar-flip-3: false;
    in-out property <bool> avatar-flip-4: false;
    in-out property <bool> avatar-flip-5: false;
    in-out property <bool> avatar-flip-6: false;
    in property <image> upload-preview;
    in property <bool> has-upload: false;
    in-out property <int> spinning-slot: -1;
    in-out property <float> spin-angle: 0;
    in-out property <string> spin-text-front: "";
    in-out property <string> spin-text-back: "";
    in-out property <bool> spin-heart-front: false;
    in-out property <bool> spin-heart-back: false;
    callback avatar-slot-clicked(int);
    callback avatar-pointer-down(int);
    callback avatar-pointer-up(int);
    callback avatar-reroll-clicked();
    callback avatar-upload-clicked();

    // --- User ---
    in property <string> user-id: "";
    in property <string> user-name: "";
    in property <string> user-initials: "";
    in property <string> user-tag: "";
    in property <image> user-avatar;
    in property <bool> has-user-avatar: false;

    // --- Crews ---
    in property <[CrewData]> crews: [];
    in property <string> active-crew-id: "";

    // --- Discover crews ---
    in-out property <bool> show-discover: false;
    in property <[DiscoverCrewData]> discover-crews-list: [];
    in property <[int]> discover-bento-bases: [];
    callback discover-load-more();

    // --- Members / chat ---
    in property <[MemberData]> members: [];
    in property <[ChatMessageData]> messages: [];
    in property <[GifItemData]> gif-results: [];
    in property <bool> loading-history: false;

    // --- Voice ---
    in-out property <bool> mic-muted: false;
    in-out property <bool> deafened: false;
    in-out property <bool> in-voice: false;
    in property <string> voice-channel-name: "";
    in property <[VoiceChannelData]> voice-channels: [];
    in-out property <bool> mic-permission-granted: true;
    in-out property <bool> mic-permission-denied: false;
    in property <bool> can-manage-channels: false;

    // --- Game sensing ---
    in property <bool> game-active: false;
    in property <string> game-name: "";
    in property <string> game-short-name: "";
    in property <color> game-color: #2a2a30;
    in property <bool> can-stream: false;
    in-out property <int> bar-state: 0;

    callback stream-requested();
    callback reaction-tapped(string);
    callback moment-submitted(string);
    callback moment-dismissed();

    // --- Settings ---
    in-out property <bool> settings-open: false;
    in property <[AudioDeviceData]> capture-devices: [];
    in property <[AudioDeviceData]> playback-devices: [];
    in-out property <string> selected-capture-id: "";
    in-out property <string> selected-playback-id: "";
    in-out property <string> selected-capture-name: "System Default";
    in-out property <string> selected-playback-name: "System Default";
    in-out property <bool> mic-testing: false;
    in-out property <float> mic-level: 0.0;
    // General settings
    in-out property <bool> settings-start-on-boot: false;
    in-out property <bool> settings-start-minimized: false;
    in-out property <bool> settings-close-to-tray: true;
    in-out property <bool> settings-auto-connect: false;
    in-out property <bool> settings-minimize-on-join: false;
    in-out property <bool> settings-hw-acceleration: true;
    // Audio settings
    in-out property <float> settings-input-volume: 1.0;
    in-out property <float> settings-output-volume: 1.0;
    in-out property <bool> settings-noise-suppression: true;
    in-out property <bool> settings-echo-cancellation: true;
    in-out property <bool> settings-ptt-mode: false;
    in property <string> settings-ptt-key-label: "Unassigned";
    in-out property <bool> settings-ptt-binding: false;
    in-out property <float> settings-vad-threshold: -40.0;
    in property <string> settings-build-version: "v0.1.0";
    in-out property <bool> settings-show-saved: false;
    // HUD settings
    in-out property <bool> settings-hud-enabled: true;
    in-out property <bool> settings-hud-overlay-in-game: true;
    in-out property <float> settings-hud-overlay-opacity: 0.8;
    in-out property <bool> settings-hud-clip-toasts: true;
    // Profile settings
    in property <image> profile-avatar-0;
    in property <image> profile-avatar-1;
    in property <image> profile-avatar-2;
    in property <image> profile-avatar-3;
    in property <image> profile-avatar-4;
    in property <image> profile-avatar-5;
    in property <image> profile-avatar-6;
    in property <image> profile-avatar-back-0;
    in property <image> profile-avatar-back-1;
    in property <image> profile-avatar-back-2;
    in property <image> profile-avatar-back-3;
    in property <image> profile-avatar-back-4;
    in property <image> profile-avatar-back-5;
    in property <image> profile-avatar-back-6;
    in property <bool> profile-avatar-loaded-0: false;
    in property <bool> profile-avatar-loaded-1: false;
    in property <bool> profile-avatar-loaded-2: false;
    in property <bool> profile-avatar-loaded-3: false;
    in property <bool> profile-avatar-loaded-4: false;
    in property <bool> profile-avatar-loaded-5: false;
    in property <bool> profile-avatar-loaded-6: false;
    in-out property <bool> profile-avatar-flip-0: false;
    in-out property <bool> profile-avatar-flip-1: false;
    in-out property <bool> profile-avatar-flip-2: false;
    in-out property <bool> profile-avatar-flip-3: false;
    in-out property <bool> profile-avatar-flip-4: false;
    in-out property <bool> profile-avatar-flip-5: false;
    in-out property <bool> profile-avatar-flip-6: false;
    in-out property <int> profile-selected-avatar: -1;
    in property <image> profile-upload-preview;
    in property <bool> profile-has-upload: false;
    in-out property <string> profile-nickname-value;
    in-out property <bool> profile-grid-expanded: false;
    callback profile-avatar-clicked(int);
    callback profile-reroll();
    callback profile-upload-clicked();
    callback profile-nickname-accepted(string);
    callback profile-expand-grid();
    callback profile-use-avatar(int);

    // --- Streaming ---
    in-out property <bool> source-picker-open: false;
    in property <[CaptureSourceData]> stream-monitors: [];
    in property <[CaptureSourceData]> stream-games: [];
    in property <[CaptureSourceData]> stream-windows: [];
    in property <bool> is-hosting: false;
    in property <bool> is-watching: false;
    in property <string> stream-label: "";
    in property <string> streamer-name: "";
    in property <image> stream-frame;
    in property <string> active-streamer-id: "";
    in property <string> active-streamer-name: "";
    in property <string> active-stream-title: "";
    in property <string> active-stream-session-id: "";
    in property <int> active-stream-width: 0;
    in property <int> active-stream-height: 0;
    in property <int> active-stream-viewer-count: 0;
    in property <[StreamCardData]> active-stream-cards: [];

    // --- New crew modal ---
    in-out property <bool> new-crew-open: false;
    in property <image> new-crew-avatar-preview;
    in-out property <bool> new-crew-has-avatar: false;
    in property <[SearchUserData]> new-crew-search-results: [];
    in property <[SearchUserData]> new-crew-invited-users: [];
    in-out property <bool> new-crew-created: false;
    in property <string> new-crew-invite-code: "";

    // --- Join crew modal (deep link invite) ---
    in-out property <bool> join-crew-modal-open: false;
    in property <string> join-crew-name: "";
    in property <string> join-crew-id: "";
    in property <string> join-crew-invite-code: "";
    in property <string> join-crew-highlight: "";
    in property <string> join-crew-avatar-seed: "";
    in property <string> join-crew-error: "";
    in property <bool> join-crew-loading: false;
    callback join-crew-confirmed(/* invite_code */ string);
    callback join-crew-dismissed();

    // --- Invite share modal ---
    in-out property <bool> invite-share-open: false;
    in property <string> invite-share-url: "";
    in-out property <bool> invite-share-copied: false;
    callback invite-copy-link();
    callback invite-share-requested();
    callback hide-invite-card();

    // --- Crew feed ---
    in property <[FeedCardData]> feed-cards: [];
    in property <bool> feed-cold-start: true;
    in property <int> feed-clip-count: 0;

    // --- Clip playback state ---
    in property <string> clip-playing-path: "";
    in property <float> clip-progress: 0.0;
    in property <bool> clip-paused: false;
    in property <float> clip-anim-tick: 0.0;
    in property <string> clip-position-text: "";
    in property <string> clip-duration-text: "";

    // --- Presence (0=online, 1=idle, 2=dnd, 3=invisible) ---
    in-out property <int> presence-status: 0;

    // --- Debug panel ---
    in-out property <bool> debug-open: false;
    in property <float> dbg-input-level: 0.0;
    in property <float> dbg-silero-prob: 0.0;
    in property <float> dbg-rnnoise-prob: 0.0;
    in property <bool> dbg-speaking: false;
    in property <bool> dbg-capturing: false;
    in property <bool> dbg-muted: false;
    in property <bool> dbg-deafened: false;
    in property <bool> dbg-aec-enabled: false;
    in property <bool> dbg-agc-enabled: false;
    in property <bool> dbg-ns-enabled: false;
    in property <int> dbg-aec-capture: 0;
    in property <int> dbg-aec-render: 0;
    in property <int> dbg-packets: 0;
    in property <int> dbg-incoming-streams: 0;
    in property <int> dbg-underruns: 0;
    in property <int> dbg-rtp-recv: 0;
    in property <float> dbg-delay-ms: 0.0;
    in property <float> dbg-rtt-ms: 0.0;
    in property <string> dbg-stream-mode: "idle";
    in property <int> dbg-stream-frames: 0;
    in property <int> dbg-stream-packets: 0;
    in property <float> dbg-stream-mb: 0.0;
    in property <float> dbg-stream-kbps: 0.0;
    in property <float> dbg-stream-fps: 0.0;
    in property <int> dbg-stream-truncations: 0;
    in property <string> dbg-host-pacing-mode: "idle";
    in property <int> dbg-host-pacing-target-kbps: 0;
    in property <float> dbg-host-pacing-out-kbps: 0.0;
    in property <float> dbg-host-pacing-mb: 0.0;
    in property <int> dbg-host-pacing-sleep-count: 0;
    in property <int> dbg-host-pacing-sleep-ms: 0;
    in property <int> dbg-host-pacing-sleep-delta-count: 0;
    in property <int> dbg-host-pacing-sleep-delta-ms: 0;
    // Level history (ring buffer, 30 entries)
    in property <float> lh0;
    in property <float> lh1;
    in property <float> lh2;
    in property <float> lh3;
    in property <float> lh4;
    in property <float> lh5;
    in property <float> lh6;
    in property <float> lh7;
    in property <float> lh8;
    in property <float> lh9;
    in property <float> lh10;
    in property <float> lh11;
    in property <float> lh12;
    in property <float> lh13;
    in property <float> lh14;
    in property <float> lh15;
    in property <float> lh16;
    in property <float> lh17;
    in property <float> lh18;
    in property <float> lh19;
    in property <float> lh20;
    in property <float> lh21;
    in property <float> lh22;
    in property <float> lh23;
    in property <float> lh24;
    in property <float> lh25;
    in property <float> lh26;
    in property <float> lh27;
    in property <float> lh28;
    in property <float> lh29;
    // Speaking state per bar
    in property <bool> sh0;
    in property <bool> sh1;
    in property <bool> sh2;
    in property <bool> sh3;
    in property <bool> sh4;
    in property <bool> sh5;
    in property <bool> sh6;
    in property <bool> sh7;
    in property <bool> sh8;
    in property <bool> sh9;
    in property <bool> sh10;
    in property <bool> sh11;
    in property <bool> sh12;
    in property <bool> sh13;
    in property <bool> sh14;
    in property <bool> sh15;
    in property <bool> sh16;
    in property <bool> sh17;
    in property <bool> sh18;
    in property <bool> sh19;
    in property <bool> sh20;
    in property <bool> sh21;
    in property <bool> sh22;
    in property <bool> sh23;
    in property <bool> sh24;
    in property <bool> sh25;
    in property <bool> sh26;
    in property <bool> sh27;
    in property <bool> sh28;
    in property <bool> sh29;

    // --- Update toast ---
    in property <bool> update-available: false;
    in property <string> update-version: "";
    in property <float> update-download-progress: -1.0;
    in property <string> protocol-warning: "";
    in-out property <string> audio-device-warning: "";

    // --- Callbacks ---
    callback update-now-clicked();
    callback update-dismiss-clicked();
    callback login(string, string);
    callback logout();
    callback create-crew(/* name */ string, /* description */ string, /* is-private */ bool);
    callback select-crew(string);
    callback new-crew-avatar-pick();
    callback new-crew-search-users(/* query */ string);
    callback new-crew-invite-user(/* id */ string);
    callback new-crew-uninvite-user(/* id */ string);
    callback new-crew-copy-invite-code();
    callback send-message(string);
    callback send-message-with-reply(/* text */ string, /* reply_to */ string);
    callback request-history();
    callback edit-message(/* message_id */ string, /* new_body */ string);
    callback delete-message(/* message_id */ string);
    callback gif-pill-clicked();
    callback gif-search(/* query */ string);
    callback gif-selected(/* gif_id */ string, /* url */ string, /* preview_url */ string, /* width */ int, /* height */ int);
    callback gif-hovered(/* preview_url */ string);
    callback emoji-pill-clicked();
    callback mic-toggle();
    callback deafen-toggle();
    callback voice-toggle();
    callback presence-changed(int);
    callback theme-toggled();
    callback settings-requested();
    callback capture-device-selected(string);
    callback playback-device-selected(string);
    callback mic-test-toggled();
    callback debug-toggled();
    // Voice channel callbacks
    callback join-voice-channel(string);
    callback toggle-voice-channel(string);
    callback create-voice-channel(/* name */ string);
    callback request-mic-permission();
    callback open-mic-settings();
    // Settings change callbacks
    callback setting-changed-start-on-boot(bool);
    callback setting-changed-start-minimized(bool);
    callback setting-changed-close-to-tray(bool);
    callback setting-changed-auto-connect(bool);
    callback setting-changed-minimize-on-join(bool);
    callback setting-changed-hw-acceleration(bool);
    callback setting-changed-input-volume(float);
    callback setting-changed-output-volume(float);
    callback setting-changed-noise-suppression(bool);
    callback setting-changed-echo-cancellation(bool);
    callback setting-changed-input-mode(bool);
    callback setting-changed-vad-threshold(float);
    callback settings-ptt-key-captured(/* key_text */ string, /* ctrl */ bool, /* alt */ bool, /* shift */ bool, /* meta */ bool);
    callback settings-reset-defaults();
    // HUD settings callbacks
    callback setting-changed-hud-enabled(bool);
    callback setting-changed-hud-overlay-in-game(bool);
    callback setting-changed-hud-overlay-opacity(float);
    callback setting-changed-hud-clip-toasts(bool);

    // --- Streaming callbacks ---
    callback list-capture-sources();
    callback start-stream(/* source_id */ string, /* source_mode */ string, /* preset */ int);
    callback stop-stream();
    callback stop-watching();
    callback watch-stream(/* host_id */ string, /* session_id */ string, /* width */ int, /* height */ int);
    callback stop-thumbnail-refresh();

    // --- Clip callbacks ---
    callback clip-captured();
    callback play-clip(string);
    callback pause-clip();
    callback resume-clip();
    callback seek-clip(float);

    // --- Onboarding callbacks ---
    callback onboarding-crew-selected(string);
    callback onboarding-create-crew(string);
    callback onboarding-continue(int);
    callback onboarding-login-requested();
    callback onboarding-link-email(string, string);
    callback onboarding-skip-identity();
    callback onboarding-capture-device-selected(string);
    callback onboarding-playback-device-selected(string);

    // --- Social auth callbacks (onboarding link) ---
    callback onboarding-auth-steam();
    callback onboarding-auth-google();
    callback onboarding-auth-twitch();
    callback onboarding-auth-discord();
    callback onboarding-auth-apple();

    // --- Sign-in callbacks (returning user) ---
    callback signin-steam();
    callback signin-google();
    callback signin-twitch();
    callback signin-discord();
    callback signin-apple();

    // --- Discover callbacks ---
    callback discover-requested();
    callback discover-join-crew(string);
    callback discover-join-invite(string);

    // ===================== ONBOARDING =====================
    if onboarding-step >= 1 && onboarding-step <= 3 && !show-sign-in: Onboarding {
        step: root.onboarding-step;
        discover-crews: root.discover-crews;
        bento-set-bases: root.onboarding-bento-bases;
        link-error: root.link-error;
        device-user-name: root.user-name;
        device-user-initials: root.user-initials;
        is-returning-user: root.is-returning-user;
        capture-devices: root.capture-devices;
        playback-devices: root.playback-devices;
        selected-capture-id: root.selected-capture-id;
        selected-playback-id: root.selected-playback-id;
        selected-capture-name <=> root.selected-capture-name;
        selected-playback-name <=> root.selected-playback-name;
        nickname <=> root.onboarding-nickname;
        selected-avatar <=> root.selected-avatar;
        avatar-img-0: root.avatar-img-0;
        avatar-img-1: root.avatar-img-1;
        avatar-img-2: root.avatar-img-2;
        avatar-img-3: root.avatar-img-3;
        avatar-img-4: root.avatar-img-4;
        avatar-img-5: root.avatar-img-5;
        avatar-img-6: root.avatar-img-6;
        avatar-back-0: root.avatar-back-0;
        avatar-back-1: root.avatar-back-1;
        avatar-back-2: root.avatar-back-2;
        avatar-back-3: root.avatar-back-3;
        avatar-back-4: root.avatar-back-4;
        avatar-back-5: root.avatar-back-5;
        avatar-back-6: root.avatar-back-6;
        avatar-loaded-0: root.avatar-loaded-0;
        avatar-loaded-1: root.avatar-loaded-1;
        avatar-loaded-2: root.avatar-loaded-2;
        avatar-loaded-3: root.avatar-loaded-3;
        avatar-loaded-4: root.avatar-loaded-4;
        avatar-loaded-5: root.avatar-loaded-5;
        avatar-loaded-6: root.avatar-loaded-6;
        avatar-deal-0: root.avatar-deal-0;
        avatar-deal-1: root.avatar-deal-1;
        avatar-deal-2: root.avatar-deal-2;
        avatar-deal-3: root.avatar-deal-3;
        avatar-deal-4: root.avatar-deal-4;
        avatar-deal-5: root.avatar-deal-5;
        avatar-deal-6: root.avatar-deal-6;
        avatar-deal-upload: root.avatar-deal-upload;
        avatar-flip-0 <=> root.avatar-flip-0;
        avatar-flip-1 <=> root.avatar-flip-1;
        avatar-flip-2 <=> root.avatar-flip-2;
        avatar-flip-3 <=> root.avatar-flip-3;
        avatar-flip-4 <=> root.avatar-flip-4;
        avatar-flip-5 <=> root.avatar-flip-5;
        avatar-flip-6 <=> root.avatar-flip-6;
        upload-preview: root.upload-preview;
        has-upload: root.has-upload;
        spinning-slot: root.spinning-slot;
        spin-angle: root.spin-angle;
        spin-text-front: root.spin-text-front;
        spin-text-back: root.spin-text-back;
        spin-heart-front: root.spin-heart-front;
        spin-heart-back: root.spin-heart-back;
        avatar-slot-clicked(i) => {
            root.avatar-slot-clicked(i);
        }
        avatar-pointer-down(i) => {
            root.avatar-pointer-down(i);
        }
        avatar-pointer-up(i) => {
            root.avatar-pointer-up(i);
        }
        reroll-clicked => {
            root.avatar-reroll-clicked();
        }
        upload-clicked => {
            root.avatar-upload-clicked();
        }
        crew-selected(id) => {
            root.onboarding-crew-selected(id);
        }
        create-crew-requested(name) => {
            root.onboarding-create-crew(name);
        }
        continue-to-step(s) => {
            root.onboarding-continue(s);
        }
        login-requested => {
            root.onboarding-login-requested();
        }
        open-sign-in => {
            root.show-sign-in = true;
        }
        link-email(email, pw) => {
            root.onboarding-link-email(email, pw);
        }
        skip-identity => {
            root.onboarding-skip-identity();
        }
        capture-device-selected(id) => {
            root.onboarding-capture-device-selected(id);
        }
        playback-device-selected(id) => {
            root.onboarding-playback-device-selected(id);
        }
        auth-steam => {
            root.onboarding-auth-steam();
        }
        auth-google => {
            root.onboarding-auth-google();
        }
        auth-twitch => {
            root.onboarding-auth-twitch();
        }
        auth-discord => {
            root.onboarding-auth-discord();
        }
        auth-apple => {
            root.onboarding-auth-apple();
        }
    }

    // ===================== SIGN-IN PANEL (from onboarding "Sign in" link) =====================
    if show-sign-in && !logged-in: SignInPanel {
        error: root.login-error;
        loading: root.login-loading;
        back => {
            root.show-sign-in = false;
        }
        signin-steam => {
            root.signin-steam();
        }
        signin-google => {
            root.signin-google();
        }
        signin-twitch => {
            root.signin-twitch();
        }
        signin-discord => {
            root.signin-discord();
        }
        signin-apple => {
            root.signin-apple();
        }
        signin-email(email, pw) => {
            root.login(email, pw);
        }
    }

    // ===================== MAIN APP =====================
    if logged-in && (onboarding-step == 0 || onboarding-step > 3): Rectangle {
        background: Theme.bg-app;

        HorizontalLayout {
            padding-left: 0px;
            padding-top: 0px;
            padding-bottom: 0px;
            padding-right: Theme.gap;
            spacing: Theme.gap;

            // LEFT: Crew sidebar
            CrewPanel {
                width: 240px;
                horizontal-stretch: 0;
                crews: root.crews;
                active-crew-id: root.active-crew-id;
                voice-channels: root.voice-channels;
                crew-selected(id) => {
                    root.show-discover = false;
                    root.select-crew(id);
                }
                crew-create-requested => {
                    root.new-crew-has-avatar = false;
                    root.new-crew-created = false;
                    root.new-crew-open = true;
                }
                browse-crews-requested => {
                    root.show-discover = true;
                    root.discover-requested();
                }
                join-voice-channel(id) => {
                    root.join-voice-channel(id);
                }
                invite-clicked => {
                    root.invite-share-requested();
                }
            }

            // RIGHT: discover OR (center stage + chat)
            // Uses a plain Rectangle with absolute positioning inside to
            // avoid any Slint layout interference from conditional `if` slots.
            Rectangle {
                horizontal-stretch: 1;

                property <length> chat-w: 340px;

                if root.show-discover: DiscoverPanel {
                    width: parent.width;
                    height: parent.height;
                    crews: root.discover-crews-list;
                    bento-set-bases: root.discover-bento-bases;
                    join-crew(id) => {
                        root.discover-join-crew(id);
                    }
                    join-invite(code) => {
                        root.discover-join-invite(code);
                    }
                    back-requested => {
                        root.show-discover = false;
                    }
                    load-more => {
                        root.discover-load-more();
                    }
                }

                if !root.show-discover: Rectangle {
                    x: 0;
                    y: 0;
                    width: parent.width - parent.chat-w - Theme.gap;
                    height: parent.height;

                    Rectangle {
                        y: 0;
                        width: parent.width;
                        height: parent.height - 84px - Theme.gap;

                        CrewFeed {
                            width: parent.width;
                            height: parent.height;
                            cards: root.feed-cards;
                            stream-cards: root.active-stream-cards;
                            is-hosting: root.is-hosting;
                            is-watching: root.is-watching;
                            active-streamer-id: root.active-streamer-id;
                            stream-frame: root.stream-frame;
                            is-cold-start: root.feed-cold-start;
                            clip-count: root.feed-clip-count;
                            clip-playing-path: root.clip-playing-path;
                            clip-progress: root.clip-progress;
                            clip-paused: root.clip-paused;
                            clip-anim-tick: root.clip-anim-tick;
                            clip-position-text: root.clip-position-text;
                            clip-duration-text: root.clip-duration-text;
                            go-live-clicked => {
                                root.list-capture-sources();
                                root.source-picker-open = true;
                            }
                            stop-stream-clicked => {
                                root.stop-stream();
                            }
                            stop-watching-clicked => {
                                root.stop-watching();
                            }
                            watch-stream-clicked(host-id, session-id, w, h) => {
                                root.watch-stream(host-id, session-id, w, h);
                            }
                            card-clicked(clip-path) => {
                                if clip-path != "" {
                                    if clip-path == root.clip-playing-path {
                                        if root.clip-paused {
                                            root.resume-clip();
                                        } else {
                                            root.pause-clip();
                                        }
                                    } else {
                                        root.play-clip(clip-path);
                                    }
                                }
                            }
                            seek-clip(v) => {
                                root.seek-clip(v);
                            }
                            invite-clicked => {
                                root.invite-share-requested();
                            }
                            hide-invite-clicked => {
                                root.hide-invite-card();
                            }
                        }
                    }

                    ControlBar {
                        y: parent.height - 84px;
                        width: parent.width;
                        height: 84px;
                        user-name: root.user-name;
                        user-initials: root.user-initials;
                        user-avatar: root.user-avatar;
                        has-user-avatar: root.has-user-avatar;
                        user-tag: root.user-tag;
                        mic-muted <=> root.mic-muted;
                        deafened <=> root.deafened;
                        in-voice: root.in-voice;
                        voice-channel-name: root.voice-channel-name;
                        mic-permission-granted: root.mic-permission-granted;
                        mic-permission-denied: root.mic-permission-denied;
                        presence-status <=> root.presence-status;
                        game-active: root.game-active;
                        game-name: root.game-name;
                        game-short-name: root.game-short-name;
                        game-color: root.game-color;
                        can-stream: root.can-stream;
                        bar-state <=> root.bar-state;
                        mic-toggled => {
                            root.mic-toggle();
                        }
                        deafen-toggled => {
                            root.deafen-toggle();
                        }
                        voice-toggled => {
                            root.voice-toggle();
                        }
                        logout-clicked => {
                            root.logout();
                        }
                        presence-changed(status) => {
                            root.presence-changed(status);
                        }
                        theme-toggled => {
                            root.theme-toggled();
                        }
                        settings-clicked => {
                            root.settings-requested();
                        }
                        request-mic-permission => {
                            root.request-mic-permission();
                        }
                        open-mic-settings => {
                            root.open-mic-settings();
                        }
                        debug-toggled => {
                            root.debug-open = !root.debug-open;
                            root.debug-toggled();
                        }
                        stream-requested => {
                            root.stream-requested();
                        }
                        reaction-tapped(sentiment) => {
                            root.reaction-tapped(sentiment);
                        }
                        moment-submitted(text) => {
                            root.moment-submitted(text);
                        }
                        moment-dismissed => {
                            root.moment-dismissed();
                        }
                        clip-captured => {
                            root.clip-captured();
                        }
                    }
                }

                if !root.show-discover: ChatPanel {
                    x: parent.width - parent.chat-w;
                    y: 0;
                    width: parent.chat-w;
                    height: parent.height;
                    messages: root.messages;
                    gif-results: root.gif-results;
                    user-name: root.user-name;
                    user-id: root.user-id;
                    loading-history: root.loading-history;
                    message-submitted(text) => {
                        root.send-message(text);
                    }
                    message-submitted-with-reply(text, reply-to) => {
                        root.send-message-with-reply(text, reply-to);
                    }
                    request-history() => {
                        root.request-history();
                    }
                    edit-message(id, body) => {
                        root.edit-message(id, body);
                    }
                    delete-message(id) => {
                        root.delete-message(id);
                    }
                    gif-pill-clicked() => {
                        root.gif-pill-clicked();
                    }
                    gif-search(query) => {
                        root.gif-search(query);
                    }
                    gif-selected(tid, url, purl, w, h) => {
                        root.gif-selected(tid, url, purl, w, h);
                    }
                    gif-hovered(purl) => {
                        root.gif-hovered(purl);
                    }
                    emoji-pill-clicked() => {
                        root.emoji-pill-clicked();
                    }
                }
            }
        }
    }

    // ===================== UPDATE TOAST =====================
    if logged-in && (onboarding-step == 0 || onboarding-step > 3): UpdateToast {
        width: min(420px, root.width - 32px);
        x: (root.width - self.width) / 2;
        y: 6px;
        update-available: root.update-available;
        version: root.update-version;
        download-progress: root.update-download-progress;
        protocol-warning: root.protocol-warning;
        update-clicked => {
            root.update-now-clicked();
        }
        dismiss-clicked => {
            root.update-dismiss-clicked();
        }
    }

    // ===================== AUDIO DEVICE WARNING MODAL =====================
    if logged-in && audio-device-warning != "": Rectangle {
        background: #000000AA;

        TouchArea {}

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(420px, parent.width - 64px);
            height: self.preferred-height;
            background: Theme.surface;
            border-radius: 12px;
            border-width: 1px;
            border-color: Theme.graphic-light;
            drop-shadow-blur: 64px;
            drop-shadow-color: #000000E6;
            drop-shadow-offset-y: 24px;

            TouchArea {}

            VerticalLayout {
                padding: 24px;
                spacing: 16px;

                Text {
                    text: "Audio device not found";
                    color: Theme.text-primary;
                    font-family: Theme.font-sans;
                    font-size: 16px;
                    font-weight: 600;
                }

                Text {
                    text: root.audio-device-warning;
                    color: Theme.text-secondary;
                    font-family: Theme.font-sans;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    alignment: end;
                    spacing: 8px;

                    Rectangle {
                        width: adw-settings-text.preferred-width + 32px;
                        height: 32px;
                        background: adw-settings-ta.has-hover ? Theme.graphic-med : Theme.graphic-light;
                        border-radius: Theme.r-inner;
                        animate background { duration: 150ms; }

                        adw-settings-text := Text {
                            text: "Go to Settings";
                            color: Theme.text-primary;
                            font-family: Theme.font-sans;
                            font-size: 13px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        adw-settings-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.audio-device-warning = "";
                                root.settings-requested();
                            }
                        }
                    }

                    Rectangle {
                        width: adw-ok-text.preferred-width + 32px;
                        height: 32px;
                        background: adw-ok-ta.has-hover ? #FF3D6E : Theme.accent;
                        border-radius: Theme.r-inner;
                        animate background { duration: 150ms; }

                        adw-ok-text := Text {
                            text: "Continue";
                            color: white;
                            font-family: Theme.font-sans;
                            font-size: 13px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        adw-ok-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.audio-device-warning = ""; }
                        }
                    }
                }
            }
        }
    }

    // ===================== DEBUG OVERLAY =====================
    if debug-open && logged-in: Rectangle {
        // Position top-right, floating over content
        x: root.width - 332px;
        y: 50px;
        width: 320px;

        DebugPanel {
            input-level: root.dbg-input-level;
            silero-vad-prob: root.dbg-silero-prob;
            rnnoise-prob: root.dbg-rnnoise-prob;
            is-speaking: root.dbg-speaking;
            is-capturing: root.dbg-capturing;
            is-muted: root.dbg-muted;
            is-deafened: root.dbg-deafened;
            aec-enabled: root.dbg-aec-enabled;
            agc-enabled: root.dbg-agc-enabled;
            ns-enabled: root.dbg-ns-enabled;
            aec-capture: root.dbg-aec-capture;
            aec-render: root.dbg-aec-render;
            packets-encoded: root.dbg-packets;
            incoming-streams: root.dbg-incoming-streams;
            underruns: root.dbg-underruns;
            rtp-recv: root.dbg-rtp-recv;
            delay-ms: root.dbg-delay-ms;
            rtt-ms: root.dbg-rtt-ms;
            stream-mode: root.dbg-stream-mode;
            stream-frames: root.dbg-stream-frames;
            stream-packets: root.dbg-stream-packets;
            stream-mb: root.dbg-stream-mb;
            stream-kbps: root.dbg-stream-kbps;
            stream-fps: root.dbg-stream-fps;
            stream-truncations: root.dbg-stream-truncations;
            host-pacing-mode: root.dbg-host-pacing-mode;
            host-pacing-target-kbps: root.dbg-host-pacing-target-kbps;
            host-pacing-out-kbps: root.dbg-host-pacing-out-kbps;
            host-pacing-mb: root.dbg-host-pacing-mb;
            host-pacing-sleep-count: root.dbg-host-pacing-sleep-count;
            host-pacing-sleep-ms: root.dbg-host-pacing-sleep-ms;
            host-pacing-sleep-delta-count: root.dbg-host-pacing-sleep-delta-count;
            host-pacing-sleep-delta-ms: root.dbg-host-pacing-sleep-delta-ms;
            lh0: root.lh0;
            lh1: root.lh1;
            lh2: root.lh2;
            lh3: root.lh3;
            lh4: root.lh4;
            lh5: root.lh5;
            lh6: root.lh6;
            lh7: root.lh7;
            lh8: root.lh8;
            lh9: root.lh9;
            lh10: root.lh10;
            lh11: root.lh11;
            lh12: root.lh12;
            lh13: root.lh13;
            lh14: root.lh14;
            lh15: root.lh15;
            lh16: root.lh16;
            lh17: root.lh17;
            lh18: root.lh18;
            lh19: root.lh19;
            lh20: root.lh20;
            lh21: root.lh21;
            lh22: root.lh22;
            lh23: root.lh23;
            lh24: root.lh24;
            lh25: root.lh25;
            lh26: root.lh26;
            lh27: root.lh27;
            lh28: root.lh28;
            lh29: root.lh29;
            sh0: root.sh0;
            sh1: root.sh1;
            sh2: root.sh2;
            sh3: root.sh3;
            sh4: root.sh4;
            sh5: root.sh5;
            sh6: root.sh6;
            sh7: root.sh7;
            sh8: root.sh8;
            sh9: root.sh9;
            sh10: root.sh10;
            sh11: root.sh11;
            sh12: root.sh12;
            sh13: root.sh13;
            sh14: root.sh14;
            sh15: root.sh15;
            sh16: root.sh16;
            sh17: root.sh17;
            sh18: root.sh18;
            sh19: root.sh19;
            sh20: root.sh20;
            sh21: root.sh21;
            sh22: root.sh22;
            sh23: root.sh23;
            sh24: root.sh24;
            sh25: root.sh25;
            sh26: root.sh26;
            sh27: root.sh27;
            sh28: root.sh28;
            sh29: root.sh29;
            close-requested => {
                root.debug-open = false;
                root.debug-toggled();
            }
        }
    }

    // ===================== NEW CREW MODAL =====================
    if new-crew-open: NewCrewModal {
        avatar-preview: root.new-crew-avatar-preview;
        has-avatar: root.new-crew-has-avatar;
        search-results: root.new-crew-search-results;
        invited-users: root.new-crew-invited-users;
        created: root.new-crew-created;
        invite-code: root.new-crew-invite-code;
        onboarding-mode: root.onboarding-step < 4;
        close-requested => {
            root.new-crew-open = false;
            root.new-crew-has-avatar = false;
            root.new-crew-created = false;
        }
        avatar-pick-requested => {
            root.new-crew-avatar-pick();
        }
        create-requested(name, desc, is-private) => {
            root.create-crew(name, desc, is-private);
        }
        search-users(query) => {
            root.new-crew-search-users(query);
        }
        invite-user(id) => {
            root.new-crew-invite-user(id);
        }
        uninvite-user(id) => {
            root.new-crew-uninvite-user(id);
        }
        copy-invite-code => {
            root.new-crew-copy-invite-code();
        }
    }

    // ===================== JOIN CREW MODAL =====================
    if join-crew-modal-open: JoinCrewModal {
        crew-name: root.join-crew-name;
        crew-id: root.join-crew-id;
        highlight: root.join-crew-highlight;
        avatar-seed: root.join-crew-avatar-seed;
        error: root.join-crew-error;
        loading: root.join-crew-loading;
        join-requested => {
            root.join-crew-confirmed(root.join-crew-invite-code);
        }
        dismiss-requested => {
            root.join-crew-modal-open = false;
            root.join-crew-dismissed();
        }
    }

    // ===================== INVITE SHARE MODAL =====================
    if invite-share-open: InviteShareModal {
        invite-url: root.invite-share-url;
        copied: root.invite-share-copied;
        copy-link => {
            root.invite-copy-link();
        }
        close-requested => {
            root.invite-share-open = false;
            root.invite-share-copied = false;
        }
    }

    // ===================== SETTINGS OVERLAY =====================
    if settings-open: SettingsModal {
        // Profile
        profile-nickname: root.user-name;
        profile-current-avatar: root.user-avatar;
        profile-has-avatar: root.has-user-avatar;
        profile-initials: root.user-initials;
        profile-avatar-0: root.profile-avatar-0;
        profile-avatar-1: root.profile-avatar-1;
        profile-avatar-2: root.profile-avatar-2;
        profile-avatar-3: root.profile-avatar-3;
        profile-avatar-4: root.profile-avatar-4;
        profile-avatar-5: root.profile-avatar-5;
        profile-avatar-6: root.profile-avatar-6;
        profile-avatar-back-0: root.profile-avatar-back-0;
        profile-avatar-back-1: root.profile-avatar-back-1;
        profile-avatar-back-2: root.profile-avatar-back-2;
        profile-avatar-back-3: root.profile-avatar-back-3;
        profile-avatar-back-4: root.profile-avatar-back-4;
        profile-avatar-back-5: root.profile-avatar-back-5;
        profile-avatar-back-6: root.profile-avatar-back-6;
        profile-avatar-loaded-0: root.profile-avatar-loaded-0;
        profile-avatar-loaded-1: root.profile-avatar-loaded-1;
        profile-avatar-loaded-2: root.profile-avatar-loaded-2;
        profile-avatar-loaded-3: root.profile-avatar-loaded-3;
        profile-avatar-loaded-4: root.profile-avatar-loaded-4;
        profile-avatar-loaded-5: root.profile-avatar-loaded-5;
        profile-avatar-loaded-6: root.profile-avatar-loaded-6;
        profile-avatar-flip-0 <=> root.profile-avatar-flip-0;
        profile-avatar-flip-1 <=> root.profile-avatar-flip-1;
        profile-avatar-flip-2 <=> root.profile-avatar-flip-2;
        profile-avatar-flip-3 <=> root.profile-avatar-flip-3;
        profile-avatar-flip-4 <=> root.profile-avatar-flip-4;
        profile-avatar-flip-5 <=> root.profile-avatar-flip-5;
        profile-avatar-flip-6 <=> root.profile-avatar-flip-6;
        profile-selected-avatar <=> root.profile-selected-avatar;
        profile-upload-preview: root.profile-upload-preview;
        profile-has-upload: root.profile-has-upload;
        profile-nickname-value <=> root.profile-nickname-value;
        profile-grid-expanded <=> root.profile-grid-expanded;
        profile-avatar-clicked(idx) => {
            root.profile-avatar-clicked(idx);
        }
        profile-reroll => {
            root.profile-reroll();
        }
        profile-upload-clicked => {
            root.profile-upload-clicked();
        }
        profile-nickname-accepted(name) => {
            root.profile-nickname-accepted(name);
        }
        profile-expand-grid => {
            root.profile-expand-grid();
        }
        profile-use-avatar(idx) => {
            root.settings-show-saved = true;
            root.profile-use-avatar(idx);
        }
        // Audio devices
        capture-devices: root.capture-devices;
        playback-devices: root.playback-devices;
        selected-capture-id: root.selected-capture-id;
        selected-playback-id: root.selected-playback-id;
        selected-capture-name <=> root.selected-capture-name;
        selected-playback-name <=> root.selected-playback-name;
        mic-testing <=> root.mic-testing;
        mic-level: root.mic-level;
        // General
        start-on-boot <=> root.settings-start-on-boot;
        start-minimized <=> root.settings-start-minimized;
        close-to-tray <=> root.settings-close-to-tray;
        auto-connect <=> root.settings-auto-connect;
        minimize-on-join <=> root.settings-minimize-on-join;
        hw-acceleration <=> root.settings-hw-acceleration;
        // Audio
        input-volume <=> root.settings-input-volume;
        output-volume <=> root.settings-output-volume;
        noise-suppression <=> root.settings-noise-suppression;
        echo-cancellation <=> root.settings-echo-cancellation;
        ptt-mode <=> root.settings-ptt-mode;
        ptt-key-label: root.settings-ptt-key-label;
        ptt-binding <=> root.settings-ptt-binding;
        vad-threshold <=> root.settings-vad-threshold;
        build-version: root.settings-build-version;
        show-saved <=> root.settings-show-saved;
        // HUD
        settings-hud-enabled <=> root.settings-hud-enabled;
        settings-hud-overlay-in-game <=> root.settings-hud-overlay-in-game;
        settings-hud-overlay-opacity <=> root.settings-hud-overlay-opacity;
        settings-hud-clip-toasts <=> root.settings-hud-clip-toasts;
        // Callbacks
        close-requested => {
            root.settings-open = false;
            if root.mic-testing {
                root.mic-testing = false;
                root.mic-test-toggled();
            }
        }
        capture-device-selected(id) => {
            root.selected-capture-id = id;
            root.capture-device-selected(id);
        }
        playback-device-selected(id) => {
            root.selected-playback-id = id;
            root.playback-device-selected(id);
        }
        mic-test-toggled => {
            root.mic-testing = !root.mic-testing;
            root.mic-test-toggled();
        }
        // Settings change callbacks — flash "Saved ✓" on each
        setting-changed-start-on-boot(v) => {
            root.settings-show-saved = true;
            root.setting-changed-start-on-boot(v);
        }
        setting-changed-start-minimized(v) => {
            root.settings-show-saved = true;
            root.setting-changed-start-minimized(v);
        }
        setting-changed-close-to-tray(v) => {
            root.settings-show-saved = true;
            root.setting-changed-close-to-tray(v);
        }
        setting-changed-auto-connect(v) => {
            root.settings-show-saved = true;
            root.setting-changed-auto-connect(v);
        }
        setting-changed-minimize-on-join(v) => {
            root.settings-show-saved = true;
            root.setting-changed-minimize-on-join(v);
        }
        setting-changed-hw-acceleration(v) => {
            root.settings-show-saved = true;
            root.setting-changed-hw-acceleration(v);
        }
        setting-changed-input-volume(v) => {
            root.settings-show-saved = true;
            root.setting-changed-input-volume(v);
        }
        setting-changed-output-volume(v) => {
            root.settings-show-saved = true;
            root.setting-changed-output-volume(v);
        }
        setting-changed-noise-suppression(v) => {
            root.settings-show-saved = true;
            root.setting-changed-noise-suppression(v);
        }
        setting-changed-echo-cancellation(v) => {
            root.settings-show-saved = true;
            root.setting-changed-echo-cancellation(v);
        }
        setting-changed-input-mode(v) => {
            root.settings-show-saved = true;
            root.setting-changed-input-mode(v);
        }
        setting-changed-vad-threshold(v) => {
            root.settings-show-saved = true;
            root.setting-changed-vad-threshold(v);
        }
        ptt-key-captured(key, ctrl, alt, shift, meta) => {
            root.settings-show-saved = true;
            root.settings-ptt-key-captured(key, ctrl, alt, shift, meta);
        }
        reset-defaults => {
            root.settings-show-saved = true;
            root.settings-reset-defaults();
        }
        setting-changed-hud-enabled(v) => {
            root.settings-show-saved = true;
            root.setting-changed-hud-enabled(v);
        }
        setting-changed-hud-overlay-in-game(v) => {
            root.settings-show-saved = true;
            root.setting-changed-hud-overlay-in-game(v);
        }
        setting-changed-hud-overlay-opacity(v) => {
            root.settings-show-saved = true;
            root.setting-changed-hud-overlay-opacity(v);
        }
        setting-changed-hud-clip-toasts(v) => {
            root.settings-show-saved = true;
            root.setting-changed-hud-clip-toasts(v);
        }
    }

    // ===================== STREAM SOURCE PICKER OVERLAY =====================
    if source-picker-open: StreamSourcePicker {
        monitors: root.stream-monitors;
        games: root.stream-games;
        windows: root.stream-windows;
        close-requested => {
            root.source-picker-open = false;
            root.stop-thumbnail-refresh();
        }
        start-stream(id, mode, preset) => {
            root.source-picker-open = false;
            root.start-stream(id, mode, preset);
        }
    }
}
