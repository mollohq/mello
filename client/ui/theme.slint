import "./fonts/Inter-Regular.ttf";
import "./fonts/Inter-Medium.ttf";
import "./fonts/Inter-SemiBold.ttf";
import "./fonts/Inter-Bold.ttf";
import "./fonts/JetBrainsMono-Regular.ttf";
import "./fonts/JetBrainsMono-Medium.ttf";

export global Theme {
    in property <bool> dark: true;

    // --- Surfaces ---
    out property <color> bg-app:     dark ? #181818 : #F5F5F5;
    out property <color> surface:    dark ? #202020 : #FFFFFF;
    out property <color> titlebar:   dark ? #161616 : #ECECEC;

    // --- Text ---
    out property <color> text-primary:   dark ? #F5F5F5 : #121212;
    out property <color> text-secondary: dark ? #606060 : #888888;
    out property <color> text-tertiary:  dark ? #404040 : #B0B0B0;

    // --- Graphic / border ---
    out property <color> graphic-light: dark ? #2E2E2E : #E0E0E0;
    out property <color> graphic-med:   dark ? #404040 : #D0D0D0;
    out property <color> graphic-dark:  dark ? #F5F5F5 : #121212;

    // --- Accent ---
    out property <color> accent:       #FF1E56;
    out property <color> accent-bg:    dark ? #FF1E561A : #FF1E5614;

    // --- Text selection (override Slint cupertino/fluent default blue) ---
    out property <color> selection-bg: dark ? #FF1E5655 : #FF1E5648;
    out property <color> selection-fg: text-primary;

    // --- Voice ---
    out property <color> voice-active:    #46923c;
    out property <color> voice-active-bg: dark ? #46923c26 : #46923c1A;

    // --- Clips ---
    out property <color> clip-amber:    #F59E0B;
    out property <color> clip-amber-bg: dark ? #F59E0B1A : #F59E0B14;

    // --- Cards / Feed ---
    out property <color> card-bg:        dark ? #222226 : #FFFFFF;
    out property <color> card-bg-hover:  dark ? #2a2a2e : #F5F5F7;
    out property <color> card-border:    dark ? #2a2a2e : #E0E0E0;
    out property <color> card-bg-inset:  dark ? #19191d : #F0F0F2;
    out property <color> card-bg-skel:   dark ? #1c1c20 : #F5F5F7;
    out property <color> skel-element:   dark ? #232328 : #E0E0E5;
    out property <color> skel-text:      dark ? #555555 : #999999;
    out property <color> skel-hint:      dark ? #3a3a3e : #BBBBBB;
    out property <color> skel-ghost:     dark ? #333333 : #CCCCCC;
    out property <color> text-sub:       dark ? #888888 : #666666;
    out property <color> text-dim:       dark ? #666666 : #888888;
    out property <color> text-value:     dark ? #cccccc : #333333;

    // --- Convenience aliases (backward compat) ---
    out property <color> bg-primary:   surface;
    out property <color> bg-secondary: bg-app;
    out property <color> bg-tertiary:  graphic-light;
    out property <color> bg-dark:      dark ? #F5F5F5 : #1A1A1A;
    out property <color> text-muted:   text-secondary;
    out property <color> accent-red:   accent;
    out property <color> accent-green: #28C840;
    out property <color> border-light: graphic-light;

    // --- Radii ---
    out property <length> r-outer: 10px;
    out property <length> r-inner: 6px;
    out property <length> r-pill:  20px;

    // backward compat
    out property <length> radius-sm: 4px;
    out property <length> radius-md: r-outer;
    out property <length> radius-lg: 16px;

    // --- Spacing ---
    out property <length> gap: 12px;
    out property <length> pad: 24px;
    // Composer separator → bottom (1px rule + pills + input + padding); control bar top aligns to that rule.
    out property <length> control-bar-height: 81px;

    out property <length> spacing-xs: 4px;
    out property <length> spacing-sm: 8px;
    out property <length> spacing-md: 16px;
    out property <length> spacing-lg: 24px;
    out property <length> spacing-xl: 32px;

    // --- Font sizes ---
    out property <length> font-xs:  10px;
    out property <length> font-sm:  11px;
    out property <length> font-md:  13px;
    out property <length> font-lg:  14px;
    out property <length> font-xl:  20px;
    out property <length> font-xxl: 32px;

    // --- Font families ---
    out property <string> font-sans: "Inter";
    out property <string> font-mono: "JetBrains Mono";

    // --- Hover helpers ---
    out property <color> hover-overlay: dark ? #FFFFFF0D : #0000000D;
    out property <color> surface-hover: dark ? #2A2A2A : #F0F0F0;
}

/// TextInput with Mello selection colors (not platform default blue).
export component MelloTextInput inherits TextInput {
    selection-background-color: Theme.selection-bg;
    selection-foreground-color: Theme.selection-fg;
}

/// Bordered single-line (or multiline) field — full-height input for reliable mouse selection.
export component MelloInputField inherits Rectangle {
    in-out property <string> text <=> input.text;
    in property <string> placeholder: "";
    in property <bool> single-line: true;
    in property <bool> read-only: false;
    in property <length> pad-x: 14px;
    in property <length> pad-y: 0px;
    in property <length> field-height: 44px;
    in property <length> font-size: 14px;
    callback accepted();

    height: field-height;
    background: Theme.bg-app;
    border-radius: 8px;
    border-width: 1px;
    border-color: input.has-focus ? Theme.accent : Theme.graphic-light;

    input := MelloTextInput {
        x: pad-x;
        y: pad-y;
        width: parent.width - 2 * pad-x;
        height: parent.height - 2 * pad-y;
        font-size: root.font-size;
        color: Theme.text-primary;
        horizontal-alignment: left;
        vertical-alignment: single-line ? center : top;
        single-line: root.single-line;
        wrap: single-line ? no-wrap : word-wrap;
        read-only: root.read-only;
        accepted => { root.accepted(); }
    }

    if placeholder != "" && input.text == "" && !read-only: Text {
        x: pad-x;
        y: pad-y;
        width: parent.width - 2 * pad-x;
        height: parent.height - 2 * pad-y;
        text: placeholder;
        font-size: root.font-size;
        color: Theme.text-tertiary;
        vertical-alignment: single-line ? center : top;
    }
}

/// Wheel-scroll container without Flickable — TextInput double/triple-click selection breaks inside Flickable (slint#6514).
export component MelloScrollArea inherits Rectangle {
    in-out property <length> scroll-y: 0;
    in property <length> content-height: 0;
    property <length> max-y: max(0px, content-height - self.height);

    clip: true;

    changed content-height => {
        scroll-y = min(scroll-y, max-y);
    }

    wheel := TouchArea {
        width: parent.width;
        height: parent.height;
        scroll-event(e) => {
            scroll-y = min(max-y, max(0px, scroll-y - e.delta-y));
            accept
        }
    }

    content := Rectangle {
        y: -scroll-y;
        width: parent.width;
        height: content-height;
        @children
    }
}
