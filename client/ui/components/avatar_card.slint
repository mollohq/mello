import { Theme } from "../theme.slint";

export component AvatarCard inherits Rectangle {
    in property <image> front-image;
    in property <image> back-image;
    in property <bool> has-image: false;
    in property <bool> selected: false;
    in property <bool> deal-visible: false;
    in-out property <bool> flipped: false;
    callback clicked();
    callback pointer-down();
    callback pointer-up();

    // Easter egg spin mode (shared — only one card spins at a time)
    in property <bool> spinning: false;
    in property <float> spin-angle: 0;
    in property <string> spin-text-front: "";
    in property <string> spin-text-back: "";
    in property <bool> spin-heart-front: false;
    in property <bool> spin-heart-back: false;

    horizontal-stretch: 1;

    property <float> deal-scale: deal-visible ? 1.0 : 0.5;
    property <float> deal-opacity: deal-visible ? 1.0 : 0.0;
    property <float> deal-y: deal-visible ? 0.0 : 12.0;

    animate deal-scale { duration: 350ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
    animate deal-opacity { duration: 350ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
    animate deal-y { duration: 350ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }

    property <float> flip-progress: flipped ? 1.0 : 0.0;
    animate flip-progress { duration: 1040ms; easing: cubic-bezier(0.4, 0.0, 0.2, 1); }

    property <float> normal-scale-x: Math.abs(Math.cos(flip-progress * 3.14159265rad));
    property <bool> normal-show-front: flip-progress < 0.5;

    property <float> spin-norm: Math.mod(spin-angle, 360.0);
    property <float> spin-scale-x: Math.abs(Math.cos(spin-angle / 180.0 * 3.14159265rad));
    property <bool> spin-show-front: spin-norm < 90.0 || spin-norm >= 270.0;

    property <float> scale-x-factor: spinning ? spin-scale-x : normal-scale-x;
    property <bool> show-front: spinning ? spin-show-front : normal-show-front;

    opacity: deal-opacity;

    av-touch := TouchArea {
        clicked => {
            if !root.spinning { root.clicked(); }
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) { root.pointer-down(); }
            if (e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel) { root.pointer-up(); }
        }
    }

    // Outer glow for selected state
    Rectangle {
        x: -1px;
        y: Math.round(deal-y) * 1px - 1px;
        width: parent.width + 2px;
        height: parent.height + 2px;
        border-radius: Theme.r-inner + 1px;
        border-width: selected ? 1px : 0px;
        border-color: Theme.accent;
        background: transparent;
    }

    // Card container with scale
    Rectangle {
        x: parent.width * (1.0 - deal-scale * scale-x-factor) / 2.0;
        y: Math.round(deal-y) * 1px;
        width: parent.width * deal-scale * scale-x-factor;
        height: parent.height * deal-scale;
        border-radius: Theme.r-inner;
        clip: true;
        background: spinning ? Theme.surface-hover : (selected ? #FF1E560A : Theme.surface);
        border-width: selected ? 1.5px : 1.5px;
        border-color: spinning ? Theme.accent : (selected ? Theme.accent : (av-touch.has-hover ? #404045 : Theme.graphic-light));

        // Front face — avatar image (normal mode)
        if show-front && has-image && !spinning: Image {
            source: front-image;
            width: parent.width * 0.70;
            height: parent.height * 0.70;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            image-fit: contain;
        }

        // Front face — word (spin mode)
        if show-front && spinning: Text {
            text: spin-text-front;
            font-family: "Oxanium";
            font-weight: 600;
            font-size: spin-heart-front ? 28px : 16px;
            color: Theme.accent;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }

        // Back face — avatar image (normal mode)
        if !show-front && has-image && !spinning: Image {
            source: back-image;
            width: parent.width * 0.70;
            height: parent.height * 0.70;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            image-fit: contain;
        }

        // Back face — word (spin mode)
        if !show-front && spinning: Text {
            text: spin-text-back;
            font-family: "Oxanium";
            font-weight: 600;
            font-size: spin-heart-back ? 28px : 16px;
            color: Theme.accent;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }

        // Loading placeholder when no image
        if !has-image && !spinning: Rectangle {
            background: Theme.graphic-light;
            border-radius: 4px;
            width: 32px;
            height: 32px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            opacity: 0.4;
        }
    }
}
