export struct CrewData {
    id: string,
    name: string,
    description: string,
    member-count: int,
    online-count: int,

    avatar: image,
    has-avatar: bool,

    has-stream: bool,
    stream-name: string,

    voice-count: int,
    v0-initials: string, v0-name: string, v0-speaking: bool,
    v1-initials: string, v1-name: string, v1-speaking: bool,
    v2-initials: string, v2-name: string, v2-speaking: bool,
    v3-initials: string, v3-name: string, v3-speaking: bool,

    msg-count: int,
    m0-author: string, m0-text: string,
    m1-author: string, m1-text: string,

    unread-count: int,
    unread-mention: bool,

    sfu-enabled: bool,

    catchup-text: string,
    has-catchup: bool,

    game-count: int,
    g0-name: string, g0-initial: string, g0-count: int,
    g1-name: string, g1-initial: string, g1-count: int,
    g2-name: string, g2-initial: string, g2-count: int,
    g3-name: string, g3-initial: string, g3-count: int,
    g4-name: string, g4-initial: string, g4-count: int,

    clip-count: int,
}

export struct FeedCardData {
    id: string,
    card-type: string,
    title: string,
    subtitle: string,
    timestamp: string,
    duration: string,
    actor-name: string,
    actor-initials: string,
    game-name: string,
    participant-count: int,
    clip-path: string,
    is-hero: bool,
    is-skeleton: bool,
}

export struct MemberData {
    id: string,
    name: string,
    initials: string,
    avatar: image,
    has-avatar: bool,
    online: bool,
    speaking: bool,
}

export struct ChatMessageData {
    message-id: string,
    sender-id: string,
    sender-name: string,
    sender-initials: string,
    sender-avatar: image,
    has-sender-avatar: bool,
    text: string,
    timestamp: string,
    display-time: string,
    is-group-start: bool,
    is-continuation: bool,
    is-system: bool,
    is-gif: bool,
    gif-image: image,
    has-gif-image: bool,
    gif-preview-url: string,
    gif-width: int,
    gif-height: int,
}

export struct GifItemData {
    gif-id: string,
    url: string,
    preview-url: string,
    width: int,
    height: int,
    preview: image,
    has-preview: bool,
}

export struct VoiceChannelMember {
    id: string,
    name: string,
    initials: string,
    avatar: image,
    has-avatar: bool,
    speaking: bool,
    joined_at: int,
}

export struct VoiceChannelData {
    id: string,
    name: string,
    member-count: int,
    is-default: bool,
    expanded: bool,
    active: bool,
    members: [VoiceChannelMember],
}

export struct AudioDeviceData {
    id: string,
    name: string,
    is-default: bool,
}

export struct CaptureSourceData {
    id: string,
    name: string,
    mode: string,
    pid: int,
    exe: string,
    is-fullscreen: bool,
    resolution: string,
    thumbnail: image,
    has-thumbnail: bool,
}

export struct DiscoverCrewData {
