export struct CrewData {
    id: string,
    name: string,
    description: string,
    member-count: int,
    online-count: int,

    avatar: image,
    has-avatar: bool,

    has-stream: bool,
    stream-name: string,

    voice-count: int,
    v0-initials: string, v0-name: string, v0-speaking: bool,
    v1-initials: string, v1-name: string, v1-speaking: bool,
    v2-initials: string, v2-name: string, v2-speaking: bool,
    v3-initials: string, v3-name: string, v3-speaking: bool,

    msg-count: int,
    m0-author: string, m0-text: string,
    m1-author: string, m1-text: string,

    unread-count: int,
    unread-mention: bool,

    sfu-enabled: bool,

    catchup-text: string,
    has-catchup: bool,
    catchup-count: int,
    catchup-loaded: bool,

    game-count: int,
    g0-name: string, g0-initial: string, g0-count: int,
    g1-name: string, g1-initial: string, g1-count: int,
    g2-name: string, g2-initial: string, g2-count: int,
    g3-name: string, g3-initial: string, g3-count: int,
    g4-name: string, g4-initial: string, g4-count: int,

    clip-count: int,
}

// Recap "this week in games" rows (spec 19). Avatars resolve client-side from
// the cache by user-id; fall back to the initials dot when not cached.
export struct RecapLbRow {
    name: string,
    initials: string,
    record: string,      // "12W 5L"
    color-index: int,
    avatar: image,
    has-avatar: bool,
}

export struct RecapAwardRow {
    kind: string,        // "grinder" | "heater" | "skid"
    title: string,
    name: string,
    detail: string,
}

export struct FeedCardData {
    id: string,
    card-type: string,
    role: string,
    size: string,
    title: string,
    subtitle: string,
    timestamp: string,
    duration: string,
    duration-min: int,
    actor-name: string,
    actor-initials: string,
    game-name: string,
    participant-count: int,
    clip-count: int,
    clip-path: string,
    is-hero: bool,
    is-skeleton: bool,
    snapshot-urls: [string],
    mvp-count: int,
    mvp0-name: string, mvp0-initials: string, mvp0-stat: string,
    mvp1-name: string, mvp1-initials: string, mvp1-stat: string,
    mvp2-name: string, mvp2-initials: string, mvp2-stat: string,
    // Real avatars for the MVP rows (spec 19); fall back to the initials dot.
    mvp0-avatar: image, mvp0-has-avatar: bool,
    mvp1-avatar: image, mvp1-has-avatar: bool,
    mvp2-avatar: image, mvp2-has-avatar: bool,
    // "This week in games" section (spec 19).
    games-summary: string,
    leaderboard: [RecapLbRow],
    awards: [RecapAwardRow],
    is-new: bool,
    was-seen: bool,
    snapshot-loading: bool,
    snapshot-poster: image,
    snapshot-poster-ready: bool,
    snapshot-error: bool,
    snapshot-playback-frame: image,
    snapshot-playback-index: int,
    snapshot-playback-revision: int,

    // Rich game-session card (spec 19 B2). Pre-formatted in Rust.
    game-record: string,        // "5W–3L" (with draws: "5W–3L–1D")
    game-streak-text: string,   // "W4" / "L2" / "—"
    game-streak-positive: bool,
    game-winrate: string,       // "62%" / "—"
    game-matches: int,
}

// Personal stats for the "You strip" pinned atop the crew feed (spec 19).
// Only the viewer sees it; display strings are pre-formatted in Rust.
export struct YouStripData {
    has-stats: bool,        // false → strip hidden (no games tracked yet)
    game-name: string,
    short-name: string,
    game-color: color,
    streak-text: string,    // "W4" / "L2" / "—"
    streak-positive: bool,
    record-text: string,    // "12W 5L"
    win-rate-text: string,  // "62%"
    recent-form: [string],  // each "W" | "L" | "D", newest last
}

export struct StreamCardData {
    host-id: string,
    session-id: string,
    streamer-name: string,
    subtitle: string,
    avatar: image,
    has-avatar: bool,
    avatar-initials: string,
    avatar-color-index: int,
    viewer-count: int,
    stream-width: int,
    stream-height: int,
    can-watch: bool,
}

export struct MemberData {
    id: string,
    name: string,
    initials: string,
    avatar: image,
    has-avatar: bool,
    online: bool,
    speaking: bool,
    role: int,
}

export struct ChatLinkData {
    url: string,
    label: string,
}

export struct ChatMessageData {
    message-id: string,
    sender-id: string,
    sender-name: string,
    sender-initials: string,
    sender-avatar: image,
    has-sender-avatar: bool,
    text: string,
    display-text: string,
    display-styled: styled-text,
    links: [ChatLinkData],
    timestamp: string,
    display-time: string,
    is-group-start: bool,
    is-continuation: bool,
    is-system: bool,
    is-unread-divider: bool,
    is-gif: bool,
    gif-image: image,
    has-gif-image: bool,
    gif-preview-url: string,
    gif-width: int,
    gif-height: int,
    is-clip: bool,
    clip-duration: string,
    clip-id: string,
    mentions-self: bool,
    reply-to-id: string,
    reply-to-name: string,
    reply-preview-text: string,
    is-edited: bool,
    is-deleted: bool,
}

export struct EmojiItemData {
    emoji: string,
    name: string,
}

export struct MentionMemberData {
    user-id: string,
    display-name: string,
    initials: string,
}

export struct GifItemData {
    gif-id: string,
    url: string,
    preview-url: string,
    width: int,
    height: int,
    preview: image,
    has-preview: bool,
}

export struct VoiceChannelMember {
    id: string,
    name: string,
    initials: string,
    avatar: image,
    has-avatar: bool,
    speaking: bool,
    muted: bool,
    deafened: bool,
    joined_at: int,
}

export struct VoiceChannelData {
    id: string,
    name: string,
    member-count: int,
    is-default: bool,
    expanded: bool,
    active: bool,
    members: [VoiceChannelMember],
}

export struct AudioDeviceData {
    id: string,
    name: string,
    is-default: bool,
}

export struct CaptureSourceData {
    id: string,
    name: string,
    mode: string,
    pid: int,
    exe: string,
    is-fullscreen: bool,
    resolution: string,
    thumbnail: image,
    has-thumbnail: bool,
}

export struct DiscoverCrewData {
    id: string,
    name: string,
    description: string,
    member-count: int,
    online-count: int,
    open: bool,
    avatar: image,
    has-avatar: bool,
}

export struct SearchUserData {
    id: string,
    display-name: string,
    is-friend: bool,
}

export global VideoRect {
    // Pushed by StreamCard's changed handlers every time absolute-position,
    // width, or height changes (scroll, resize, layout reflow).
    // Args: canvas_x, canvas_y, canvas_w, canvas_h, viewport_y, viewport_h
    // All in logical pixels; Rust multiplies by scale_factor.
    callback geometry-changed(float, float, float, float, float, float);
}
