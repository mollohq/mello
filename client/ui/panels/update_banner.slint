import { Theme } from "../theme.slint";

export component UpdateToast inherits Rectangle {
    in property <bool> update-available: false;
    in property <string> version: "";
    in property <float> download-progress: -1.0;
    in property <string> protocol-warning: "";

    callback update-clicked();
    callback dismiss-clicked();

    property <bool> show: update-available || protocol-warning != "";
    property <bool> downloading: download-progress >= 0;

    visible: show;
    width: toast.preferred-width + 2 * 16px;
    height: toast.preferred-height + 2 * 12px;
    background: Theme.surface;
    border-color: Theme.graphic-med;
    border-width: 1px;
    border-radius: Theme.r-inner;
    drop-shadow-blur: 32px;
    drop-shadow-color: #00000066;
    drop-shadow-offset-y: 8px;

    toast := HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 12px;
        padding-bottom: 12px;
        spacing: 16px;
        alignment: center;

        VerticalLayout {
            alignment: center;
            spacing: 2px;

            Text {
                text: protocol-warning != "" ? protocol-warning
                    : downloading ? "Updating…"
                    : "New version available";
                color: Theme.text-primary;
                font-family: Theme.font-sans;
                font-size: 12px;
                font-weight: 600;
                letter-spacing: -0.02 * 1px;
            }

            if protocol-warning == "": Text {
                text: downloading ? "Downloading v" + version
                    : "v" + version;
                color: Theme.text-secondary;
                font-family: Theme.font-mono;
                font-size: Theme.font-xs;
            }
        }

        if downloading && protocol-warning == "": Rectangle {
            width: 80px;
            height: 4px;
            background: Theme.graphic-light;
            border-radius: 2px;
            y: (parent.height - self.height) / 2;

            Rectangle {
                width: parent.width * clamp(download-progress, 0, 1);
                height: parent.height;
                background: Theme.accent;
                border-radius: 2px;
                animate width { duration: 100ms; }
            }
        }

        if !downloading && protocol-warning == "": Rectangle {
            width: btn-layout.preferred-width;
            height: 28px;
            background: ta.has-hover ? #FF3D6E : Theme.accent;
            border-radius: Theme.r-inner;
            animate background { duration: 150ms; }

            btn-layout := HorizontalLayout {
                alignment: center;
                padding-left: 14px;
                padding-right: 14px;

                Text {
                    text: "UPDATE";
                    color: white;
                    font-family: Theme.font-mono;
                    font-size: Theme.font-xs;
                    font-weight: 600;
                    letter-spacing: 0.06 * 1px;
                    vertical-alignment: center;
                }
            }

            ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.update-clicked(); }
            }
        }
    }
}
