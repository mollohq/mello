import { Theme } from "../theme.slint";
import { CrewData } from "../types.slint";

export component CrewPanel inherits Rectangle {
    in property <[CrewData]> crews: [];
    in property <string> active-crew-id: "";

    callback crew-selected(string);
    callback crew-create-requested(string);

    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.graphic-light;
    border-radius: Theme.r-outer;

    VerticalLayout {
        padding: Theme.pad;
        spacing: 0px;

        // --- Header kicker ---
        HorizontalLayout {
            height: 16px;
            spacing: 8px;

            Text {
                text: "YOUR CREWS";
                font-size: Theme.font-sm;
                font-weight: 600;
                letter-spacing: 1.3px;
                color: Theme.text-secondary;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background: Theme.accent;
                y: (parent.height - self.height) / 2;
            }
        }

        Rectangle { height: 20px; }

        // --- Stats ---
        HorizontalLayout {
            height: 36px;

            Text {
                text: crews.length;
                font-size: Theme.font-xxl;
                font-weight: 400;
                color: Theme.text-primary;
                vertical-alignment: bottom;
                letter-spacing: -0.5px;
            }

            Rectangle { width: 6px; }

            Text {
                text: "ACT";
                font-size: Theme.font-md;
                font-weight: 600;
                color: Theme.text-primary;
                vertical-alignment: bottom;
                letter-spacing: 0.5px;
            }
        }

        Text {
            text: "GLOBAL NETWORK";
            font-family: Theme.font-mono;
            font-size: Theme.font-md;
            color: Theme.text-secondary;
            letter-spacing: -0.3px;
        }

        Rectangle { height: 40px; }

        // --- Crew list (scrollable) ---
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 0px;

                // "ACTIVE NOW" section kicker
                Text {
                    text: "ACTIVE NOW";
                    font-size: Theme.font-xs;
                    font-weight: 600;
                    letter-spacing: 1.3px;
                    color: Theme.text-secondary;
                    height: 16px;
                }

                Rectangle { height: 12px; }

                for crew[i] in crews: Rectangle {
                    height: 44px;
                    border-radius: Theme.r-inner;
                    background: crew.id == active-crew-id
                        ? Theme.bg-app
                        : (item-hover.has-hover ? Theme.bg-app : transparent);

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 12px;
                        alignment: center;

                        // Status dot
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: crew.id == active-crew-id
                                ? Theme.accent
                                : Theme.graphic-med;
                        }

                        // Crew name
                        Text {
                            text: crew.name;
                            font-family: Theme.font-mono;
                            font-size: Theme.font-md;
                            font-weight: crew.id == active-crew-id ? 500 : 400;
                            color: crew.id == active-crew-id
                                ? Theme.text-primary
                                : (item-hover.has-hover ? Theme.text-primary : Theme.text-secondary);
                            horizontal-stretch: 1;
                            overflow: elide;
                            vertical-alignment: center;
                        }

                        // Member count
                        Text {
                            text: crew.online-count > 0
                                ? crew.online-count + "/" + crew.member-count
                                : crew.member-count;
                            font-family: Theme.font-mono;
                            font-size: Theme.font-sm;
                            color: Theme.text-tertiary;
                            vertical-alignment: center;
                        }
                    }

                    item-hover := TouchArea {
                        clicked => { crew-selected(crew.id); }
                    }
                }
            }
        }

        // --- Create crew input ---
        Rectangle { height: Theme.gap; }

        Rectangle {
            height: 40px;
            background: Theme.bg-app;
            border-radius: Theme.r-inner;
            border-width: 1px;
            border-color: Theme.graphic-light;

            crew-name-input := TextInput {
                x: 14px;
                width: parent.width - 28px;
                height: parent.height;
                font-family: Theme.font-mono;
                font-size: Theme.font-md;
                color: Theme.text-primary;
                vertical-alignment: center;
                accepted => {
                    if crew-name-input.text != "" {
                        crew-create-requested(crew-name-input.text);
                        crew-name-input.text = "";
                    }
                }
            }
            if crew-name-input.text == "": Text {
                x: 14px;
                color: Theme.text-tertiary;
                font-family: Theme.font-mono;
                font-size: Theme.font-md;
                vertical-alignment: center;
                text: "+ New crew";
            }
        }
    }
}
