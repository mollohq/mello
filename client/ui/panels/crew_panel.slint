import { Theme } from "../theme.slint";
import { CrewData, VoiceChannelData, VoiceChannelMember } from "../types.slint";

component VcMemberRow inherits Rectangle {
    in property <string> name;
    in property <string> initials;
    in property <bool> speaking: false;
    in property <bool> muted: false;
    in property <bool> deafened: false;
    in property <image> avatar;
    in property <bool> has-avatar: false;

    height: 30px;
    border-radius: 6px;
    background: transparent;
    border-width: 0px;
    border-color: transparent;

    HorizontalLayout {
        spacing: 7px;
        padding-left: 8px;
        padding-right: 8px;

        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 4px;
            background: Theme.graphic-med;
            border-width: speaking ? 2px : 0px;
            border-color: speaking ? Theme.accent-green : transparent;
            clip: true;
            y: (parent.height - self.height) / 2;

            if has-avatar: Image {
                source: avatar;
                width: parent.width;
                height: parent.height;
                image-fit: cover;
            }

            if !has-avatar: Text {
                text: initials;
                font-family: Theme.font-mono;
                font-size: 8px;
                font-weight: 600;
                color: white;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: name;
            font-size: 12px;
            color: speaking ? Theme.text-primary : Theme.text-dim;
            font-weight: speaking ? 500 : 400;
            horizontal-stretch: 1;
            overflow: elide;
            vertical-alignment: center;
        }

        Rectangle {
            width: (muted || deafened) ? 12px : 0px;
            height: 12px;

            if deafened: Image {
                source: @image-url("../icons/headphone-off.svg");
                width: 12px;
                height: 12px;
                colorize: Theme.graphic-med;
            }

            if muted && !deafened: Image {
                source: @image-url("../icons/mic-off.svg");
                width: 12px;
                height: 12px;
                colorize: Theme.graphic-med;
            }
        }
    }
}

component CatchupStoryCard inherits Rectangle {
    in property <CrewData> crew;

    background: transparent;
    border-width: 0px;
    height: 14px;
    vertical-stretch: 0;

    HorizontalLayout {
        spacing: 4px;

        Rectangle {
            width: 3px;
            height: 3px;
            border-radius: 2px;
            background: crew.catchup-loaded
                ? (crew.catchup-count > 0 ? Theme.accent : Theme.graphic-med)
                : Theme.skel-text;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: crew.catchup-loaded
                ? (
                    crew.catchup-count > 0
                        ? (
                            crew.catchup-text == ""
                                ? ("While away (" + crew.catchup-count + "): activity picked up.")
                                : ("While away (" + crew.catchup-count + "): " + crew.catchup-text)
                        )
                        : "All quiet lately."
                )
                : "Loading recent story...";
            font-family: Theme.font-mono;
            font-size: 10px;
            color: Theme.text-sub;
            horizontal-stretch: 1;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component SidebarActionButton inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    callback tapped();

    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.card-border;
    background: btn-touch.has-hover ? Theme.surface-hover : Theme.card-bg-skel;

    HorizontalLayout {
        alignment: center;
        spacing: 5px;

        Rectangle {
            width: 12px;
            height: parent.height;

            Image {
                source: icon;
                width: 12px;
                height: 12px;
                colorize: btn-touch.has-hover ? Theme.text-sub : Theme.text-dim;
                y: (parent.height - self.height) / 2;
            }
        }

        Text {
            text: label;
            font-size: 10px;
            font-weight: 500;
            color: btn-touch.has-hover ? Theme.text-sub : Theme.text-dim;
            vertical-alignment: center;
        }
    }

    btn-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            tapped();
        }
    }
}

component CompactCrewCard inherits Rectangle {
    in property <CrewData> crew;
    callback selected(string);

    border-radius: 10px;
    background: card-touch.has-hover ? (Theme.dark ? #202226 : Theme.card-bg-hover) : (Theme.dark ? #1A1B1E : Theme.card-bg-skel);
    border-width: 1px;
    border-color: card-touch.has-hover ? (Theme.dark ? #36393F : Theme.graphic-med) : Theme.card-border;

    VerticalLayout {
        padding: 10px;
        padding-left: 11px;
        padding-right: 11px;
        spacing: 5px;

        HorizontalLayout {
            spacing: 7px;
            height: 24px;

            if crew.has-avatar: Rectangle {
                width: 22px;
                height: 22px;
                border-radius: 5px;
                clip: true;
                opacity: card-touch.has-hover ? 0.72 : 0.52;
                y: (parent.height - self.height) / 2;

                Image {
                    source: crew.avatar;
                    width: parent.width;
                    height: parent.height;
                    image-fit: cover;
                }
            }

            if !crew.has-avatar: Rectangle {
                width: 22px;
                height: 22px;
                border-radius: 5px;
                background: Theme.card-border;
                opacity: card-touch.has-hover ? 0.68 : 0.48;
                y: (parent.height - self.height) / 2;

                Text {
                    text: crew.name;
                    font-size: 7px;
                    font-family: Theme.font-mono;
                    font-weight: 700;
                    color: Theme.text-dim;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: clip;
                }
            }

            Text {
                text: crew.name;
                font-size: 13px;
                font-weight: 700;
                color: card-touch.has-hover ? #C8CDD8 : #9198A7;
                horizontal-stretch: 1;
                overflow: elide;
                vertical-alignment: center;
            }

            if crew.has-stream: Rectangle {
                border-radius: 3px;
                background: #dc2626;
                height: 16px;
                min-width: 34px;
                vertical-stretch: 0;

                HorizontalLayout {
                    alignment: center;
                    spacing: 3px;
                    padding-left: 4px;
                    padding-right: 5px;

                    Rectangle {
                        width: 4px;
                        height: 4px;
                        border-radius: 2px;
                        background: white;
                        y: (parent.height - self.height) / 2;
                    }

                    Text {
                        text: "LIVE";
                        font-size: 8px;
                        font-weight: 700;
                        color: white;
                        vertical-alignment: center;
                    }
                }
            }

            if crew.clip-count > 0 && !crew.has-stream: Rectangle {
                border-radius: 4px;
                border-width: 1px;
                border-color: Theme.dark ? #EB4D5F22 : #EB4D5F33;
                background: Theme.dark ? #EB4D5F18 : #EB4D5F14;
                height: 16px;
                min-width: 31px;
                vertical-stretch: 0;

                HorizontalLayout {
                    alignment: center;
                    spacing: 3px;
                    padding-left: 4px;
                    padding-right: 5px;

                    Image {
                        source: @image-url("../icons/scissors.svg");
                        width: 8px;
                        height: 8px;
                        colorize: Theme.dark ? #EB4D5F88 : #EB4D5FAA;
                        y: (parent.height - self.height) / 2;
                    }

                    Text {
                        text: crew.clip-count;
                        font-size: 9px;
                        font-weight: 700;
                        color: Theme.dark ? #EB4D5F88 : #EB4D5FAA;
                        vertical-alignment: center;
                    }
                }
            }

            if crew.voice-count > 0: Rectangle {
                border-radius: 4px;
                border-width: 1px;
                border-color: Theme.card-border;
                background: Theme.card-bg-inset;
                height: 16px;
                min-width: 24px;
                vertical-stretch: 0;

                HorizontalLayout {
                    alignment: center;
                    spacing: 3px;
                    padding-left: 4px;
                    padding-right: 5px;

                    Text {
                        text: crew.voice-count;
                        font-family: Theme.font-mono;
                        font-size: 9px;
                        font-weight: 700;
                        color: Theme.text-sub;
                        vertical-alignment: center;
                    }

                    Image {
                        source: @image-url("../icons/headphones.svg");
                        width: 8px;
                        height: 8px;
                        colorize: Theme.accent-green;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }
        }

        if crew.game-count > 0: Rectangle {
            height: 12px;

            HorizontalLayout {
                Text {
                    text: "MOST PLAYED LAST WEEK";
                    font-size: 9px;
                    font-weight: 600;
                    color: Theme.skel-text;
                    vertical-alignment: center;
                }
            }
        }

        if crew.game-count > 0: HorizontalLayout {
            spacing: 4px;

            if crew.g0-name != "": Rectangle {
                border-radius: 3px;
                border-width: 1px;
                border-color: Theme.card-border;
                background: Theme.dark ? #77777714 : #7777770E;
                height: 14px;
                min-width: 12px;
                vertical-stretch: 0;

                Text {
                    text: crew.g0-name;
                    font-size: 8px;
                    color: Theme.text-sub;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    x: 4px;
                    width: parent.width - 8px;
                }
            }
            if crew.g1-name != "": Rectangle {
                border-radius: 3px;
                border-width: 1px;
                border-color: Theme.card-border;
                background: Theme.dark ? #77777714 : #7777770E;
                height: 14px;
                min-width: 12px;
                vertical-stretch: 0;

                Text {
                    text: crew.g1-name;
                    font-size: 8px;
                    color: Theme.text-sub;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    x: 4px;
                    width: parent.width - 8px;
                }
            }
            if crew.g2-name != "": Rectangle {
                border-radius: 3px;
                border-width: 1px;
                border-color: Theme.card-border;
                background: Theme.dark ? #77777714 : #7777770E;
                height: 14px;
                min-width: 12px;
                vertical-stretch: 0;

                Text {
                    text: crew.g2-name;
                    font-size: 8px;
                    color: Theme.text-sub;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    x: 4px;
                    width: parent.width - 8px;
                }
            }
        }

        CatchupStoryCard {
            crew: crew;
        }
    }

    card-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            selected(crew.id);
        }
    }
}

component ActiveCrewCard inherits Rectangle {
    in property <CrewData> crew;
    in property <[VoiceChannelData]> voice-channels;
    in property <length> card-height: 320px;
    in property <bool> can-manage: false;
    callback join-voice(string);
    callback invite-clicked();
    callback crew-edit-requested();
    callback crew-leave-requested();
    callback crew-add-channel-requested();

    border-radius: 10px;
    background: Theme.dark ? #1A1B1E : Theme.card-bg;
    border-width: 1px;
    border-color: Theme.dark ? #3D4048 : Theme.graphic-med;
    clip: true;
    height: card-height;

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: 56px;
            background: Theme.dark ? #222428 : Theme.card-bg-hover;
            border-width: 0px;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;

                if crew.has-avatar: Rectangle {
                    width: 32px;
                    height: 32px;
                    border-radius: 7px;
                    clip: true;
                    y: (parent.height - self.height) / 2;

                    Image {
                        source: crew.avatar;
                        width: parent.width;
                        height: parent.height;
                        image-fit: cover;
                    }
                }

                if !crew.has-avatar: Rectangle {
                    width: 32px;
                    height: 32px;
                    border-radius: 7px;
                    background: Theme.accent;
                    y: (parent.height - self.height) / 2;

                    Text {
                        text: crew.name;
                        font-size: 9px;
                        font-family: Theme.font-mono;
                        font-weight: 800;
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: clip;
                    }
                }

                Text {
                    text: crew.name;
                    font-size: 14px;
                    font-weight: 700;
                    color: Theme.text-primary;
                    horizontal-stretch: 1;
                    horizontal-alignment: center;
                    overflow: elide;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: 24px;

                    Rectangle {
                        width: 24px;
                        height: 24px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 5px;
                        background: invite-touch.has-hover ? Theme.card-bg-hover : transparent;

                        Image {
                            source: @image-url("../icons/user-plus.svg");
                            width: 14px;
                            height: 14px;
                            colorize: Theme.text-sub;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }

                        invite-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.invite-clicked(); }
                        }
                    }
                }

                Rectangle {
                    width: 24px;

                    Rectangle {
                        width: 24px;
                        height: 24px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 5px;
                        background: chevron-touch.has-hover ? Theme.card-bg-hover : transparent;

                        Image {
                            source: @image-url("../icons/chevron-down.svg");
                            width: 12px;
                            height: 12px;
                            colorize: chevron-touch.has-hover ? Theme.text-primary : Theme.text-sub;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }

                        chevron-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { crew-context-popup.show(); }
                        }
                    }
                }
            }
        }

        crew-context-popup := PopupWindow {
            x: root.width - 172px;
            y: 52px;
            width: 164px;

            Rectangle {
                background: Theme.surface;
                border-radius: Theme.r-inner;
                border-width: 1px;
                border-color: Theme.graphic-light;
                drop-shadow-blur: 12px;
                drop-shadow-color: Theme.dark ? #00000060 : #00000018;
                drop-shadow-offset-y: 4px;

                VerticalLayout {
                    padding: 4px;

                    if root.can-manage: Rectangle {
                        height: 32px;
                        border-radius: 6px;
                        background: ctx-edit-ta.has-hover ? Theme.hover-overlay : transparent;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;

                            Image {
                                source: @image-url("../icons/settings.svg");
                                width: 14px;
                                height: 14px;
                                colorize: Theme.text-secondary;
                                y: (parent.height - self.height) / 2;
                            }

                            Text {
                                text: "Crew settings";
                                font-size: 13px;
                                color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                        }

                        ctx-edit-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.crew-edit-requested(); }
                        }
                    }

                    if root.can-manage: Rectangle {
                        height: 32px;
                        border-radius: 6px;
                        background: ctx-add-ch-ta.has-hover ? Theme.hover-overlay : transparent;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;

                            Image {
                                source: @image-url("../icons/plus.svg");
                                width: 14px;
                                height: 14px;
                                colorize: Theme.text-secondary;
                                y: (parent.height - self.height) / 2;
                            }

                            Text {
                                text: "Add channel";
                                font-size: 13px;
                                color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                        }

                        ctx-add-ch-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.crew-add-channel-requested(); }
                        }
                    }

                    Rectangle {
                        height: 32px;
                        border-radius: 6px;
                        background: ctx-invite-ta.has-hover ? Theme.hover-overlay : transparent;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;

                            Image {
                                source: @image-url("../icons/user-plus.svg");
                                width: 14px;
                                height: 14px;
                                colorize: Theme.text-secondary;
                                y: (parent.height - self.height) / 2;
                            }

                            Text {
                                text: "Invite";
                                font-size: 13px;
                                color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                        }

                        ctx-invite-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.invite-clicked(); }
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: Theme.graphic-light;
                    }

                    Rectangle {
                        height: 32px;
                        border-radius: 6px;
                        background: ctx-leave-ta.has-hover ? Theme.hover-overlay : transparent;

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;

                            Image {
                                source: @image-url("../icons/x.svg");
                                width: 14px;
                                height: 14px;
                                colorize: #ef4444;
                                y: (parent.height - self.height) / 2;
                            }

                            Text {
                                text: "Leave crew";
                                font-size: 13px;
                                color: #ef4444;
                                vertical-alignment: center;
                            }
                        }

                        ctx-leave-ta := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.crew-leave-requested(); }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.card-border;
        }

        Rectangle {
            vertical-stretch: 1;
            clip: true;

            Flickable {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;

                VerticalLayout {
                    padding: 7px;
                    spacing: 5px;

                    for ch in voice-channels: VerticalLayout {
                        spacing: 2px;

                        if ch.member-count > 0: Rectangle {
                            height: 22px;
                            border-radius: 5px;
                            background: ch.active ? (Theme.dark ? #2B2D31AA : Theme.card-border) : (ch-touch.has-hover ? Theme.card-border : transparent);

                            HorizontalLayout {
                                padding-left: 7px;
                                padding-right: 7px;
                                spacing: 5px;

                                Image {
                                    source: @image-url("../icons/chevron-down.svg");
                                    width: 8px;
                                    height: 8px;
                                    colorize: ch.active ? Theme.text-sub : Theme.text-dim;
                                    y: (parent.height - self.height) / 2;
                                }

                                Text {
                                    text: ch.name;
                                    font-size: 12px;
                                    font-weight: 600;
                                    color: ch.active ? Theme.text-primary : Theme.text-sub;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }

                                Text {
                                    text: ch.member-count;
                                    font-family: Theme.font-mono;
                                    font-size: 10px;
                                    font-weight: 700;
                                    color: ch.member-count > 0 ? (ch.active ? Theme.accent : #F59E0B) : Theme.text-tertiary;
                                    vertical-alignment: center;
                                    min-width: 14px;
                                    horizontal-alignment: right;
                                }

                                if ch.member-count > 0: Image {
                                    source: @image-url("../icons/speaker.svg");
                                    width: 10px;
                                    height: 10px;
                                    colorize: Theme.text-tertiary;
                                    y: (parent.height - self.height) / 2;
                                }
                            }

                            ch-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    join-voice(ch.id);
                                }
                            }
                        }

                        if ch.member-count > 0: VerticalLayout {
                            spacing: 2px;

                            for member in ch.members: VcMemberRow {
                                name: member.name;
                                initials: member.initials;
                                speaking: member.speaking;
                                muted: member.muted;
                                deafened: member.deafened;
                                avatar: member.avatar;
                                has-avatar: member.has-avatar;
                            }
                        }

                        if ch.member-count == 0: Rectangle {
                            height: 24px;
                            border-radius: 5px;
                            background: ch-touch-empty.has-hover ? (Theme.dark ? #2B2D3122 : Theme.card-border) : transparent;

                            HorizontalLayout {
                                padding-left: 7px;
                                padding-right: 7px;
                                spacing: 6px;

                                Image {
                                    source: @image-url("../icons/mic.svg");
                                    width: 11px;
                                    height: 11px;
                                    colorize: Theme.text-tertiary;
                                    y: (parent.height - self.height) / 2;
                                }

                                Text {
                                    text: ch.name + " [0]";
                                    font-size: 11px;
                                    color: Theme.text-tertiary;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }
                            }

                            ch-touch-empty := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    join-voice(ch.id);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

export component CrewPanel inherits Rectangle {
    in property <[CrewData]> crews: [];
    in property <string> active-crew-id: "";
    in property <[VoiceChannelData]> voice-channels: [];
    in property <bool> can-manage: false;

    callback crew-selected(string);
    callback crew-create-requested();
    callback browse-crews-requested();
    callback join-voice-channel(string);
    callback invite-clicked();
    callback crew-edit-requested();
    callback crew-leave-requested();
    callback crew-add-channel-requested();

    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.graphic-light;
    border-radius: 0px;

    VerticalLayout {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        padding: 0px;
        spacing: 6px;

        Rectangle {
            vertical-stretch: 1;
            clip: true;

            Flickable {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;

                VerticalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 6px;
                    spacing: 8px;

                    for crew in crews: VerticalLayout {
                        if crew.id == active-crew-id: ActiveCrewCard {
                            crew: crew;
                            voice-channels: root.voice-channels;
                            card-height: root.height * 0.48;
                            can-manage: root.can-manage;
                            join-voice(id) => {
                                join-voice-channel(id);
                            }
                            invite-clicked => {
                                root.invite-clicked();
                            }
                            crew-edit-requested => {
                                root.crew-edit-requested();
                            }
                            crew-leave-requested => {
                                root.crew-leave-requested();
                            }
                            crew-add-channel-requested => {
                                root.crew-add-channel-requested();
                            }
                        }
                        if crew.id != active-crew-id: CompactCrewCard {
                            crew: crew;
                            selected(id) => {
                                crew-selected(id);
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 0;
            height: 1px;
            background: Theme.card-border;
        }

        HorizontalLayout {
            vertical-stretch: 0;
            padding-left: 8px;
            padding-right: 8px;
            padding-bottom: 3px;
            spacing: 7px;
            height: 30px;

            SidebarActionButton {
                horizontal-stretch: 1;
                label: "New crew";
                icon: @image-url("../icons/plus.svg");
                tapped => {
                    crew-create-requested();
                }
            }

            SidebarActionButton {
                horizontal-stretch: 1;
                label: "Discover";
                icon: @image-url("../icons/compass.svg");
                tapped => {
                    browse-crews-requested();
                }
            }
        }
    }
}

