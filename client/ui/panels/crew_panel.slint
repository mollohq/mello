import { Theme } from "../theme.slint";
import { CrewData, VoiceChannelData, VoiceChannelMember } from "../types.slint";

component VoiceBars inherits HorizontalLayout {
    in property <bool> speaking: false;
    spacing: 2px;
    alignment: center;

    Rectangle {
        width: 2px;
        height: speaking ? 8px : 4px;
        border-radius: 1px;
        background: speaking ? Theme.accent : Theme.graphic-med;
    }

    Rectangle {
        width: 2px;
        height: speaking ? 12px : 4px;
        border-radius: 1px;
        background: speaking ? Theme.accent : Theme.graphic-med;
    }

    Rectangle {
        width: 2px;
        height: speaking ? 8px : 4px;
        border-radius: 1px;
        background: speaking ? Theme.accent : Theme.graphic-med;
    }
}

component VcMemberRow inherits Rectangle {
    in property <string> name;
    in property <string> initials;
    in property <bool> speaking: false;
    in property <image> avatar;
    in property <bool> has-avatar: false;

    height: 22px;

    HorizontalLayout {
        spacing: 7px;
        padding-left: 31px;

        Rectangle {
            width: 18px;
            height: 18px;
            border-radius: 4px;
            background: speaking ? Theme.graphic-med : Theme.graphic-light;
            clip: true;
            y: (parent.height - self.height) / 2;

            if has-avatar: Image {
                source: avatar;
                width: parent.width;
                height: parent.height;
                image-fit: cover;
            }

            if !has-avatar: Text {
                text: initials;
                font-family: Theme.font-mono;
                font-size: 7px;
                font-weight: 600;
                color: white;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: name;
            font-size: 11px;
            color: Theme.text-sub;
            horizontal-stretch: 1;
            overflow: elide;
            vertical-alignment: center;
        }

        if speaking: VoiceBars {
            speaking: true;
        }
    }
}

component CrewMsg inherits HorizontalLayout {
    in property <string> author;
    in property <string> body;

    spacing: 6px;
    height: 14px;

    Text {
        text: author;
        font-family: Theme.font-mono;
        font-size: 10px;
        font-weight: 600;
        color: Theme.skel-text;
        vertical-alignment: center;
    }

    Text {
        text: body;
        font-family: Theme.font-mono;
        font-size: 10px;
        color: Theme.text-tertiary;
        horizontal-stretch: 1;
        overflow: elide;
        vertical-alignment: center;
    }
}

export component CrewPanel inherits Rectangle {
    in property <[CrewData]> crews: [];
    in property <string> active-crew-id: "";
    in property <[VoiceChannelData]> voice-channels: [];

    callback crew-selected(string);
    callback crew-create-requested();
    callback browse-crews-requested();
    callback join-voice-channel(string);

    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.graphic-light;
    border-radius: Theme.r-outer;

    property <length> bottom-h: 97px;

    VerticalLayout {
        padding: 14px;
        spacing: 0px;

        // ===== Section label =====
        Text {
            text: "Your crews";
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1.2px;
            color: Theme.skel-text;
            height: 20px;
        }

        // ===== ACTIVE CREW CARD =====
        for crew[i] in crews: Rectangle {
            visible: crew.id == active-crew-id;
            height: self.visible ? Math.min(self.preferred-height, root.height * 0.5) : 0px;

            VerticalLayout {
                spacing: 0px;

                Rectangle {
                    border-radius: 10px;
                    background: Theme.card-bg;
                    border-width: 1px;
                    border-color: Theme.dark ? #EB4D5F33 : #FF1E5622;
                    clip: true;

                    VerticalLayout {
                        spacing: 0px;

                        // --- Header ---
                        Rectangle {
                            height: 54px;
                            border-width: 0px;

                            HorizontalLayout {
                                padding: 12px;
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 10px;

                                if crew.has-avatar: Rectangle {
                                    width: 30px;
                                    height: 30px;
                                    border-radius: 7px;
                                    clip: true;
                                    y: (parent.height - self.height) / 2;

                                    Image {
                                        source: crew.avatar;
                                        width: parent.width;
                                        height: parent.height;
                                        image-fit: cover;
                                    }
                                }

                                if !crew.has-avatar: Rectangle {
                                    width: 30px;
                                    height: 30px;
                                    border-radius: 7px;
                                    background: Theme.accent;
                                    y: (parent.height - self.height) / 2;

                                    Text {
                                        text: crew.name;
                                        font-size: 10px;
                                        font-weight: 700;
                                        color: white;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    spacing: 2px;

                                    Text {
                                        text: crew.name;
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: Theme.text-primary;
                                        overflow: elide;
                                    }

                                    HorizontalLayout {
                                        spacing: 6px;

                                        if crew.sfu-enabled: Rectangle {
                                            width: 30px;
                                            height: 14px;
                                            border-radius: 3px;
                                            background: Theme.dark ? #4ade8022 : #28C84018;

                                            Text {
                                                text: "SFU";
                                                font-size: 8px;
                                                font-weight: 700;
                                                letter-spacing: 0.5px;
                                                color: Theme.accent-green;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }

                                        Text {
                                            text: crew.online-count + " / " + crew.member-count;
                                            font-size: 11px;
                                            color: Theme.text-dim;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                Rectangle {
                                    width: 8px;
                                    height: 8px;
                                    border-radius: 4px;
                                    background: Theme.accent;
                                    y: (parent.height - self.height) / 2;
                                }
                            }

                            // Bottom border
                            Rectangle {
                                y: parent.height - 1px;
                                height: 1px;
                                background: Theme.card-border;
                            }
                        }

                        // --- Voice channels ---
                        Flickable {
                            VerticalLayout {
                                padding-top: 8px;
                                padding-bottom: 8px;
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 2px;

                                for ch in voice-channels: VerticalLayout {
                                    spacing: 4px;

                                    // Channel row
                                    Rectangle {
                                        height: 30px;
                                        border-radius: 6px;
                                        background: ch.active ? Theme.card-border : (ch-hover.has-hover ? Theme.card-border : transparent);

                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            spacing: 7px;

                                            Image {
                                                source: @image-url("../icons/mic.svg");
                                                width: 14px;
                                                height: 14px;
                                                colorize: ch.active ? Theme.text-sub : Theme.text-dim;
                                                y: (parent.height - self.height) / 2;
                                            }

                                            Text {
                                                text: ch.name;
                                                font-size: 12px;
                                                color: ch.active ? Theme.text-primary : Theme.text-sub;
                                                horizontal-stretch: 1;
                                                overflow: elide;
                                                vertical-alignment: center;
                                            }

                                            Text {
                                                text: ch.member-count;
                                                font-size: 11px;
                                                font-weight: 500;
                                                color: ch.member-count > 0 ? Theme.accent-green : Theme.text-tertiary;
                                                vertical-alignment: center;
                                                min-width: 14px;
                                                horizontal-alignment: right;
                                            }
                                        }

                                        ch-hover := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                join-voice-channel(ch.id);
                                            }
                                        }
                                    }

                                    // Members under channel
                                    if ch.member-count > 0: VerticalLayout {
                                        spacing: 4px;

                                        for member in ch.members: VcMemberRow {
                                            name: member.name;
                                            initials: member.initials;
                                            speaking: member.speaking;
                                            avatar: member.avatar;
                                            has-avatar: member.has-avatar;
                                        }
                                    }

                                    Rectangle { height: 2px; }
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 12px; }
            }
        }

        // ===== Other crews section label =====
        Text {
            text: "Other crews";
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1.2px;
            color: Theme.skel-text;
            height: 20px;
        }

        Rectangle { height: 4px; }

        // ===== NON-ACTIVE CREW CARDS =====
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 6px;

                for crew[i] in crews: Rectangle {
                    visible: crew.id != active-crew-id;
                    height: self.visible ? self.preferred-height : 0px;

                    Rectangle {
                        border-radius: 8px;
                        background: other-hover.has-hover ? Theme.card-bg : Theme.card-bg-skel;
                        border-width: 1px;
                        border-color: other-hover.has-hover ? Theme.graphic-med : Theme.card-border;

                        VerticalLayout {
                            padding: 10px;
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 6px;

                            // --- Header row ---
                            HorizontalLayout {
                                spacing: 7px;
                                height: 22px;

                                if crew.has-avatar: Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    border-radius: 5px;
                                    clip: true;
                                    opacity: crew.voice-count > 0 || crew.has-stream ? 0.8 : 0.6;

                                    Image {
                                        source: crew.avatar;
                                        width: parent.width;
                                        height: parent.height;
                                        image-fit: cover;
                                    }
                                }

                                if !crew.has-avatar: Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    border-radius: 5px;
                                    background: Theme.card-border;
                                    opacity: crew.voice-count > 0 || crew.has-stream ? 0.8 : 0.6;

                                    Text {
                                        text: crew.name;
                                        font-size: 8px;
                                        font-weight: 700;
                                        color: Theme.text-dim;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Text {
                                    text: crew.name;
                                    font-size: 12px;
                                    font-weight: 500;
                                    color: other-hover.has-hover ? Theme.text-value : Theme.text-sub;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }

                                // Clips FOMO badge
                                if crew.clip-count > 0: Rectangle {
                                    width: 38px;
                                    height: 18px;
                                    border-radius: 4px;
                                    background: Theme.clip-amber-bg;
                                    border-width: 1px;
                                    border-color: Theme.dark ? #F59E0B22 : #F59E0B33;

                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 3px;

                                        Image {
                                            source: @image-url("../icons/scissors.svg");
                                            colorize: #F59E0B88;
                                            width: 10px;
                                            height: 10px;
                                            y: (parent.height - self.height) / 2;
                                        }

                                        Text {
                                            text: crew.clip-count;
                                            font-size: 9px;
                                            font-weight: 700;
                                            color: #F59E0B88;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }

                            // --- Activity line ---
                            if crew.has-stream: HorizontalLayout {
                                spacing: 5px;
                                height: 14px;
                                padding-left: 29px;

                                Rectangle {
                                    width: 4px;
                                    height: 4px;
                                    border-radius: 2px;
                                    background: Theme.accent;
                                    opacity: 0.6;
                                    y: (parent.height - self.height) / 2;
                                }

                                Text {
                                    text: crew.stream-name;
                                    font-size: 10px;
                                    color: Theme.skel-text;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                            }

                            if !crew.has-stream && crew.voice-count > 0: HorizontalLayout {
                                spacing: 5px;
                                height: 14px;
                                padding-left: 29px;

                                Rectangle {
                                    width: 4px;
                                    height: 4px;
                                    border-radius: 2px;
                                    background: Theme.accent-green;
                                    opacity: 0.6;
                                    y: (parent.height - self.height) / 2;
                                }

                                Text {
                                    text: crew.voice-count + " in voice";
                                    font-size: 10px;
                                    color: Theme.skel-text;
                                    vertical-alignment: center;
                                }
                            }

                            // --- Chat preview ---
                            if crew.msg-count > 0: VerticalLayout {
                                spacing: 3px;
                                padding-left: 29px;

                                CrewMsg {
                                    author: crew.m0-author;
                                    body: crew.m0-text;
                                }

                                if crew.msg-count >= 2: CrewMsg {
                                    author: crew.m1-author;
                                    body: crew.m1-text;
                                }
                            }
                        }

                        other-hover := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                crew-selected(crew.id);
                            }
                        }
                    }
                }
            }
        }

        Rectangle { height: 8px; }

        // ===== Bottom actions =====
        Rectangle {
            height: 1px;
            background: Theme.card-border;
        }

        Rectangle { height: 10px; }

        Rectangle {
            height: 34px;
            border-radius: 6px;
            background: browse-touch.has-hover ? Theme.surface-hover : transparent;

            HorizontalLayout {
                padding-left: 10px;
                spacing: 8px;
                alignment: start;

                Image {
                    source: @image-url("../icons/search.svg");
                    width: 14px;
                    height: 14px;
                    colorize: browse-touch.has-hover ? Theme.text-sub : Theme.skel-text;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: "Browse crews";
                    font-size: 12px;
                    color: browse-touch.has-hover ? Theme.text-sub : Theme.skel-text;
                    vertical-alignment: center;
                }
            }

            browse-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    browse-crews-requested();
                }
            }
        }

        Rectangle {
            height: 34px;
            border-radius: 6px;
            background: new-crew-touch.has-hover ? Theme.surface-hover : transparent;

            HorizontalLayout {
                padding-left: 10px;
                spacing: 8px;
                alignment: start;

                Text {
                    text: "+";
                    font-size: 16px;
                    color: new-crew-touch.has-hover ? Theme.text-sub : Theme.skel-text;
                    vertical-alignment: center;
                }

                Text {
                    text: "New crew";
                    font-size: 12px;
                    color: new-crew-touch.has-hover ? Theme.text-sub : Theme.skel-text;
                    vertical-alignment: center;
                }
            }

            new-crew-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    crew-create-requested();
                }
            }
        }
    }
}
