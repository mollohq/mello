import { Theme } from "../theme.slint";
import { CrewData } from "../types.slint";

component VoiceBars inherits HorizontalLayout {
    in property <bool> speaking: false;
    spacing: 2px;
    alignment: center;

    Rectangle {
        width: 2px;
        height: speaking ? 8px : 4px;
        border-radius: 1px;
        background: speaking ? Theme.accent : Theme.graphic-med;
    }

    Rectangle {
        width: 2px;
        height: speaking ? 12px : 4px;
        border-radius: 1px;
        background: speaking ? Theme.accent : Theme.graphic-med;
    }

    Rectangle {
        width: 2px;
        height: speaking ? 8px : 4px;
        border-radius: 1px;
        background: speaking ? Theme.accent : Theme.graphic-med;
    }
}

component MemberChip inherits Rectangle {
    in property <string> initials;
    in property <string> name;
    in property <bool> speaking: false;

    height: 26px;
    border-radius: 4px;
    background: Theme.bg-app;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 5px;
        alignment: center;

        Rectangle {
            width: 18px;
            height: 18px;
            border-radius: 3px;
            background: speaking ? Theme.graphic-med : Theme.graphic-light;
            border-width: speaking ? 1px : 0px;
            border-color: Theme.graphic-dark;

            Text {
                text: initials;
                font-family: Theme.font-mono;
                font-size: 8px;
                font-weight: 600;
                color: speaking ? Theme.text-primary : Theme.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: name;
            font-family: Theme.font-mono;
            font-size: Theme.font-xs;
            color: speaking ? Theme.text-primary : Theme.text-secondary;
            vertical-alignment: center;
        }

        if speaking: VoiceBars {
            speaking: true;
        }
    }
}

component VoiceMiniRow inherits Rectangle {
    in property <string> initials;
    in property <string> name;
    in property <bool> speaking: false;

    height: 18px;

    HorizontalLayout {
        spacing: 6px;
        alignment: center;

        Rectangle {
            width: 18px;
            height: 18px;
            border-radius: 3px;
            background: speaking ? Theme.graphic-med : Theme.graphic-light;
            border-width: speaking ? 1px : 0px;
            border-color: speaking ? Theme.graphic-dark : transparent;

            Text {
                text: initials;
                font-family: Theme.font-mono;
                font-size: 8px;
                font-weight: 600;
                color: speaking ? Theme.text-primary : Theme.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: name;
            font-family: Theme.font-mono;
            font-size: Theme.font-xs;
            color: Theme.text-secondary;
            horizontal-stretch: 1;
            overflow: elide;
            vertical-alignment: center;
        }

        VoiceBars {
            speaking: speaking;
        }
    }
}

component StreamThumbnail inherits Rectangle {
    in property <bool> small: false;

    width: small ? 56px : 72px;
    height: small ? 36px : 44px;
    border-radius: 4px;
    background: Theme.dark ? #111111 : Theme.surface;
    border-width: 1px;
    border-color: Theme.graphic-light;

    // Live dot
    Rectangle {
        x: 3px;
        y: 3px;
        width: 4px;
        height: 4px;
        border-radius: 2px;
        background: Theme.accent;
    }

    // Placeholder lines
    VerticalLayout {
        alignment: center;
        spacing: 3px;
        padding-left: (parent.width - 32px) / 2;
        padding-right: (parent.width - 32px) / 2;

        Rectangle {
            height: 2px;
            border-radius: 1px;
            background: Theme.graphic-dark;
            opacity: 0.4;
        }

        Rectangle {
            height: 2px;
            width: 22px;
            border-radius: 1px;
            background: Theme.graphic-dark;
            opacity: 0.4;
        }
    }
}

component CrewMsg inherits HorizontalLayout {
    in property <string> author;
    in property <string> body;

    spacing: 6px;
    height: 14px;

    Text {
        text: author;
        font-family: Theme.font-mono;
        font-size: 9px;
        font-weight: 600;
        color: Theme.text-secondary;
        vertical-alignment: center;
    }

    Text {
        text: body;
        font-family: Theme.font-mono;
        font-size: 9px;
        color: Theme.text-tertiary;
        horizontal-stretch: 1;
        overflow: elide;
        vertical-alignment: center;
    }
}

export component CrewPanel inherits Rectangle {
    in property <[CrewData]> crews: [];
    in property <string> active-crew-id: "";

    callback crew-selected(string);
    callback crew-create-requested(string);
    callback browse-crews-requested();

    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.graphic-light;
    border-radius: Theme.r-outer;

    property <length> header-h: 16px;
    property <length> header-area: Theme.pad + header-h + 20px;
    property <length> bottom-h: 97px;
    property <length> bottom-area: bottom-h + Theme.pad;

    // --- Header ---
    HorizontalLayout {
        x: Theme.pad;
        y: Theme.pad;
        width: root.width - 2 * Theme.pad;
        height: root.header-h;
        spacing: 8px;

        Text {
            text: "YOUR CREWS";
            font-size: Theme.font-sm;
            font-weight: 600;
            letter-spacing: 1.3px;
            color: Theme.text-secondary;
            vertical-alignment: center;
        }

        Rectangle { horizontal-stretch: 1; }

        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: Theme.accent;
            y: (parent.height - self.height) / 2;
        }
    }

    // --- Crew cards (scrollable, fills middle) ---
    Flickable {
        x: Theme.pad;
        y: root.header-area;
        width: root.width - 2 * Theme.pad;
        height: root.height - root.header-area - root.bottom-area;

        VerticalLayout {
            spacing: 0px;

                // ===== ACTIVE NOW section =====
                Text {
                    text: "ACTIVE NOW";
                    font-size: Theme.font-xs;
                    font-weight: 600;
                    letter-spacing: 1.3px;
                    color: Theme.text-secondary;
                    height: 16px;
                }

                Rectangle {
                    height: 12px;
                }

                for crew[i] in crews: Rectangle {
                    visible: crew.online-count > 0 || crew.id == active-crew-id;
                    height: self.visible ? self.preferred-height : 0px;

                    // Card wrapper
                    VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            border-radius: Theme.r-inner;
                            background: crew.id == active-crew-id ? (Theme.dark ? #FF1E5612 : #FF1E560D) : Theme.bg-app;
                            border-width: 1px;
                            border-color: crew.id == active-crew-id ? Theme.accent : (card-hover.has-hover ? Theme.graphic-med : transparent);
                            clip: true;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 0px;

                                // --- Card header ---
                                HorizontalLayout {
                                    height: crew.id == active-crew-id ? 20px : 18px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        alignment: center;
                                        width: 6px;

                                        Rectangle {
                                            width: 6px;
                                            height: 6px;
                                            border-radius: 3px;
                                            background: Theme.accent;
                                        }
                                    }

                                    Text {
                                        text: crew.name;
                                        font-family: Theme.font-mono;
                                        font-size: crew.id == active-crew-id ? 14px : 12px;
                                        font-weight: 500;
                                        color: Theme.text-primary;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: crew.online-count + " / " + crew.member-count;
                                        font-family: Theme.font-mono;
                                        font-size: crew.id == active-crew-id ? Theme.font-sm : Theme.font-xs;
                                        color: crew.id == active-crew-id ? Theme.text-primary : Theme.text-secondary;
                                        vertical-alignment: center;
                                    }
                                }

                                // ===== ACTIVE card body =====
                                if crew.id == active-crew-id: VerticalLayout {
                                    spacing: 0px;

                                    Rectangle {
                                        height: 14px;
                                    }

                                    // Member chips (flow-wrapped via VerticalLayout of rows)
                                    HorizontalLayout {
                                        spacing: 6px;

                                        if crew.voice-count >= 1: MemberChip {
                                            initials: crew.v0-initials;
                                            name: crew.v0-name;
                                            speaking: crew.v0-speaking;
                                        }
                                        if crew.voice-count >= 2: MemberChip {
                                            initials: crew.v1-initials;
                                            name: crew.v1-name;
                                            speaking: crew.v1-speaking;
                                        }
                                    }

                                    if crew.voice-count >= 3: Rectangle {
                                        height: 6px;
                                    }

                                    if crew.voice-count >= 3: HorizontalLayout {
                                        spacing: 6px;

                                        MemberChip {
                                            initials: crew.v2-initials;
                                            name: crew.v2-name;
                                            speaking: crew.v2-speaking;
                                        }

                                        if crew.voice-count >= 4: MemberChip {
                                            initials: crew.v3-initials;
                                            name: crew.v3-name;
                                            speaking: crew.v3-speaking;
                                        }
                                    }

                                    // Stream preview (if streaming)
                                    if crew.has-stream: Rectangle {
                                        height: 10px;
                                    }

                                    if crew.has-stream: HorizontalLayout {
                                        spacing: 6px;

                                        StreamThumbnail {
                                            small: true;
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            spacing: 2px;

                                            Text {
                                                text: "LIVE STREAM";
                                                font-family: Theme.font-mono;
                                                font-size: 9px;
                                                color: Theme.text-tertiary;
                                                letter-spacing: 0.7px;
                                            }

                                            Text {
                                                text: crew.stream-name;
                                                font-family: Theme.font-mono;
                                                font-size: Theme.font-sm;
                                                color: Theme.text-primary;
                                            }
                                        }
                                    }
                                }

                                // ===== INACTIVE card body =====
                                if crew.id != active-crew-id && (crew.voice-count > 0 || crew.has-stream): VerticalLayout {
                                    spacing: 0px;

                                    Rectangle {
                                        height: 10px;
                                    }

                                    // Preview: stream thumbnail + voice rows
                                    HorizontalLayout {
                                        spacing: 8px;

                                        if crew.has-stream: StreamThumbnail {
                                            small: false;
                                        }

                                        if crew.voice-count > 0: VerticalLayout {
                                            spacing: 6px;
                                            vertical-stretch: 1;

                                            if crew.voice-count >= 1: VoiceMiniRow {
                                                initials: crew.v0-initials;
                                                name: crew.v0-name;
                                                speaking: crew.v0-speaking;
                                            }
                                            if crew.voice-count >= 2: VoiceMiniRow {
                                                initials: crew.v1-initials;
                                                name: crew.v1-name;
                                                speaking: crew.v1-speaking;
                                            }
                                            if crew.voice-count >= 3: VoiceMiniRow {
                                                initials: crew.v2-initials;
                                                name: crew.v2-name;
                                                speaking: crew.v2-speaking;
                                            }
                                        }
                                    }
                                }

                                // Messages (shown for any non-active crew with messages)
                                if crew.id != active-crew-id && crew.msg-count > 0: VerticalLayout {
                                    spacing: 0px;

                                    Rectangle {
                                        height: 10px;
                                    }

                                    Rectangle {
                                        height: 1px;
                                        background: Theme.graphic-light;
                                    }

                                    Rectangle {
                                        height: 10px;
                                    }

                                    CrewMsg {
                                        author: crew.m0-author;
                                        body: crew.m0-text;
                                    }

                                    if crew.msg-count >= 2: Rectangle {
                                        height: 5px;
                                    }

                                    if crew.msg-count >= 2: CrewMsg {
                                        author: crew.m1-author;
                                        body: crew.m1-text;
                                    }
                                }
                            }

                            card-hover := TouchArea {
                                clicked => {
                                    crew-selected(crew.id);
                                }
                            }
                        }

                        // Spacing between cards
                        Rectangle {
                            height: 8px;
                        }
                    }
                }

                // ===== IDLE section =====
                Rectangle {
                    height: 20px;
                }

                Text {
                    text: "IDLE";
                    font-size: Theme.font-xs;
                    font-weight: 600;
                    letter-spacing: 1.3px;
                    color: Theme.text-secondary;
                    height: 16px;
                }

                Rectangle {
                    height: 12px;
                }

                for crew[i] in crews: Rectangle {
                    visible: crew.online-count <= 0 && crew.id != active-crew-id;
                    height: self.visible ? self.preferred-height : 0px;
                    opacity: 0.5;

                    VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            border-radius: Theme.r-inner;
                            background: Theme.bg-app;
                            border-width: 1px;
                            border-color: idle-hover.has-hover ? Theme.graphic-med : transparent;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 0px;

                                HorizontalLayout {
                                    height: 18px;
                                    spacing: 8px;

                                    Text {
                                        text: crew.name;
                                        font-family: Theme.font-mono;
                                        font-size: 12px;
                                        font-weight: 500;
                                        color: Theme.text-secondary;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: "0";
                                        font-family: Theme.font-mono;
                                        font-size: Theme.font-xs;
                                        color: Theme.text-secondary;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    height: 4px;
                                }

                                Text {
                                    text: "No members online";
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-xs;
                                    color: Theme.text-tertiary;
                                }
                            }

                            idle-hover := TouchArea {
                                clicked => {
                                    crew-selected(crew.id);
                                }
                            }
                        }

                        Rectangle {
                            height: 8px;
                        }
                    }
                }
            }
        }

    // --- Bottom actions (absolute positioned at bottom) ---
    VerticalLayout {
        x: Theme.pad;
        y: root.height - root.bottom-area;
        width: root.width - 2 * Theme.pad;
        height: root.bottom-h;
        spacing: 8px;

        Rectangle {
            height: 1px;
            background: Theme.graphic-light;
        }

        Rectangle {
            height: 40px;
            border-radius: Theme.r-inner;
            background: browse-touch.has-hover ? Theme.hover-overlay : transparent;

            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 10px;
                alignment: start;

                Image {
                    source: @image-url("../icons/search.svg");
                    width: 16px;
                    height: 16px;
                    colorize: browse-touch.has-hover ? Theme.text-primary : Theme.text-secondary;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: "Browse crews";
                    font-family: Theme.font-mono;
                    font-size: Theme.font-md;
                    color: browse-touch.has-hover ? Theme.text-primary : Theme.text-secondary;
                    vertical-alignment: center;
                }
            }

            browse-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    browse-crews-requested();
                }
            }
        }

        Rectangle {
            height: 40px;
            background: Theme.bg-app;
            border-radius: Theme.r-inner;
            border-width: 1px;
            border-color: Theme.graphic-light;

            crew-name-input := TextInput {
                x: 14px;
                width: parent.width - 28px;
                height: parent.height;
                font-family: Theme.font-mono;
                font-size: Theme.font-md;
                color: Theme.text-primary;
                vertical-alignment: center;
                accepted => {
                    if crew-name-input.text != "" {
                        crew-create-requested(crew-name-input.text);
                        crew-name-input.text = "";
                    }
                }
            }

            if crew-name-input.text == "": Text {
                x: 14px;
                color: Theme.text-tertiary;
                font-family: Theme.font-mono;
                font-size: Theme.font-md;
                vertical-alignment: center;
                text: "+ New crew";
            }
        }
    }
}

