import { Theme } from "../theme.slint";
import { CrewData, AudioDeviceData } from "../types.slint";
import { DeviceDropdown } from "settings_modal.slint";

// ─── Reusable components ───

component CrewCard inherits Rectangle {
    in property <string> crew-name;
    in property <string> crew-description;
    in property <int> member-count;
    in property <int> online-count;
    in property <bool> featured: false;
    in property <image> crew-avatar;
    in property <bool> has-avatar: false;
    callback clicked();

    background: Theme.surface;
    border-radius: Theme.r-outer;
    border-width: 1px;
    border-color: card-touch.has-hover ? Theme.accent : Theme.graphic-light;

    card-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        padding: 24px;
        spacing: 8px;
        alignment: space-between;

        VerticalLayout {
            spacing: 8px;

            HorizontalLayout {
                spacing: 12px;

                if has-avatar: Rectangle {
                    width: 40px;
                    height: 40px;
                    border-radius: 10px;
                    clip: true;

                    Image {
                        source: crew-avatar;
                        width: parent.width;
                        height: parent.height;
                        image-fit: cover;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    spacing: 0px;

                    HorizontalLayout {
                        spacing: 10px;

                        Text {
                            text: crew-name;
                            font-family: Theme.font-mono;
                            font-size: 18px;
                            font-weight: 500;
                            color: Theme.text-primary;
                            overflow: elide;
                            letter-spacing: 0.5px;
                            horizontal-stretch: 1;
                        }

                        if online-count > 0: Rectangle {
                            width: pill-text.preferred-width + 28px;
                            height: 24px;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: #FF1E564D;
                            background: #FF1E561A;

                            HorizontalLayout {
                                alignment: center;
                                spacing: 6px;

                                Rectangle {
                                    width: 6px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background: Theme.accent;
                                }

                                pill-text := Text {
                                    text: "LIVE";
                                    font-family: Theme.font-mono;
                                    font-size: 10px;
                                    color: Theme.accent;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }

            if crew-description != "": Text {
                text: crew-description;
                font-size: 14px;
                color: Theme.text-secondary;
                wrap: word-wrap;
                overflow: elide;
            }
        }

        HorizontalLayout {
            alignment: space-between;

            Text {
                text: member-count < 10 ? "0" + member-count + " MEMBERS" : member-count + " MEMBERS";
                font-family: Theme.font-mono;
                font-size: 11px;
                color: Theme.text-tertiary;
                vertical-alignment: center;
            }

            Rectangle {
                width: 80px;
                Text {
                    text: card-touch.has-hover ? "CONNECT →" : "JOIN";
                    font-family: Theme.font-mono;
                    font-size: 12px;
                    font-weight: 500;
                    color: card-touch.has-hover ? Theme.accent : Theme.text-tertiary;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                }
            }
        }
    }
}

component CreateCrewCard inherits Rectangle {
    callback clicked();

    background: transparent;
    border-radius: Theme.r-outer;
    border-width: 1px;
    border-color: create-touch.has-hover ? Theme.accent : Theme.text-tertiary;

    create-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        alignment: center;
        spacing: 16px;

        HorizontalLayout {
            alignment: center;

            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: 16px;
                background: create-touch.has-hover ? Theme.accent : Theme.graphic-light;

                Text {
                    text: "+";
                    font-size: 28px;
                    font-weight: 300;
                    color: Theme.text-primary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Text {
            text: "CREATE YOUR\nOWN CREW";
            font-family: Theme.font-mono;
            font-size: 14px;
            color: Theme.text-secondary;
            horizontal-alignment: center;
            letter-spacing: 1.5px;
        }
    }
}

component AvatarCard inherits Rectangle {
    in property <image> front-image;
    in property <image> back-image;
    in property <bool> has-image: false;
    in property <bool> selected: false;
    in property <bool> deal-visible: false;
    in-out property <bool> flipped: false;
    callback clicked();
    callback pointer-down();
    callback pointer-up();

    // Easter egg spin mode (shared — only one card spins at a time)
    in property <bool> spinning: false;
    in property <float> spin-angle: 0;
    in property <string> spin-text-front: "";
    in property <string> spin-text-back: "";
    in property <bool> spin-heart-front: false;
    in property <bool> spin-heart-back: false;

    horizontal-stretch: 1;

    property <float> deal-scale: deal-visible ? 1.0 : 0.5;
    property <float> deal-opacity: deal-visible ? 1.0 : 0.0;
    property <float> deal-y: deal-visible ? 0.0 : 12.0;

    animate deal-scale { duration: 350ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
    animate deal-opacity { duration: 350ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }
    animate deal-y { duration: 350ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }

    property <float> flip-progress: flipped ? 1.0 : 0.0;
    animate flip-progress { duration: 1040ms; easing: cubic-bezier(0.4, 0.0, 0.2, 1); }

    property <float> normal-scale-x: Math.abs(Math.cos(flip-progress * 3.14159265rad));
    property <bool> normal-show-front: flip-progress < 0.5;

    property <float> spin-norm: Math.mod(spin-angle, 360.0);
    property <float> spin-scale-x: Math.abs(Math.cos(spin-angle / 180.0 * 3.14159265rad));
    property <bool> spin-show-front: spin-norm < 90.0 || spin-norm >= 270.0;

    property <float> scale-x-factor: spinning ? spin-scale-x : normal-scale-x;
    property <bool> show-front: spinning ? spin-show-front : normal-show-front;

    opacity: deal-opacity;

    av-touch := TouchArea {
        clicked => {
            if !root.spinning { root.clicked(); }
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) { root.pointer-down(); }
            if (e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel) { root.pointer-up(); }
        }
    }

    // Outer glow for selected state
    Rectangle {
        x: -1px;
        y: Math.round(deal-y) * 1px - 1px;
        width: parent.width + 2px;
        height: parent.height + 2px;
        border-radius: Theme.r-inner + 1px;
        border-width: selected ? 1px : 0px;
        border-color: Theme.accent;
        background: transparent;
    }

    // Card container with scale
    Rectangle {
        x: parent.width * (1.0 - deal-scale * scale-x-factor) / 2.0;
        y: Math.round(deal-y) * 1px;
        width: parent.width * deal-scale * scale-x-factor;
        height: parent.height * deal-scale;
        border-radius: Theme.r-inner;
        clip: true;
        background: spinning ? Theme.surface-hover : (selected ? #FF1E560A : Theme.surface);
        border-width: selected ? 1.5px : 1.5px;
        border-color: spinning ? Theme.accent : (selected ? Theme.accent : (av-touch.has-hover ? #404045 : Theme.graphic-light));

        // Front face — avatar image (normal mode)
        if show-front && has-image && !spinning: Image {
            source: front-image;
            width: parent.width * 0.70;
            height: parent.height * 0.70;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            image-fit: contain;
        }

        // Front face — word (spin mode)
        if show-front && spinning: Text {
            text: spin-text-front;
            font-family: "Oxanium";
            font-weight: 600;
            font-size: spin-heart-front ? 28px : 16px;
            color: Theme.accent;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }

        // Back face — avatar image (normal mode)
        if !show-front && has-image && !spinning: Image {
            source: back-image;
            width: parent.width * 0.70;
            height: parent.height * 0.70;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            image-fit: contain;
        }

        // Back face — word (spin mode)
        if !show-front && spinning: Text {
            text: spin-text-back;
            font-family: "Oxanium";
            font-weight: 600;
            font-size: spin-heart-back ? 28px : 16px;
            color: Theme.accent;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }

        // Loading placeholder when no image
        if !has-image && !spinning: Rectangle {
            background: Theme.graphic-light;
            border-radius: 4px;
            width: 32px;
            height: 32px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            opacity: 0.4;
        }
    }
}

component AvatarFallback inherits Rectangle {
    in property <string> nickname: "";
    in property <int> color-index: 0;
    in property <length> size: 80px;

    width: size;
    height: size;
    border-radius: size > 60px ? 12px : 6px;

    property <[color]> palette: [
        #EB4D5F, #7C5CFC, #06B6D4, #F472B6,
        #10B981, #F59E0B, #8B5CF6, #EC4899,
    ];

    background: palette[Math.clamp(color-index, 0, 7)];

    Text {
        text: nickname;
        font-family: Theme.font-mono;
        font-size: parent.size * 0.32;
        font-weight: 500;
        color: #FFFFFF;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component StepIndicator inherits Rectangle {
    in property <int> current-step: 1;
    callback step-clicked(int);

    height: 20px;

    HorizontalLayout {
        spacing: 16px;
        alignment: start;

        Text {
            text: current-step < 10 ? "STEP 0" + current-step + " / 03" : "STEP " + current-step + " / 03";
            font-family: Theme.font-mono;
            font-size: 13px;
            color: Theme.accent;
            letter-spacing: 2px;
            vertical-alignment: center;
        }

        // Dots container — explicit centering via y offset
        Rectangle {
            width: 24px * 3 + 8px * 2;

            Rectangle {
                x: 0;
                y: (parent.height - 2px) / 2;
                width: 24px;
                height: 2px;
                background: current-step >= 1 ? Theme.accent : Theme.graphic-light;
                TouchArea {
                    clicked => {
                        root.step-clicked(1);
                    }
                }
            }

            Rectangle {
                x: 24px + 8px;
                y: (parent.height - 2px) / 2;
                width: 24px;
                height: 2px;
                background: current-step >= 2 ? Theme.accent : Theme.graphic-light;
                TouchArea {
                    clicked => {
                        root.step-clicked(2);
                    }
                }
            }

            Rectangle {
                x: (24px + 8px) * 2;
                y: (parent.height - 2px) / 2;
                width: 24px;
                height: 2px;
                background: current-step >= 3 ? Theme.accent : Theme.graphic-light;
                TouchArea {
                    clicked => {
                        root.step-clicked(3);
                    }
                }
            }
        }
    }
}

component InputField inherits Rectangle {
    in-out property <string> text <=> ti.text;
    in property <string> placeholder;
    in property <bool> is-password: false;

    height: 52px;
    background: Theme.surface;
    border-radius: Theme.r-inner;
    border-width: 1px;
    border-color: ti.has-focus ? Theme.graphic-med : Theme.graphic-light;

    ti := TextInput {
        x: 16px;
        width: parent.width - 32px;
        height: parent.height;
        font-family: Theme.font-mono;
        font-size: 14px;
        color: Theme.text-primary;
        horizontal-alignment: left;
        vertical-alignment: center;
        input-type: is-password ? InputType.password : InputType.text;
    }

    if ti.text == "": Text {
        x: 16px;
        color: Theme.text-tertiary;
        font-family: Theme.font-mono;
        font-size: 14px;
        vertical-alignment: center;
        text: placeholder;
    }
}

component AccentButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    callback clicked();

    height: 52px;
    background: enabled ? Theme.accent : Theme.graphic-med;
    border-radius: Theme.r-inner;

    btn-touch := TouchArea {
        clicked => {
            if root.enabled {
                root.clicked();
            }
        }
    }

    HorizontalLayout {
        alignment: center;
        spacing: 12px;

        Text {
            text: label;
            font-family: Theme.font-mono;
            font-size: 14px;
            font-weight: 600;
            color: #FFFFFF;
            vertical-alignment: center;
        }

        Text {
            text: "→";
            font-size: 16px;
            color: #FFFFFF;
            vertical-alignment: center;
        }
    }
}

component AuthButton inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> has-icon: false;
    in property <bool> subdued: false;
    callback clicked();

    height: 56px;
    preferred-width: 0px;
    background: auth-touch.has-hover ? #FFFFFF05 : transparent;
    border-radius: Theme.r-inner;
    border-width: 1px;
    border-color: auth-touch.has-hover ? Theme.graphic-med : Theme.graphic-light;
    opacity: subdued ? 0.6 : 1.0;

    auth-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    HorizontalLayout {
        padding-left: 16px;
        spacing: 16px;
        alignment: start;

        if has-icon: Image {
            source: icon;
            width: 20px;
            height: 20px;
            colorize: Theme.text-primary;
            y: (parent.height - self.height) / 2;
            opacity: 0.8;
        }

        Text {
            text: label;
            font-family: Theme.font-mono;
            font-size: 13px;
            color: Theme.text-primary;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

// ─── Main onboarding component ───

export component Onboarding inherits Rectangle {
    in property <int> step: 1;
    in property <[CrewData]> discover-crews: [];
    in property <[int]> bento-set-bases: [];
    in property <string> link-error: "";

    // Audio device props for Step 2
    in property <[AudioDeviceData]> capture-devices: [];
    in property <[AudioDeviceData]> playback-devices: [];
    in property <string> selected-capture-id: "";
    in property <string> selected-playback-id: "";
    in-out property <string> selected-capture-name: "System Default";
    in-out property <string> selected-playback-name: "System Default";

    min-height: 800px;
    min-width: 1024px;
    in-out property <string> nickname: "";
    in-out property <int> selected-avatar: -1;

    property <image> chosen-avatar-img:
        selected-avatar == 0 ? avatar-img-0 :
        selected-avatar == 1 ? avatar-img-1 :
        selected-avatar == 2 ? avatar-img-2 :
        selected-avatar == 3 ? avatar-img-3 :
        selected-avatar == 4 ? avatar-img-4 :
        selected-avatar == 5 ? avatar-img-5 :
        selected-avatar == 6 ? avatar-img-6 :
        upload-preview;
    property <bool> has-chosen-avatar: selected-avatar >= 0;

    // Avatar grid images (set from Rust)
    in property <image> avatar-img-0;
    in property <image> avatar-img-1;
    in property <image> avatar-img-2;
    in property <image> avatar-img-3;
    in property <image> avatar-img-4;
    in property <image> avatar-img-5;
    in property <image> avatar-img-6;
    in property <image> avatar-back-0;
    in property <image> avatar-back-1;
    in property <image> avatar-back-2;
    in property <image> avatar-back-3;
    in property <image> avatar-back-4;
    in property <image> avatar-back-5;
    in property <image> avatar-back-6;
    in property <bool> avatar-loaded-0: false;
    in property <bool> avatar-loaded-1: false;
    in property <bool> avatar-loaded-2: false;
    in property <bool> avatar-loaded-3: false;
    in property <bool> avatar-loaded-4: false;
    in property <bool> avatar-loaded-5: false;
    in property <bool> avatar-loaded-6: false;
    in property <bool> avatar-deal-0: false;
    in property <bool> avatar-deal-1: false;
    in property <bool> avatar-deal-2: false;
    in property <bool> avatar-deal-3: false;
    in property <bool> avatar-deal-4: false;
    in property <bool> avatar-deal-5: false;
    in property <bool> avatar-deal-6: false;
    in property <bool> avatar-deal-upload: false;
    in-out property <bool> avatar-flip-0: false;
    in-out property <bool> avatar-flip-1: false;
    in-out property <bool> avatar-flip-2: false;
    in-out property <bool> avatar-flip-3: false;
    in-out property <bool> avatar-flip-4: false;
    in-out property <bool> avatar-flip-5: false;
    in-out property <bool> avatar-flip-6: false;

    // Upload
    in property <image> upload-preview;
    in property <bool> has-upload: false;

    // Easter egg spin state (shared across all cards)
    in property <int> spinning-slot: -1;
    in property <float> spin-angle: 0;
    in property <string> spin-text-front: "";
    in property <string> spin-text-back: "";
    in property <bool> spin-heart-front: false;
    in property <bool> spin-heart-back: false;

    callback avatar-slot-clicked(int);
    callback avatar-pointer-down(int);
    callback avatar-pointer-up(int);
    callback reroll-clicked();
    callback upload-clicked();

    in property <string> device-user-name: "";
    in property <string> device-user-initials: "";
    in property <bool> is-returning-user: false;

    // Email link form state (step 3)
    property <bool> show-email-form: false;
    property <string> link-email-value;
    property <string> link-password-value;

    callback crew-selected(string);
    callback create-crew-requested(string);
    callback continue-to-step(int);
    callback login-requested();
    callback open-sign-in();
    callback link-email(string, string);
    callback skip-identity();
    callback capture-device-selected(string);
    callback playback-device-selected(string);

    // Social auth callbacks
    callback auth-steam();
    callback auth-google();
    callback auth-twitch();
    callback auth-discord();
    callback auth-apple();

    background: Theme.bg-app;

    // ===================== STEP 1: Discover crews =====================
    if step == 1: Rectangle {
        background: Theme.bg-app;

        // ── Crew discovery view ──
        Rectangle {

            // "Sign in" text link — top-right
            Rectangle {
                x: parent.width - 120px - self.width;
                y: is-returning-user ? 80px + 48px + 12px : 80px;
                width: signin-link-text.preferred-width + 16px;
                height: 32px;

                signin-link-text := Text {
                    text: "Sign in →";
                    font-family: Theme.font-mono;
                    font-size: 13px;
                    font-weight: 600;
                    color: signin-link-touch.has-hover ? Theme.accent : Theme.text-secondary;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    letter-spacing: 0.3px;
                }

                signin-link-touch := TouchArea {
                    clicked => {
                        root.open-sign-in();
                    }
                }
            }

            // Login pill — top-right, absolute positioned (only for returning users)
            if is-returning-user: Rectangle {
                x: parent.width - 120px - self.width;
                y: 80px;
                width: pill-layout.preferred-width;
                height: 48px;
                background: Theme.surface;
                border-radius: 999px;
                border-width: 1px;
                border-color: Theme.graphic-light;

                pill-layout := HorizontalLayout {
                    spacing: 0px;

                    // User side
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 16px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 10px;

                        Rectangle {
                            width: 32px;
                            height: 32px;
                            border-radius: 16px;
                            background: Theme.accent;

                            Text {
                                text: device-user-initials != "" ? device-user-initials : "?";
                                font-family: Theme.font-mono;
                                font-size: 13px;
                                font-weight: 700;
                                color: #FFFFFF;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;

                            Text {
                                text: "DEVICE USER";
                                font-family: Theme.font-mono;
                                font-size: 9px;
                                color: Theme.text-tertiary;
                                letter-spacing: 1px;
                            }

                            Text {
                                text: device-user-name != "" ? device-user-name : "anonymous";
                                font-family: Theme.font-mono;
                                font-size: 12px;
                                font-weight: 600;
                                color: Theme.text-primary;
                                letter-spacing: 0.3px;
                            }
                        }
                    }

                    // Divider
                    Rectangle {
                        width: 1px;
                        background: Theme.graphic-light;
                    }

                    // Sign In CTA (fast-track as device user)
                    Rectangle {
                        width: pill-cta-text.preferred-width + 36px;
                        height: 48px;

                        pill-cta-text := Text {
                            text: "SIGN IN →";
                            font-family: Theme.font-mono;
                            font-size: 11px;
                            font-weight: 700;
                            color: pill-cta-touch.has-hover ? Theme.accent : Theme.accent;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        pill-cta-touch := TouchArea {
                            clicked => {
                                root.login-requested();
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                padding-top: 48px;
                padding-left: 120px;
                padding-right: 120px;
                spacing: 0px;

                // Header
                VerticalLayout {
                    spacing: 16px;

                    StepIndicator {
                        current-step: 1;
                        step-clicked(s) => {
                            root.continue-to-step(s);
                        }
                    }

                    Text {
                        text: "Discover Your Crew";
                        font-size: 48px;
                        font-weight: 500;
                        color: Theme.text-primary;
                        letter-spacing: -1.5px;
                    }

                    Text {
                        text: "Join a specialized squad to begin your deployment, or establish a new unit and lead the way.";
                        font-size: 18px;
                        color: Theme.text-secondary;
                        max-width: 540px;
                    }
                }

                Rectangle {
                    height: 56px;
                }

                // Bento grid — repeating 5-item sets, 240px row heights
                VerticalLayout {
                    spacing: 20px;

                    for base in root.bento-set-bases: VerticalLayout {
                        spacing: 20px;

                        // Row 1: [featured 2x] [create CTA or 1x] [1x]
                        if discover-crews.length > base: HorizontalLayout {
                            height: 240px;
                            spacing: 20px;

                            CrewCard {
                                horizontal-stretch: 2;
                                featured: true;
                                crew-name: discover-crews[base].name;
                                crew-description: discover-crews[base].description;
                                member-count: discover-crews[base].member-count;
                                online-count: discover-crews[base].online-count;
                                crew-avatar: discover-crews[base].avatar;
                                has-avatar: discover-crews[base].has-avatar;
                                clicked => { root.crew-selected(discover-crews[base].id); }
                            }

                            if base == 0: CreateCrewCard {
                                horizontal-stretch: 1;
                                clicked => { root.create-crew-requested("New Crew"); }
                            }

                            if base != 0: CrewCard {
                                horizontal-stretch: 1;
                                crew-name: discover-crews.length > base + 1 ? discover-crews[base + 1].name : "";
                                crew-description: discover-crews.length > base + 1 ? discover-crews[base + 1].description : "";
                                member-count: discover-crews.length > base + 1 ? discover-crews[base + 1].member-count : 0;
                                online-count: discover-crews.length > base + 1 ? discover-crews[base + 1].online-count : 0;
                                crew-avatar: discover-crews.length > base + 1 ? discover-crews[base + 1].avatar : @image-url("");
                                has-avatar: discover-crews.length > base + 1 ? discover-crews[base + 1].has-avatar : false;
                                visible: discover-crews.length > base + 1;
                                clicked => {
                                    if discover-crews.length > base + 1 { root.crew-selected(discover-crews[base + 1].id); }
                                }
                            }

                            CrewCard {
                                horizontal-stretch: 1;
                                crew-name: discover-crews.length > base + 1 ? discover-crews[base + 1].name : "";
                                crew-description: discover-crews.length > base + 1 ? discover-crews[base + 1].description : "";
                                member-count: discover-crews.length > base + 1 ? discover-crews[base + 1].member-count : 0;
                                online-count: discover-crews.length > base + 1 ? discover-crews[base + 1].online-count : 0;
                                crew-avatar: discover-crews.length > base + 1 ? discover-crews[base + 1].avatar : @image-url("");
                                has-avatar: discover-crews.length > base + 1 ? discover-crews[base + 1].has-avatar : false;
                                visible: base == 0 ? discover-crews.length > base + 1 : false;
                                clicked => {
                                    if discover-crews.length > base + 1 { root.crew-selected(discover-crews[base + 1].id); }
                                }
                            }
                        }

                        // Row 2: [1x] [featured 2x] [1x]
                        if discover-crews.length > base + 2: HorizontalLayout {
                            height: 240px;
                            spacing: 20px;

                            CrewCard {
                                horizontal-stretch: 1;
                                crew-name: discover-crews[base + 2].name;
                                crew-description: discover-crews[base + 2].description;
                                member-count: discover-crews[base + 2].member-count;
                                online-count: discover-crews[base + 2].online-count;
                                crew-avatar: discover-crews[base + 2].avatar;
                                has-avatar: discover-crews[base + 2].has-avatar;
                                clicked => { root.crew-selected(discover-crews[base + 2].id); }
                            }

                            CrewCard {
                                horizontal-stretch: 2;
                                featured: true;
                                crew-name: discover-crews.length > base + 3 ? discover-crews[base + 3].name : "";
                                crew-description: discover-crews.length > base + 3 ? discover-crews[base + 3].description : "";
                                member-count: discover-crews.length > base + 3 ? discover-crews[base + 3].member-count : 0;
                                online-count: discover-crews.length > base + 3 ? discover-crews[base + 3].online-count : 0;
                                crew-avatar: discover-crews.length > base + 3 ? discover-crews[base + 3].avatar : @image-url("");
                                has-avatar: discover-crews.length > base + 3 ? discover-crews[base + 3].has-avatar : false;
                                visible: discover-crews.length > base + 3;
                                clicked => {
                                    if discover-crews.length > base + 3 { root.crew-selected(discover-crews[base + 3].id); }
                                }
                            }

                            CrewCard {
                                horizontal-stretch: 1;
                                crew-name: discover-crews.length > base + 4 ? discover-crews[base + 4].name : "";
                                crew-description: discover-crews.length > base + 4 ? discover-crews[base + 4].description : "";
                                member-count: discover-crews.length > base + 4 ? discover-crews[base + 4].member-count : 0;
                                online-count: discover-crews.length > base + 4 ? discover-crews[base + 4].online-count : 0;
                                crew-avatar: discover-crews.length > base + 4 ? discover-crews[base + 4].avatar : @image-url("");
                                has-avatar: discover-crews.length > base + 4 ? discover-crews[base + 4].has-avatar : false;
                                visible: discover-crews.length > base + 4;
                                clicked => {
                                    if discover-crews.length > base + 4 { root.crew-selected(discover-crews[base + 4].id); }
                                }
                            }
                        }
                    }
                }

                // Push nav to bottom
                Rectangle {
                    vertical-stretch: 1;
                    min-height: 40px;
                }

                // Bottom margin
                Rectangle {
                    height: 40px;
                }
            }
        }

    }

    // ===================== STEP 2: Profile setup =====================
    if step == 2: Rectangle {
        background: Theme.bg-app;

        VerticalLayout {
            padding-top: 80px;
            padding-left: 140px;
            padding-right: 140px;
            padding-bottom: 40px;
            spacing: 0px;

            // Header
            VerticalLayout {
                spacing: 12px;

                StepIndicator {
                    current-step: 2;
                    step-clicked(s) => {
                        root.continue-to-step(s);
                    }
                }

                Text {
                    text: "Profile & Device Setup";
                    font-size: 36px;
                    font-weight: 500;
                    color: Theme.text-primary;
                    letter-spacing: -0.7px;
                }
            }

            Rectangle {
                height: 64px;
            }

            // Two-column grid (440px left | flex right, gap 120px)
            HorizontalLayout {
                spacing: 120px;

                // Left column: Avatar + nickname (fixed 440px)
                VerticalLayout {
                    width: 440px;
                    alignment: start;

                    Text {
                        text: "CHOOSE IDENTITY";
                        font-family: Theme.font-mono;
                        font-size: 10px;
                        font-weight: 500;
                        color: Theme.text-secondary;
                        letter-spacing: 1.4px;
                    }

                    Rectangle {
                        height: 16px;
                    }

                    // Avatar grid 4x2
                    VerticalLayout {
                        spacing: 10px;

                        HorizontalLayout {
                            spacing: 10px;
                            height: 96px;

                            AvatarCard {
                                front-image: root.avatar-img-0;
                                back-image: root.avatar-back-0;
                                has-image: root.avatar-loaded-0;
                                selected: root.selected-avatar == 0;
                                deal-visible: root.avatar-deal-0;
                                flipped: root.avatar-flip-0;
                                spinning: root.spinning-slot == 0;
                                spin-angle: root.spin-angle;
                                spin-text-front: root.spin-text-front;
                                spin-text-back: root.spin-text-back;
                                spin-heart-front: root.spin-heart-front;
                                spin-heart-back: root.spin-heart-back;
                                clicked => { root.avatar-slot-clicked(0); }
                                pointer-down => { root.avatar-pointer-down(0); }
                                pointer-up => { root.avatar-pointer-up(0); }
                            }

                            AvatarCard {
                                front-image: root.avatar-img-1;
                                back-image: root.avatar-back-1;
                                has-image: root.avatar-loaded-1;
                                selected: root.selected-avatar == 1;
                                deal-visible: root.avatar-deal-1;
                                flipped: root.avatar-flip-1;
                                spinning: root.spinning-slot == 1;
                                spin-angle: root.spin-angle;
                                spin-text-front: root.spin-text-front;
                                spin-text-back: root.spin-text-back;
                                spin-heart-front: root.spin-heart-front;
                                spin-heart-back: root.spin-heart-back;
                                clicked => { root.avatar-slot-clicked(1); }
                                pointer-down => { root.avatar-pointer-down(1); }
                                pointer-up => { root.avatar-pointer-up(1); }
                            }

                            AvatarCard {
                                front-image: root.avatar-img-2;
                                back-image: root.avatar-back-2;
                                has-image: root.avatar-loaded-2;
                                selected: root.selected-avatar == 2;
                                deal-visible: root.avatar-deal-2;
                                flipped: root.avatar-flip-2;
                                spinning: root.spinning-slot == 2;
                                spin-angle: root.spin-angle;
                                spin-text-front: root.spin-text-front;
                                spin-text-back: root.spin-text-back;
                                spin-heart-front: root.spin-heart-front;
                                spin-heart-back: root.spin-heart-back;
                                clicked => { root.avatar-slot-clicked(2); }
                                pointer-down => { root.avatar-pointer-down(2); }
                                pointer-up => { root.avatar-pointer-up(2); }
                            }

                            AvatarCard {
                                front-image: root.avatar-img-3;
                                back-image: root.avatar-back-3;
                                has-image: root.avatar-loaded-3;
                                selected: root.selected-avatar == 3;
                                deal-visible: root.avatar-deal-3;
                                flipped: root.avatar-flip-3;
                                spinning: root.spinning-slot == 3;
                                spin-angle: root.spin-angle;
                                spin-text-front: root.spin-text-front;
                                spin-text-back: root.spin-text-back;
                                spin-heart-front: root.spin-heart-front;
                                spin-heart-back: root.spin-heart-back;
                                clicked => { root.avatar-slot-clicked(3); }
                                pointer-down => { root.avatar-pointer-down(3); }
                                pointer-up => { root.avatar-pointer-up(3); }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            height: 96px;

                            AvatarCard {
                                front-image: root.avatar-img-4;
                                back-image: root.avatar-back-4;
                                has-image: root.avatar-loaded-4;
                                selected: root.selected-avatar == 4;
                                deal-visible: root.avatar-deal-4;
                                flipped: root.avatar-flip-4;
                                spinning: root.spinning-slot == 4;
                                spin-angle: root.spin-angle;
                                spin-text-front: root.spin-text-front;
                                spin-text-back: root.spin-text-back;
                                spin-heart-front: root.spin-heart-front;
                                spin-heart-back: root.spin-heart-back;
                                clicked => { root.avatar-slot-clicked(4); }
                                pointer-down => { root.avatar-pointer-down(4); }
                                pointer-up => { root.avatar-pointer-up(4); }
                            }

                            AvatarCard {
                                front-image: root.avatar-img-5;
                                back-image: root.avatar-back-5;
                                has-image: root.avatar-loaded-5;
                                selected: root.selected-avatar == 5;
                                deal-visible: root.avatar-deal-5;
                                flipped: root.avatar-flip-5;
                                spinning: root.spinning-slot == 5;
                                spin-angle: root.spin-angle;
                                spin-text-front: root.spin-text-front;
                                spin-text-back: root.spin-text-back;
                                spin-heart-front: root.spin-heart-front;
                                spin-heart-back: root.spin-heart-back;
                                clicked => { root.avatar-slot-clicked(5); }
                                pointer-down => { root.avatar-pointer-down(5); }
                                pointer-up => { root.avatar-pointer-up(5); }
                            }

                            AvatarCard {
                                front-image: root.avatar-img-6;
                                back-image: root.avatar-back-6;
                                has-image: root.avatar-loaded-6;
                                selected: root.selected-avatar == 6;
                                deal-visible: root.avatar-deal-6;
                                flipped: root.avatar-flip-6;
                                spinning: root.spinning-slot == 6;
                                spin-angle: root.spin-angle;
                                spin-text-front: root.spin-text-front;
                                spin-text-back: root.spin-text-back;
                                spin-heart-front: root.spin-heart-front;
                                spin-heart-back: root.spin-heart-back;
                                clicked => { root.avatar-slot-clicked(6); }
                                pointer-down => { root.avatar-pointer-down(6); }
                                pointer-up => { root.avatar-pointer-up(6); }
                            }

                            // Upload slot (8th position)
                            Rectangle {
                                horizontal-stretch: 1;
                                border-radius: Theme.r-inner;
                                background: Theme.surface;
                                border-width: 1.5px;
                                border-color: root.selected-avatar == 7 ? Theme.accent : (upload-touch.has-hover ? #404045 : Theme.graphic-light);

                                property <float> up-opacity: root.avatar-deal-upload ? 1.0 : 0.0;
                                opacity: up-opacity;
                                animate up-opacity { duration: 350ms; easing: cubic-bezier(0.34, 1.56, 0.64, 1); }

                                upload-touch := TouchArea {
                                    clicked => { root.upload-clicked(); }
                                }

                                if root.has-upload: Image {
                                    source: root.upload-preview;
                                    width: parent.width * 0.70;
                                    height: parent.height * 0.70;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    image-fit: contain;
                                }

                                if !root.has-upload: VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    HorizontalLayout {
                                        alignment: center;
                                        Text {
                                            text: "+";
                                            font-size: 22px;
                                            font-weight: 300;
                                            color: Theme.text-tertiary;
                                        }
                                    }
                                    HorizontalLayout {
                                        alignment: center;
                                        Text {
                                            text: "UPLOAD";
                                            font-family: Theme.font-mono;
                                            font-size: 9px;
                                            color: Theme.text-tertiary;
                                            letter-spacing: 0.8px;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 20px;
                    }

                    // Reroll button
                    HorizontalLayout {
                        alignment: start;

                        Rectangle {
                            width: reroll-layout.preferred-width + 32px;
                            height: 40px;
                            background: Theme.surface;
                            border-radius: Theme.r-inner;
                            border-width: 1.5px;
                            border-color: reroll-touch.has-hover ? Theme.accent : Theme.graphic-light;

                            reroll-touch := TouchArea {
                                clicked => { root.reroll-clicked(); }
                            }

                            reroll-layout := HorizontalLayout {
                                alignment: center;
                                spacing: 8px;

                                Image {
                                    source: @image-url("../icons/dice.svg");
                                    width: 16px;
                                    height: 16px;
                                    colorize: Theme.text-secondary;
                                    y: (parent.height - self.height) / 2;
                                }

                                Text {
                                    text: "REROLL ALL";
                                    font-family: Theme.font-mono;
                                    font-size: 11px;
                                    font-weight: 500;
                                    letter-spacing: 0.8px;
                                    color: Theme.text-secondary;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 36px;
                    }

                    Text {
                        text: "CREW NICKNAME";
                        font-family: Theme.font-mono;
                        font-size: 10px;
                        font-weight: 500;
                        color: Theme.text-secondary;
                        letter-spacing: 1.4px;
                    }

                    Rectangle {
                        height: 12px;
                    }

                    InputField {
                        text <=> root.nickname;
                        placeholder: "Enter handle...";
                    }
                }

                // Right column: Device selectors
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: start;

                    Text {
                        text: "MICROPHONE INPUT";
                        font-size: 10px;
                        font-weight: 600;
                        color: Theme.text-secondary;
                        letter-spacing: 1.3px;
                    }

                    Rectangle {
                        height: 8px;
                    }

                    DeviceDropdown {
                        devices: root.capture-devices;
                        selected-id: root.selected-capture-id;
                        selected-name <=> root.selected-capture-name;
                        device-selected(id) => {
                            root.capture-device-selected(id);
                        }
                    }

                    Rectangle {
                        height: 32px;
                    }

                    Text {
                        text: "SPEAKER OUTPUT";
                        font-size: 10px;
                        font-weight: 600;
                        color: Theme.text-secondary;
                        letter-spacing: 1.3px;
                    }

                    Rectangle {
                        height: 8px;
                    }

                    DeviceDropdown {
                        devices: root.playback-devices;
                        selected-id: root.selected-playback-id;
                        selected-name <=> root.selected-playback-name;
                        device-selected(id) => {
                            root.playback-device-selected(id);
                        }
                    }
                }
            }

            // Push continue button to bottom
            Rectangle {
                vertical-stretch: 1;
            }

            // Footer with Continue button
            HorizontalLayout {
                height: 52px;
                alignment: end;

                AccentButton {
                    width: 200px;
                    label: "Continue";
                    enabled: nickname != "" && root.selected-avatar >= 0;
                    clicked => {
                        root.continue-to-step(3);
                    }
                }
            }
        }
    }

    // ===================== STEP 3: Lock in identity =====================
    if step == 3: Rectangle {
        background: Theme.bg-app;

        VerticalLayout {
            padding-top: 80px;
            padding-left: 120px;
            padding-right: 120px;
            padding-bottom: 40px;
            spacing: 0px;

            // Header: top-left aligned
            VerticalLayout {
                spacing: 8px;

                StepIndicator {
                    current-step: 3;
                    step-clicked(s) => {
                        root.continue-to-step(s);
                    }
                }

                Text {
                    text: "Lock in your identity.";
                    font-size: 48px;
                    font-weight: 500;
                    color: Theme.text-primary;
                    letter-spacing: -1.5px;
                    horizontal-alignment: left;
                }

                Text {
                    text: "Save your setup so you can jump back in anytime.";
                    font-size: 14px;
                    color: Theme.text-secondary;
                    font-family: Theme.font-mono;
                    horizontal-alignment: left;
                }

                Rectangle {
                    height: 48px;
                }
            }

            // Centered content
            VerticalLayout {
                vertical-stretch: 1;
                alignment: start;

                // Summary card
                HorizontalLayout {
                    alignment: center;

                    Rectangle {
                        width: 320px;
                        height: 80px;
                        background: Theme.surface;
                        border-radius: Theme.r-inner;
                        border-width: 1px;
                        border-color: Theme.graphic-light;

                        HorizontalLayout {
                            padding-left: 24px;
                            padding-right: 24px;
                            padding-top: 16px;
                            padding-bottom: 16px;
                            spacing: 20px;
                            alignment: start;

                            Rectangle {
                                width: 48px;
                                height: 48px;
                                background: #FF1E561A;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: Theme.accent;
                                clip: true;

                                if has-chosen-avatar: Image {
                                    source: chosen-avatar-img;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: contain;
                                }

                                if !has-chosen-avatar: Text {
                                    text: nickname != "" ? nickname : "?";
                                    font-family: Theme.font-mono;
                                    font-size: 14px;
                                    font-weight: 600;
                                    color: Theme.text-primary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    max-width: 40px;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 4px;

                                Text {
                                    text: nickname != "" ? nickname : "Anonymous";
                                    font-family: Theme.font-mono;
                                    font-size: 16px;
                                    font-weight: 500;
                                    color: Theme.text-primary;
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    Rectangle {
                                        width: 6px;
                                        height: 6px;
                                        border-radius: 3px;
                                        background: Theme.accent-green;
                                    }

                                    Text {
                                        text: "ONLINE";
                                        font-size: 12px;
                                        color: Theme.text-secondary;
                                        letter-spacing: 0.5px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Auth grid view (default) ──
                if !show-email-form: Rectangle {
                    height: 64px;
                }

                if !show-email-form: HorizontalLayout {
                    alignment: center;

                    VerticalLayout {
                        width: 576px;
                        spacing: 16px;

                        // Row 1: Steam | Twitch
                        HorizontalLayout {
                            spacing: 16px;

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Steam";
                                icon: @image-url("../icons/brands/steam.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-steam();
                                }
                            }

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Twitch";
                                icon: @image-url("../icons/brands/twitch.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-twitch();
                                }
                            }
                        }

                        // Row 2: Google | Apple
                        HorizontalLayout {
                            spacing: 16px;

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Google";
                                icon: @image-url("../icons/brands/google.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-google();
                                }
                            }

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Apple";
                                icon: @image-url("../icons/brands/apple.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-apple();
                                }
                            }
                        }

                        // Row 3: Discord | Email+password
                        HorizontalLayout {
                            spacing: 16px;

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Discord";
                                icon: @image-url("../icons/brands/discord.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-discord();
                                }
                            }

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Email + password";
                                icon: @image-url("../icons/mail.svg");
                                has-icon: true;
                                subdued: true;
                                clicked => {
                                    root.show-email-form = true;
                                }
                            }
                        }
                    }
                }

                if !show-email-form: Rectangle {
                    height: 48px;
                }

                if !show-email-form: HorizontalLayout {
                    alignment: center;

                    Rectangle {
                        width: skip-text.preferred-width + 16px;
                        height: 24px;

                        skip-text := Text {
                            text: "Skip for now — continue as guest";
                            font-family: Theme.font-mono;
                            font-size: 11px;
                            color: skip-touch.has-hover ? Theme.text-secondary : Theme.text-tertiary;
                            letter-spacing: 0.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        skip-touch := TouchArea {
                            clicked => {
                                root.skip-identity();
                            }
                        }
                    }
                }

                // ── Email+password sub-view ──
                if show-email-form: Rectangle {
                    height: 48px;
                }

                if show-email-form: HorizontalLayout {
                    alignment: center;

                    VerticalLayout {
                        width: 400px;
                        spacing: 16px;

                        Text {
                            text: "Link email & password";
                            font-size: 20px;
                            font-weight: 500;
                            color: Theme.text-primary;
                            letter-spacing: -0.3px;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Your account will be tied to this email.";
                            font-family: Theme.font-mono;
                            font-size: 13px;
                            color: Theme.text-secondary;
                            horizontal-alignment: center;
                        }

                        Rectangle {
                            height: 8px;
                        }

                        InputField {
                            text <=> root.link-email-value;
                            placeholder: "Email";
                        }

                        InputField {
                            text <=> root.link-password-value;
                            placeholder: "Password";
                            is-password: true;
                        }

                        if link-error != "": Text {
                            text: link-error;
                            color: Theme.accent;
                            font-size: 13px;
                        }

                        // Action row: ← Back (secondary) + Link account → (primary CTA)
                        HorizontalLayout {
                            spacing: 12px;

                            // ← Back — secondary button
                            Rectangle {
                                horizontal-stretch: 0;
                                width: 120px;
                                height: 52px;
                                background: email-back-touch.has-hover ? Theme.graphic-light : transparent;
                                border-radius: Theme.r-inner;
                                border-width: 1px;
                                border-color: Theme.graphic-light;

                                email-back-touch := TouchArea {
                                    clicked => {
                                        root.show-email-form = false;
                                    }
                                }

                                HorizontalLayout {
                                    alignment: center;
                                    spacing: 8px;

                                    Text {
                                        text: "←";
                                        font-size: 16px;
                                        color: Theme.text-secondary;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: "Back";
                                        font-family: Theme.font-mono;
                                        font-size: 13px;
                                        font-weight: 500;
                                        color: Theme.text-secondary;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Link account → primary CTA
                            Rectangle {
                                horizontal-stretch: 1;
                                height: 52px;
                                border-radius: Theme.r-inner;
                                background: root.link-email-value != "" && root.link-password-value != "" ? Theme.accent : Theme.graphic-med;

                                link-touch := TouchArea {
                                    clicked => {
                                        if root.link-email-value != "" && root.link-password-value != "" {
                                            root.link-email(root.link-email-value, root.link-password-value);
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    alignment: center;
                                    spacing: 12px;

                                    Text {
                                        text: "Link account";
                                        font-family: Theme.font-mono;
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: #FFFFFF;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: "→";
                                        font-size: 16px;
                                        color: #FFFFFF;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
