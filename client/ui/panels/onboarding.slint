import { Theme } from "../theme.slint";
import { CrewData, AudioDeviceData } from "../types.slint";
import { DeviceDropdown } from "settings_modal.slint";

// ─── Reusable components ───

component CrewCard inherits Rectangle {
    in property <string> crew-name;
    in property <string> crew-description;
    in property <int> member-count;
    in property <int> online-count;
    in property <bool> featured: false;
    callback clicked();

    background: Theme.surface;
    border-radius: Theme.r-outer;
    border-width: 1px;
    border-color: card-touch.has-hover ? Theme.accent : Theme.graphic-light;

    card-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        padding: 24px;
        spacing: 8px;
        alignment: space-between;

        VerticalLayout {
            spacing: 8px;

            HorizontalLayout {
                alignment: space-between;

                Text {
                    text: crew-name;
                    font-family: Theme.font-mono;
                    font-size: 18px;
                    font-weight: 500;
                    color: Theme.text-primary;
                    overflow: elide;
                    letter-spacing: 0.5px;
                }

                if online-count > 0: Rectangle {
                    width: pill-text.preferred-width + 28px;
                    height: 24px;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: #FF1E564D;
                    background: #FF1E561A;

                    HorizontalLayout {
                        alignment: center;
                        spacing: 6px;

                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.accent;
                        }

                        pill-text := Text {
                            text: "LIVE";
                            font-family: Theme.font-mono;
                            font-size: 10px;
                            color: Theme.accent;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            if crew-description != "": Text {
                text: crew-description;
                font-size: 14px;
                color: Theme.text-secondary;
                wrap: word-wrap;
                overflow: elide;
            }
        }

        HorizontalLayout {
            alignment: space-between;

            Text {
                text: member-count < 10 ? "0" + member-count + " MEMBERS" : member-count + " MEMBERS";
                font-family: Theme.font-mono;
                font-size: 11px;
                color: Theme.text-tertiary;
                vertical-alignment: center;
            }

            Text {
                text: card-touch.has-hover ? "CONNECT →" : "JOIN";
                font-family: Theme.font-mono;
                font-size: 12px;
                font-weight: 500;
                color: card-touch.has-hover ? Theme.accent : Theme.text-tertiary;
                vertical-alignment: center;
            }
        }
    }
}

component CreateCrewCard inherits Rectangle {
    callback clicked();

    background: transparent;
    border-radius: Theme.r-outer;
    border-width: 1px;
    border-color: create-touch.has-hover ? Theme.accent : Theme.text-tertiary;

    create-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        alignment: center;
        spacing: 16px;

        HorizontalLayout {
            alignment: center;

            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: 16px;
                background: create-touch.has-hover ? Theme.accent : Theme.graphic-light;

                Text {
                    text: "+";
                    font-size: 28px;
                    font-weight: 300;
                    color: Theme.text-primary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Text {
            text: "CREATE YOUR\nOWN CREW";
            font-family: Theme.font-mono;
            font-size: 14px;
            color: Theme.text-secondary;
            horizontal-alignment: center;
            letter-spacing: 1.5px;
        }
    }
}

component AvatarOption inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    callback clicked();

    horizontal-stretch: 1;
    border-radius: Theme.r-inner;
    background: selected ? #FF1E561A : Theme.surface;
    border-width: selected ? 2px : 1px;
    border-color: selected ? Theme.accent : (av-touch.has-hover ? Theme.graphic-med : Theme.graphic-light);

    av-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: label;
        font-family: Theme.font-mono;
        font-size: 18px;
        color: selected ? Theme.text-primary : Theme.text-tertiary;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component StepIndicator inherits Rectangle {
    in property <int> current-step: 1;
    callback step-clicked(int);

    height: 20px;

    HorizontalLayout {
        spacing: 16px;
        alignment: start;

        Text {
            text: current-step < 10 ? "STEP 0" + current-step + " / 03" : "STEP " + current-step + " / 03";
            font-family: Theme.font-mono;
            font-size: 13px;
            color: Theme.accent;
            letter-spacing: 2px;
            vertical-alignment: center;
        }

        // Dots container — explicit centering via y offset
        Rectangle {
            width: 24px * 3 + 8px * 2;

            Rectangle {
                x: 0;
                y: (parent.height - 2px) / 2;
                width: 24px;
                height: 2px;
                background: current-step >= 1 ? Theme.accent : Theme.graphic-light;
                TouchArea {
                    clicked => {
                        root.step-clicked(1);
                    }
                }
            }

            Rectangle {
                x: 24px + 8px;
                y: (parent.height - 2px) / 2;
                width: 24px;
                height: 2px;
                background: current-step >= 2 ? Theme.accent : Theme.graphic-light;
                TouchArea {
                    clicked => {
                        root.step-clicked(2);
                    }
                }
            }

            Rectangle {
                x: (24px + 8px) * 2;
                y: (parent.height - 2px) / 2;
                width: 24px;
                height: 2px;
                background: current-step >= 3 ? Theme.accent : Theme.graphic-light;
                TouchArea {
                    clicked => {
                        root.step-clicked(3);
                    }
                }
            }
        }
    }
}

component InputField inherits Rectangle {
    in-out property <string> text <=> ti.text;
    in property <string> placeholder;
    in property <bool> is-password: false;

    height: 52px;
    background: Theme.surface;
    border-radius: Theme.r-inner;
    border-width: 1px;
    border-color: ti.has-focus ? Theme.graphic-med : Theme.graphic-light;

    ti := TextInput {
        x: 16px;
        width: parent.width - 32px;
        height: parent.height;
        font-family: Theme.font-mono;
        font-size: 14px;
        color: Theme.text-primary;
        horizontal-alignment: left;
        vertical-alignment: center;
        input-type: is-password ? InputType.password : InputType.text;
    }

    if ti.text == "": Text {
        x: 16px;
        color: Theme.text-tertiary;
        font-family: Theme.font-mono;
        font-size: 14px;
        vertical-alignment: center;
        text: placeholder;
    }
}

component AccentButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    callback clicked();

    height: 52px;
    background: enabled ? Theme.accent : Theme.graphic-med;
    border-radius: Theme.r-inner;

    btn-touch := TouchArea {
        clicked => {
            if root.enabled {
                root.clicked();
            }
        }
    }

    HorizontalLayout {
        alignment: center;
        spacing: 12px;

        Text {
            text: label;
            font-family: Theme.font-mono;
            font-size: 14px;
            font-weight: 600;
            color: #FFFFFF;
            vertical-alignment: center;
        }

        Text {
            text: "→";
            font-size: 16px;
            color: #FFFFFF;
            vertical-alignment: center;
        }
    }
}

component AuthButton inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> has-icon: false;
    in property <bool> subdued: false;
    callback clicked();

    height: 56px;
    preferred-width: 0px;
    background: auth-touch.has-hover ? #FFFFFF05 : transparent;
    border-radius: Theme.r-inner;
    border-width: 1px;
    border-color: auth-touch.has-hover ? Theme.graphic-med : Theme.graphic-light;
    opacity: subdued ? 0.6 : 1.0;

    auth-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    HorizontalLayout {
        padding-left: 16px;
        spacing: 16px;
        alignment: start;

        if has-icon: Image {
            source: icon;
            width: 20px;
            height: 20px;
            colorize: Theme.text-primary;
            y: (parent.height - self.height) / 2;
            opacity: 0.8;
        }

        Text {
            text: label;
            font-family: Theme.font-mono;
            font-size: 13px;
            color: Theme.text-primary;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

// ─── Main onboarding component ───

export component Onboarding inherits Rectangle {
    in property <int> step: 1;
    in property <[CrewData]> discover-crews: [];
    in property <string> link-error: "";

    // Audio device props for Step 2
    in property <[AudioDeviceData]> capture-devices: [];
    in property <[AudioDeviceData]> playback-devices: [];
    in property <string> selected-capture-id: "";
    in property <string> selected-playback-id: "";
    in-out property <string> selected-capture-name: "System Default";
    in-out property <string> selected-playback-name: "System Default";

    min-height: 800px;
    min-width: 1024px;
    in-out property <string> nickname: "";
    in-out property <int> selected-avatar: 0;

    in property <string> device-user-name: "";
    in property <bool> is-returning-user: false;

    // Sign-in view state (email/password login from step 1)
    in property <string> sign-in-error: "";
    in property <bool> sign-in-loading: false;
    property <bool> show-sign-in: false;
    property <string> si-email;
    property <string> si-password;

    // Email link form state (step 3)
    property <bool> show-email-form: false;
    property <string> link-email-value;
    property <string> link-password-value;

    callback crew-selected(string);
    callback create-crew-requested(string);
    callback continue-to-step(int);
    callback login-requested();
    callback sign-in(string, string);
    callback link-email(string, string);
    callback skip-identity();
    callback capture-device-selected(string);
    callback playback-device-selected(string);

    // Social auth callbacks
    callback auth-steam();
    callback auth-google();
    callback auth-twitch();
    callback auth-discord();
    callback auth-apple();

    background: Theme.bg-app;

    // ===================== STEP 1: Discover crews =====================
    if step == 1: Rectangle {
        background: Theme.bg-app;

        // ── Crew discovery (default sub-view) ──
        if !show-sign-in: Rectangle {

            // "Sign in" text link — top-right
            Rectangle {
                x: parent.width - 120px - self.width;
                y: is-returning-user ? 80px + 48px + 12px : 80px;
                width: signin-link-text.preferred-width + 16px;
                height: 32px;

                signin-link-text := Text {
                    text: "Sign in →";
                    font-family: Theme.font-mono;
                    font-size: 13px;
                    font-weight: 600;
                    color: signin-link-touch.has-hover ? Theme.accent : Theme.text-secondary;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    letter-spacing: 0.3px;
                }

                signin-link-touch := TouchArea {
                    clicked => {
                        show-sign-in = true;
                    }
                }
            }

            // Login pill — top-right, absolute positioned (only for returning users)
            if is-returning-user: Rectangle {
                x: parent.width - 120px - self.width;
                y: 80px;
                width: pill-layout.preferred-width;
                height: 48px;
                background: Theme.surface;
                border-radius: 999px;
                border-width: 1px;
                border-color: Theme.graphic-light;

                pill-layout := HorizontalLayout {
                    spacing: 0px;

                    // User side
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 16px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 10px;

                        Rectangle {
                            width: 32px;
                            height: 32px;
                            border-radius: 16px;
                            background: Theme.accent;

                            Text {
                                text: device-user-name != "" ? device-user-name : "?";
                                font-family: Theme.font-mono;
                                font-size: 13px;
                                font-weight: 700;
                                color: #FFFFFF;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;

                            Text {
                                text: "DEVICE USER";
                                font-family: Theme.font-mono;
                                font-size: 9px;
                                color: Theme.text-tertiary;
                                letter-spacing: 1px;
                            }

                            Text {
                                text: device-user-name != "" ? device-user-name : "anonymous";
                                font-family: Theme.font-mono;
                                font-size: 12px;
                                font-weight: 600;
                                color: Theme.text-primary;
                                letter-spacing: 0.3px;
                            }
                        }
                    }

                    // Divider
                    Rectangle {
                        width: 1px;
                        background: Theme.graphic-light;
                    }

                    // Sign In CTA (fast-track as device user)
                    Rectangle {
                        width: pill-cta-text.preferred-width + 36px;
                        height: 48px;

                        pill-cta-text := Text {
                            text: "SIGN IN →";
                            font-family: Theme.font-mono;
                            font-size: 11px;
                            font-weight: 700;
                            color: pill-cta-touch.has-hover ? Theme.accent : Theme.accent;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        pill-cta-touch := TouchArea {
                            clicked => {
                                root.login-requested();
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                padding-top: 80px;
                padding-left: 120px;
                padding-right: 120px;
                padding-bottom: 60px;
                spacing: 0px;

                // Header
                VerticalLayout {
                    spacing: 16px;

                    StepIndicator {
                        current-step: 1;
                        step-clicked(s) => {
                            root.continue-to-step(s);
                        }
                    }

                    Text {
                        text: "Discover Your Crew";
                        font-size: 48px;
                        font-weight: 500;
                        color: Theme.text-primary;
                        letter-spacing: -1.5px;
                    }

                    Text {
                        text: "Join a specialized squad to begin your deployment, or establish a new unit and lead the way.";
                        font-size: 18px;
                        color: Theme.text-secondary;
                        max-width: 540px;
                    }
                }

                Rectangle {
                    height: 56px;
                }

                // Bento grid — fixed 240px row heights
                VerticalLayout {
                    spacing: 20px;

                    // Row 1: [featured crew 0 (2x)] [create CTA] [crew 1]
                    HorizontalLayout {
                        height: 240px;
                        spacing: 20px;

                        CrewCard {
                            horizontal-stretch: 2;
                            featured: true;
                            crew-name: discover-crews.length > 0 ? discover-crews[0].name : "";
                            crew-description: discover-crews.length > 0 ? discover-crews[0].description : "";
                            member-count: discover-crews.length > 0 ? discover-crews[0].member-count : 0;
                            online-count: discover-crews.length > 0 ? discover-crews[0].online-count : 0;
                            visible: discover-crews.length > 0;
                            clicked => {
                                if discover-crews.length > 0 {
                                    root.crew-selected(discover-crews[0].id);
                                }
                            }
                        }

                        CreateCrewCard {
                            horizontal-stretch: 1;
                            clicked => {
                                root.create-crew-requested("New Crew");
                            }
                        }

                        CrewCard {
                            horizontal-stretch: 1;
                            crew-name: discover-crews.length > 1 ? discover-crews[1].name : "";
                            crew-description: discover-crews.length > 1 ? discover-crews[1].description : "";
                            member-count: discover-crews.length > 1 ? discover-crews[1].member-count : 0;
                            online-count: discover-crews.length > 1 ? discover-crews[1].online-count : 0;
                            visible: discover-crews.length > 1;
                            clicked => {
                                if discover-crews.length > 1 {
                                    root.crew-selected(discover-crews[1].id);
                                }
                            }
                        }
                    }

                    // Row 2: [crew 2] [featured crew 3 (2x)] [crew 4]
                    HorizontalLayout {
                        height: 240px;
                        spacing: 20px;

                        CrewCard {
                            horizontal-stretch: 1;
                            crew-name: discover-crews.length > 2 ? discover-crews[2].name : "";
                            crew-description: discover-crews.length > 2 ? discover-crews[2].description : "";
                            member-count: discover-crews.length > 2 ? discover-crews[2].member-count : 0;
                            online-count: discover-crews.length > 2 ? discover-crews[2].online-count : 0;
                            visible: discover-crews.length > 2;
                            clicked => {
                                if discover-crews.length > 2 {
                                    root.crew-selected(discover-crews[2].id);
                                }
                            }
                        }

                        CrewCard {
                            horizontal-stretch: 2;
                            featured: true;
                            crew-name: discover-crews.length > 3 ? discover-crews[3].name : "";
                            crew-description: discover-crews.length > 3 ? discover-crews[3].description : "";
                            member-count: discover-crews.length > 3 ? discover-crews[3].member-count : 0;
                            online-count: discover-crews.length > 3 ? discover-crews[3].online-count : 0;
                            visible: discover-crews.length > 3;
                            clicked => {
                                if discover-crews.length > 3 {
                                    root.crew-selected(discover-crews[3].id);
                                }
                            }
                        }

                        CrewCard {
                            horizontal-stretch: 1;
                            crew-name: discover-crews.length > 4 ? discover-crews[4].name : "";
                            crew-description: discover-crews.length > 4 ? discover-crews[4].description : "";
                            member-count: discover-crews.length > 4 ? discover-crews[4].member-count : 0;
                            online-count: discover-crews.length > 4 ? discover-crews[4].online-count : 0;
                            visible: discover-crews.length > 4;
                            clicked => {
                                if discover-crews.length > 4 {
                                    root.crew-selected(discover-crews[4].id);
                                }
                            }
                        }
                    }
                }

                // Push nav to bottom
                Rectangle {
                    vertical-stretch: 1;
                }

                // Bottom navigation
                HorizontalLayout {
                    alignment: end;
                    spacing: 32px;
                    height: 48px;

                    Rectangle {
                        width: skip-step1-text.preferred-width + 16px;

                        skip-step1-text := Text {
                            text: "Skip exploration";
                            font-family: Theme.font-mono;
                            font-size: 13px;
                            color: skip-step1-touch.has-hover ? Theme.text-secondary : Theme.text-tertiary;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        skip-step1-touch := TouchArea {
                            clicked => {
                                root.continue-to-step(2);
                            }
                        }
                    }

                    AccentButton {
                        width: 160px;
                        label: "CONTINUE";
                        clicked => {
                            root.continue-to-step(2);
                        }
                    }
                }
            }
        }

        // ── Sign-in sub-view ──
        if show-sign-in: Rectangle {

            VerticalLayout {
                padding-top: 80px;
                padding-left: 120px;
                padding-right: 120px;
                padding-bottom: 60px;
                spacing: 0px;

                // Back link
                HorizontalLayout {
                    alignment: start;
                    height: 32px;

                    Rectangle {
                        width: back-text.preferred-width + 16px;
                        height: 32px;

                        back-text := Text {
                            text: "← Back";
                            font-family: Theme.font-mono;
                            font-size: 13px;
                            color: back-touch.has-hover ? Theme.text-secondary : Theme.text-tertiary;
                            vertical-alignment: center;
                        }

                        back-touch := TouchArea {
                            clicked => {
                                show-sign-in = false;
                            }
                        }
                    }
                }

                Rectangle {
                    height: 32px;
                }

                // Header
                VerticalLayout {
                    spacing: 16px;

                    Text {
                        text: "Sign In";
                        font-size: 48px;
                        font-weight: 500;
                        color: Theme.text-primary;
                        letter-spacing: -1.5px;
                    }

                    Text {
                        text: "Sign in with an existing account or link a new identity.";
                        font-size: 18px;
                        color: Theme.text-secondary;
                        max-width: 540px;
                    }
                }

                Rectangle {
                    height: 56px;
                }

                // Auth options
                VerticalLayout {
                    width: 400px;
                    spacing: 16px;

                    // P0 social auth (full-width)
                    AuthButton {
                        label: "Continue with Steam";
                        icon: @image-url("../icons/brands/steam.svg");
                        has-icon: true;
                        clicked => {
                            root.auth-steam();
                        }
                    }

                    AuthButton {
                        label: "Continue with Google";
                        icon: @image-url("../icons/brands/google.svg");
                        has-icon: true;
                        clicked => {
                            root.auth-google();
                        }
                    }

                    AuthButton {
                        label: "Continue with Twitch";
                        icon: @image-url("../icons/brands/twitch.svg");
                        has-icon: true;
                        clicked => {
                            root.auth-twitch();
                        }
                    }

                    // P1 social auth (half-width row)
                    HorizontalLayout {
                        spacing: 16px;

                        AuthButton {
                            horizontal-stretch: 1;
                            label: "Discord";
                            icon: @image-url("../icons/brands/discord.svg");
                            has-icon: true;
                            subdued: true;
                            clicked => {
                                root.auth-discord();
                            }
                        }

                        AuthButton {
                            horizontal-stretch: 1;
                            label: "Apple";
                            icon: @image-url("../icons/brands/apple.svg");
                            has-icon: true;
                            subdued: true;
                            clicked => {
                                root.auth-apple();
                            }
                        }
                    }

                    // Divider
                    HorizontalLayout {
                        height: 32px;
                        spacing: 16px;
                        alignment: center;

                        Rectangle {
                            vertical-stretch: 0;
                            height: 1px;
                            horizontal-stretch: 1;
                            background: Theme.graphic-light;
                            y: parent.height / 2;
                        }

                        Text {
                            text: "or";
                            font-family: Theme.font-mono;
                            font-size: 12px;
                            color: Theme.text-tertiary;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            vertical-stretch: 0;
                            height: 1px;
                            horizontal-stretch: 1;
                            background: Theme.graphic-light;
                            y: parent.height / 2;
                        }
                    }

                    // Email / password
                    InputField {
                        text <=> root.si-email;
                        placeholder: "Email";
                    }

                    InputField {
                        text <=> root.si-password;
                        placeholder: "Password";
                        is-password: true;
                    }

                    // Error
                    if sign-in-error != "": Text {
                        text: sign-in-error;
                        color: Theme.accent;
                        font-size: 13px;
                    }

                    // Sign-in button
                    AccentButton {
                        label: sign-in-loading ? "SIGNING IN…" : "SIGN IN";
                        enabled: !sign-in-loading;
                        clicked => {
                            root.sign-in(root.si-email, root.si-password);
                        }
                    }
                }

                // Push to bottom
                Rectangle {
                    vertical-stretch: 1;
                }
            }
        }
    }

    // ===================== STEP 2: Profile setup =====================
    if step == 2: Rectangle {
        background: Theme.bg-app;

        VerticalLayout {
            padding-top: 80px;
            padding-left: 140px;
            padding-right: 140px;
            padding-bottom: 40px;
            spacing: 0px;

            // Header
            VerticalLayout {
                spacing: 12px;

                StepIndicator {
                    current-step: 2;
                    step-clicked(s) => {
                        root.continue-to-step(s);
                    }
                }

                Text {
                    text: "Profile & Device Setup";
                    font-size: 36px;
                    font-weight: 500;
                    color: Theme.text-primary;
                    letter-spacing: -0.7px;
                }
            }

            Rectangle {
                height: 64px;
            }

            // Two-column grid (440px left | flex right, gap 120px)
            HorizontalLayout {
                spacing: 120px;

                // Left column: Avatar + nickname (fixed 440px)
                VerticalLayout {
                    width: 440px;
                    alignment: start;

                    Text {
                        text: "CHOOSE IDENTITY";
                        font-size: 11px;
                        font-weight: 500;
                        color: Theme.text-secondary;
                        letter-spacing: 1.5px;
                    }

                    Rectangle {
                        height: 20px;
                    }

                    // Avatar grid 4x2
                    VerticalLayout {
                        spacing: 12px;

                        HorizontalLayout {
                            spacing: 12px;
                            height: 96px;

                            AvatarOption {
                                label: "ME";
                                selected: selected-avatar == 0;
                                clicked => {
                                    selected-avatar = 0;
                                }
                            }

                            AvatarOption {
                                label: "A1";
                                selected: selected-avatar == 1;
                                clicked => {
                                    selected-avatar = 1;
                                }
                            }

                            AvatarOption {
                                label: "A2";
                                selected: selected-avatar == 2;
                                clicked => {
                                    selected-avatar = 2;
                                }
                            }

                            AvatarOption {
                                label: "A3";
                                selected: selected-avatar == 3;
                                clicked => {
                                    selected-avatar = 3;
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            height: 96px;

                            AvatarOption {
                                label: "A4";
                                selected: selected-avatar == 4;
                                clicked => {
                                    selected-avatar = 4;
                                }
                            }

                            AvatarOption {
                                label: "A5";
                                selected: selected-avatar == 5;
                                clicked => {
                                    selected-avatar = 5;
                                }
                            }

                            AvatarOption {
                                label: "A6";
                                selected: selected-avatar == 6;
                                clicked => {
                                    selected-avatar = 6;
                                }
                            }

                            AvatarOption {
                                label: "A7";
                                selected: selected-avatar == 7;
                                clicked => {
                                    selected-avatar = 7;
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 48px;
                    }

                    Text {
                        text: "CREW NICKNAME";
                        font-size: 11px;
                        font-weight: 500;
                        color: Theme.text-secondary;
                        letter-spacing: 1.5px;
                    }

                    Rectangle {
                        height: 12px;
                    }

                    InputField {
                        text <=> root.nickname;
                        placeholder: "Enter handle...";
                    }
                }

                // Right column: Device selectors
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: start;

                    Text {
                        text: "MICROPHONE INPUT";
                        font-size: 10px;
                        font-weight: 600;
                        color: Theme.text-secondary;
                        letter-spacing: 1.3px;
                    }

                    Rectangle {
                        height: 8px;
                    }

                    DeviceDropdown {
                        devices: root.capture-devices;
                        selected-id: root.selected-capture-id;
                        selected-name <=> root.selected-capture-name;
                        device-selected(id) => {
                            root.capture-device-selected(id);
                        }
                    }

                    Rectangle {
                        height: 32px;
                    }

                    Text {
                        text: "SPEAKER OUTPUT";
                        font-size: 10px;
                        font-weight: 600;
                        color: Theme.text-secondary;
                        letter-spacing: 1.3px;
                    }

                    Rectangle {
                        height: 8px;
                    }

                    DeviceDropdown {
                        devices: root.playback-devices;
                        selected-id: root.selected-playback-id;
                        selected-name <=> root.selected-playback-name;
                        device-selected(id) => {
                            root.playback-device-selected(id);
                        }
                    }
                }
            }

            // Push continue button to bottom
            Rectangle {
                vertical-stretch: 1;
            }

            // Footer with Continue button
            HorizontalLayout {
                height: 52px;
                alignment: end;

                AccentButton {
                    width: 200px;
                    label: "Continue";
                    enabled: nickname != "";
                    clicked => {
                        root.continue-to-step(3);
                    }
                }
            }
        }
    }

    // ===================== STEP 3: Lock in identity =====================
    if step == 3: Rectangle {
        background: Theme.bg-app;

        VerticalLayout {
            padding-top: 80px;
            padding-left: 120px;
            padding-right: 120px;
            padding-bottom: 40px;
            spacing: 0px;

            // Header: top-left aligned
            VerticalLayout {
                spacing: 8px;

                StepIndicator {
                    current-step: 3;
                    step-clicked(s) => {
                        root.continue-to-step(s);
                    }
                }

                Text {
                    text: "Lock in your identity.";
                    font-size: 48px;
                    font-weight: 500;
                    color: Theme.text-primary;
                    letter-spacing: -1.5px;
                    horizontal-alignment: left;
                }

                Text {
                    text: "Save your setup so you can jump back in anytime.";
                    font-size: 14px;
                    color: Theme.text-secondary;
                    font-family: Theme.font-mono;
                    horizontal-alignment: left;
                }

                Rectangle {
                    height: 48px;
                }
            }

            // Centered content
            VerticalLayout {
                vertical-stretch: 1;
                alignment: start;

                // Summary card
                HorizontalLayout {
                    alignment: center;

                    Rectangle {
                        width: 320px;
                        height: 80px;
                        background: Theme.surface;
                        border-radius: Theme.r-inner;
                        border-width: 1px;
                        border-color: Theme.graphic-light;

                        HorizontalLayout {
                            padding-left: 24px;
                            padding-right: 24px;
                            padding-top: 16px;
                            padding-bottom: 16px;
                            spacing: 20px;
                            alignment: start;

                            Rectangle {
                                width: 48px;
                                height: 48px;
                                background: #FF1E561A;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: Theme.accent;

                                Text {
                                    text: nickname != "" ? nickname : "?";
                                    font-family: Theme.font-mono;
                                    font-size: 18px;
                                    color: Theme.text-primary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 4px;

                                Text {
                                    text: nickname != "" ? nickname : "Anonymous";
                                    font-family: Theme.font-mono;
                                    font-size: 16px;
                                    font-weight: 500;
                                    color: Theme.text-primary;
                                }

                                HorizontalLayout {
                                    spacing: 8px;

                                    Rectangle {
                                        width: 6px;
                                        height: 6px;
                                        border-radius: 3px;
                                        background: Theme.accent-green;
                                    }

                                    Text {
                                        text: "ONLINE";
                                        font-size: 12px;
                                        color: Theme.text-secondary;
                                        letter-spacing: 0.5px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Auth grid view (default) ──
                if !show-email-form: Rectangle {
                    height: 64px;
                }

                if !show-email-form: HorizontalLayout {
                    alignment: center;

                    VerticalLayout {
                        width: 576px;
                        spacing: 16px;

                        // Row 1: Steam | Twitch
                        HorizontalLayout {
                            spacing: 16px;

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Steam";
                                icon: @image-url("../icons/brands/steam.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-steam();
                                }
                            }

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Twitch";
                                icon: @image-url("../icons/brands/twitch.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-twitch();
                                }
                            }
                        }

                        // Row 2: Google | Apple
                        HorizontalLayout {
                            spacing: 16px;

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Google";
                                icon: @image-url("../icons/brands/google.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-google();
                                }
                            }

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Apple";
                                icon: @image-url("../icons/brands/apple.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-apple();
                                }
                            }
                        }

                        // Row 3: Discord | Email+password
                        HorizontalLayout {
                            spacing: 16px;

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Discord";
                                icon: @image-url("../icons/brands/discord.svg");
                                has-icon: true;
                                clicked => {
                                    root.auth-discord();
                                }
                            }

                            AuthButton {
                                horizontal-stretch: 1;
                                label: "Email + password";
                                icon: @image-url("../icons/mail.svg");
                                has-icon: true;
                                subdued: true;
                                clicked => {
                                    root.show-email-form = true;
                                }
                            }
                        }
                    }
                }

                if !show-email-form: Rectangle {
                    height: 48px;
                }

                if !show-email-form: HorizontalLayout {
                    alignment: center;

                    Rectangle {
                        width: skip-text.preferred-width + 16px;
                        height: 24px;

                        skip-text := Text {
                            text: "Skip for now — continue as guest";
                            font-family: Theme.font-mono;
                            font-size: 11px;
                            color: skip-touch.has-hover ? Theme.text-secondary : Theme.text-tertiary;
                            letter-spacing: 0.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        skip-touch := TouchArea {
                            clicked => {
                                root.skip-identity();
                            }
                        }
                    }
                }

                // ── Email+password sub-view ──
                if show-email-form: Rectangle {
                    height: 48px;
                }

                if show-email-form: HorizontalLayout {
                    alignment: center;

                    VerticalLayout {
                        width: 400px;
                        spacing: 16px;

                        Text {
                            text: "Link email & password";
                            font-size: 20px;
                            font-weight: 500;
                            color: Theme.text-primary;
                            letter-spacing: -0.3px;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Your account will be tied to this email.";
                            font-family: Theme.font-mono;
                            font-size: 13px;
                            color: Theme.text-secondary;
                            horizontal-alignment: center;
                        }

                        Rectangle {
                            height: 8px;
                        }

                        InputField {
                            text <=> root.link-email-value;
                            placeholder: "Email";
                        }

                        InputField {
                            text <=> root.link-password-value;
                            placeholder: "Password";
                            is-password: true;
                        }

                        if link-error != "": Text {
                            text: link-error;
                            color: Theme.accent;
                            font-size: 13px;
                        }

                        // Action row: ← Back (secondary) + Link account → (primary CTA)
                        HorizontalLayout {
                            spacing: 12px;

                            // ← Back — secondary button
                            Rectangle {
                                horizontal-stretch: 0;
                                width: 120px;
                                height: 52px;
                                background: email-back-touch.has-hover ? Theme.graphic-light : transparent;
                                border-radius: Theme.r-inner;
                                border-width: 1px;
                                border-color: Theme.graphic-light;

                                email-back-touch := TouchArea {
                                    clicked => {
                                        root.show-email-form = false;
                                    }
                                }

                                HorizontalLayout {
                                    alignment: center;
                                    spacing: 8px;

                                    Text {
                                        text: "←";
                                        font-size: 16px;
                                        color: Theme.text-secondary;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: "Back";
                                        font-family: Theme.font-mono;
                                        font-size: 13px;
                                        font-weight: 500;
                                        color: Theme.text-secondary;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Link account → primary CTA
                            Rectangle {
                                horizontal-stretch: 1;
                                height: 52px;
                                border-radius: Theme.r-inner;
                                background: root.link-email-value != "" && root.link-password-value != "" ? Theme.accent : Theme.graphic-med;

                                link-touch := TouchArea {
                                    clicked => {
                                        if root.link-email-value != "" && root.link-password-value != "" {
                                            root.link-email(root.link-email-value, root.link-password-value);
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    alignment: center;
                                    spacing: 12px;

                                    Text {
                                        text: "Link account";
                                        font-family: Theme.font-mono;
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: #FFFFFF;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: "→";
                                        font-size: 16px;
                                        color: #FFFFFF;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
