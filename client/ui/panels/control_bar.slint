import { Theme } from "../theme.slint";
import { GameBadge } from "../components/game_badge.slint";

component ActionButton inherits Rectangle {
    in property <image> icon;
    in property <bool> alert: false;
    callback clicked();
    width: 40px;
    Rectangle {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: alert ? Theme.accent-bg : (btn-hover.has-hover ? (Theme.dark ? #FFFFFF1A : #0000000D) : transparent);
        y: (parent.height - self.height) / 2;
        Image {
            source: icon;
            width: 20px;
            height: 20px;
            colorize: alert ? Theme.accent : (btn-hover.has-hover ? Theme.text-primary : Theme.text-secondary);
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
    }

    btn-hover := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

component ReactionButton inherits Rectangle {
    in property <image> icon;
    in property <color> icon-color;
    in property <color> bg;
    in property <color> border-clr;
    callback clicked();
    width: 42px;
    height: 42px;
    border-radius: Theme.r-inner;
    background: react-hover.has-hover ? border-clr : bg;
    border-width: 1px;
    border-color: border-clr;
    Image {
        source: icon;
        width: 22px;
        height: 22px;
        colorize: icon-color;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    react-hover := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

component MenuItem inherits Rectangle {
    in property <string> label;
    in property <color> dot-color: transparent;
    in property <bool> has-dot: false;
    in property <bool> checked: false;
    in property <bool> destructive: false;
    callback clicked();
    height: 36px;
    border-radius: Theme.r-inner;
    background: item-hover.has-hover ? Theme.hover-overlay : transparent;
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: start;
        if has-dot: Rectangle {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: dot-color;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: label;
            font-size: Theme.font-md;
            font-weight: checked ? 600 : 400;
            color: destructive ? Theme.accent : Theme.text-primary;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }

        if checked: Text {
            text: "✓";
            font-size: Theme.font-md;
            color: Theme.accent-green;
            vertical-alignment: center;
        }
    }

    item-hover := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component MenuSeparator inherits Rectangle {
    height: 1px;
    background: Theme.graphic-light;
}

export component ControlBar inherits Rectangle {
    in property <string> user-name: "";
    in property <string> user-initials: "";
    in property <image> user-avatar;
    in property <bool> has-user-avatar: false;
    in property <string> user-tag: "";
    in-out property <bool> mic-muted: false;
    in-out property <bool> deafened: false;
    in-out property <bool> in-voice: false;
    in property <bool> mic-permission-granted: true;
    in property <bool> mic-permission-denied: false;
    // 0=online, 1=idle, 2=dnd, 3=invisible
    in-out property <int> presence-status: 0;

    // Game sensing
    in property <bool> game-active: false;
    in property <string> game-name: "";
    in property <string> game-short-name: "";
    in property <color> game-color: #2a2a30;
    in property <bool> can-stream: false;
    in property <bool> is-hosting: false;
    in property <bool> is-watching: false;
    // 0=idle, 1=now-playing, 2=post-game, 3=moment-input, 4=confirmed
    in-out property <int> bar-state: 0;
    callback mic-toggled();
    callback deafen-toggled();
    callback voice-toggled();
    callback logout-clicked();
    callback presence-changed(int);
    callback theme-toggled();
    callback settings-clicked();
    callback debug-toggled();
    callback request-mic-permission();
    callback open-mic-settings();
    callback go-live-clicked();

    // Game callbacks
    callback stream-requested();
    callback reaction-tapped(string);
    callback moment-submitted(string);
    callback moment-dismissed();

    // Clip
    callback clip-captured();
    in property <string> voice-channel-name: "";
    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.dark ? #FFFFFF0D : Theme.graphic-light;
    border-radius: 16px;
    HorizontalLayout {
        padding: 14px;
        spacing: 12px;

        // ===== LEFT: Identity / Voice card =====
        Rectangle {
            horizontal-stretch: 0;
            background: Theme.bg-app;
            border-radius: 12px;
            border-width: 1px;
            border-color: Theme.dark ? #FFFFFF0D : #0000000D;
            HorizontalLayout {
                padding: 6px;
                padding-right: in-voice ? 8px : 16px;
                spacing: 16px;

                // Avatar
                Rectangle {
                    width: 44px;
                    height: 44px;
                    border-radius: 8px;
                    background: avatar-touch.has-hover ? Theme.graphic-light : Theme.bg-app;
                    clip: true;
                    if has-user-avatar: Image {
                        source: user-avatar;
                        width: parent.width;
                        height: parent.height;
                        image-fit: contain;
                    }
                    if !has-user-avatar: Text {
                        text: user-initials != "" ? user-initials : "?";
                        font-weight: 600;
                        font-size: 14px;
                        color: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        x: parent.width - 14px;
                        y: parent.height - 14px;
                        width: 14px;
                        height: 14px;
                        border-radius: 7px;
                        background: in-voice ? Theme.bg-app : Theme.surface;
                        Rectangle {
                            x: 3px;
                            y: 3px;
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: in-voice ? Theme.accent-green : (presence-status == 0 ? Theme.accent-green : (presence-status == 1 ? #FFBD2E : (presence-status == 2 ? Theme.accent : Theme.graphic-med)));
                        }
                    }

                    avatar-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            user-menu.show();
                        }
                    }

                    user-menu := PopupWindow {
                        x: 0;
                        y: -344px;
                        width: 220px;
                        Rectangle {
                            background: Theme.surface;
                            border-radius: Theme.r-outer;
                            border-width: 1px;
                            border-color: Theme.graphic-light;
                            drop-shadow-blur: 16px;
                            drop-shadow-color: Theme.dark ? #00000080 : #00000020;
                            drop-shadow-offset-y: 4px;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 2px;
                                Text {
                                    text: "PRESENCE";
                                    font-size: Theme.font-xs;
                                    font-weight: 600;
                                    letter-spacing: 1.2px;
                                    color: Theme.text-tertiary;
                                    height: 28px;
                                    vertical-alignment: center;
                                    x: 12px;
                                }

                                MenuItem {
                                    label: "Online";
                                    has-dot: true;
                                    dot-color: Theme.accent-green;
                                    checked: presence-status == 0;
                                    clicked => {
                                        presence-status = 0;
                                        presence-changed(0);
                                    }
                                }

                                MenuItem {
                                    label: "Idle";
                                    has-dot: true;
                                    dot-color: #FFBD2E;
                                    checked: presence-status == 1;
                                    clicked => {
                                        presence-status = 1;
                                        presence-changed(1);
                                    }
                                }

                                MenuItem {
                                    label: "Do Not Disturb";
                                    has-dot: true;
                                    dot-color: Theme.accent;
                                    checked: presence-status == 2;
                                    clicked => {
                                        presence-status = 2;
                                        presence-changed(2);
                                    }
                                }

                                MenuItem {
                                    label: "Invisible";
                                    has-dot: true;
                                    dot-color: Theme.graphic-med;
                                    checked: presence-status == 3;
                                    clicked => {
                                        presence-status = 3;
                                        presence-changed(3);
                                    }
                                }

                                MenuSeparator { }

                                MenuItem {
                                    label: Theme.dark ? "Light Mode" : "Dark Mode";
                                    clicked => {
                                        theme-toggled();
                                    }
                                }

                                MenuItem {
                                    label: "Debug Audio";
                                    clicked => {
                                        debug-toggled();
                                    }
                                }

                                MenuSeparator { }

                                MenuItem {
                                    label: "Log Out";
                                    destructive: true;
                                    clicked => {
                                        logout-clicked();
                                    }
                                }
                            }
                        }
                    }
                }

                // Name + status
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: user-name != "" ? user-name : "Not connected";
                        font-size: 15px;
                        font-weight: 600;
                        color: Theme.dark ? #E0E0E0 : Theme.text-primary;
                        overflow: elide;
                    }

                    if !in-voice && user-tag != "": Text {
                        text: user-tag;
                        font-family: Theme.font-mono;
                        font-size: Theme.font-xs;
                        color: Theme.text-secondary;
                        overflow: elide;
                    }
                    if in-voice: HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.accent-green;
                            y: (parent.height - self.height) / 2;
                        }

                        Text {
                            text: voice-channel-name != "" ? voice-channel-name : "VOICE";
                            font-family: Theme.font-mono;
                            font-size: Theme.font-sm;
                            font-weight: 700;
                            letter-spacing: 1.5px;
                            color: Theme.accent-green;
                            vertical-alignment: center;
                        }
                    }
                }

                // Separator (voice card only)
                if in-voice: Rectangle {
                    width: 9px;
                    Rectangle {
                        width: 1px;
                        height: 24px;
                        background: Theme.dark ? #FFFFFF14 : #00000014;
                        x: 4px;
                        y: (parent.height - self.height) / 2;
                    }
                }

                // Disconnect button (voice card only)
                if in-voice: Rectangle {
                    width: 40px;
                    Rectangle {
                        width: 40px;
                        height: 40px;
                        border-radius: 8px;
                        background: hangup-hover.has-hover ? (Theme.dark ? #FF1E5633 : #FF1E5628) : Theme.accent-bg;
                        border-width: 1px;
                        border-color: Theme.dark ? #FF1E5633 : #FF1E5620;
                        y: (parent.height - self.height) / 2;
                        Image {
                            source: @image-url("../icons/phone-off.svg");
                            width: 20px;
                            height: 20px;
                            colorize: Theme.accent;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }

                    hangup-hover := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            voice-toggled();
                        }
                    }
                }
            }
        }

        // ===== SPACER =====
        Rectangle {
            horizontal-stretch: 1;
        }

        // ===== CENTER: Game states =====

        // State 1: Now Playing
        if bar-state == 1: VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            Rectangle {
                background: Theme.bg-app;
                border-radius: 12px;
                border-width: 1px;
                border-color: Theme.dark ? #FFFFFF0D : #0000000D;
                HorizontalLayout {
                    padding: 12px;
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 12px;
                    GameBadge {
                        short-name: game-short-name;
                        bg-color: game-color;
                        size: 32px;
                        y: (parent.height - self.height) / 2;
                    }

                    VerticalLayout {
                        spacing: 2px;
                        alignment: center;
                        Text {
                            text: "NOW PLAYING";
                            font-size: 10px;
                            color: Theme.text-tertiary;
                            letter-spacing: 1px;
                        }

                        Text {
                            text: game-name;
                            font-size: 13px;
                            color: Theme.text-secondary;
                            font-weight: 500;
                        }
                    }

                    if can-stream: Rectangle {
                        width: 1px;
                        height: 24px;
                        background: Theme.dark ? #FFFFFF14 : #00000014;
                        y: (parent.height - self.height) / 2;
                    }
                    if can-stream: Rectangle {
                        width: stream-label.preferred-width + 28px;
                        height: 32px;
                        border-radius: 8px;
                        background: Theme.accent;
                        y: (parent.height - self.height) / 2;
                        stream-label := Text {
                            text: "STREAM";
                            font-size: 11px;
                            font-weight: 700;
                            color: white;
                            letter-spacing: 0.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                stream-requested();
                            }
                        }
                    }
                }
            }
        }

        // State 2: Post-game prompt
        if bar-state == 2: VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            HorizontalLayout {
                spacing: 16px;
                GameBadge {
                    short-name: game-short-name;
                    bg-color: game-color;
                    size: 32px;
                }

                Text {
                    text: "How'd it go?";
                    font-size: 13px;
                    color: Theme.text-secondary;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    spacing: 10px;
                    ReactionButton {
                        icon: @image-url("../icons/trophy.svg");
                        icon-color: #4ade80;
                        bg: #1e2a1e;
                        border-clr: #2d4a2d;
                        clicked => {
                            reaction-tapped("win");
                        }
                    }

                    ReactionButton {
                        icon: @image-url("../icons/sad-face.svg");
                        icon-color: #f87171;
                        bg: #2a1e1e;
                        border-clr: #4a2d2d;
                        clicked => {
                            reaction-tapped("loss");
                        }
                    }

                    ReactionButton {
                        icon: @image-url("../icons/star.svg");
                        icon-color: #fbbf24;
                        bg: #2a2418;
                        border-clr: #4a3d1d;
                        clicked => {
                            reaction-tapped("highlight");
                        }
                    }
                }
            }
        }

        // State 3: Moment text input
        if bar-state == 3: VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            HorizontalLayout {
                spacing: 10px;
                Rectangle {
                    horizontal-stretch: 1;
                    height: 36px;
                    border-radius: Theme.r-inner;
                    background: Theme.bg-app;
                    border-width: 1px;
                    border-color: Theme.graphic-light;
                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 8px;
                        alignment: start;
                        Image {
                            source: @image-url("../icons/star.svg");
                            width: 16px;
                            height: 16px;
                            colorize: #fbbf24;
                            y: (parent.height - self.height) / 2;
                        }

                        moment-input := TextInput {
                            font-size: 13px;
                            color: Theme.text-primary;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            accepted => {
                                if self.text != "" {
                                    moment-submitted(self.text);
                                    self.text = "";
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: Theme.r-inner;
                    background: Theme.accent;
                    Image {
                        source: @image-url("../icons/arrow-right.svg");
                        width: 16px;
                        height: 16px;
                        colorize: white;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if moment-input.text != "" {
                                moment-submitted(moment-input.text);
                                moment-input.text = "";
                            }
                        }
                    }
                }
            }
        }

        // State 4: Confirmed
        if bar-state == 4: VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            HorizontalLayout {
                spacing: 8px;
                Image {
                    source: @image-url("../icons/checkmark.svg");
                    width: 18px;
                    height: 18px;
                    colorize: #4ade80;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: "Moment shared with crew";
                    font-size: 13px;
                    color: #4ade80;
                    font-weight: 500;
                    vertical-alignment: center;
                }
            }
        }

        // ===== SPACER =====
        Rectangle {
            horizontal-stretch: 1;
        }

        // ===== RIGHT: Controls group =====
        if mic-permission-granted: Rectangle {
            horizontal-stretch: 0;
            background: Theme.bg-app;
            border-radius: 12px;
            border-width: 1px;
            border-color: Theme.dark ? #FFFFFF0D : #0000000D;
            HorizontalLayout {
                padding: 6px;
                spacing: 0px;

                // Clip button (only when in voice)
                if in-voice: Rectangle {
                    width: 40px;
                    Rectangle {
                        width: 40px;
                        height: 40px;
                        border-radius: 8px;
                        background: clip-hover.has-hover ? (Theme.dark ? #F59E0B33 : #F59E0B28) : transparent;
                        y: (parent.height - self.height) / 2;
                        Image {
                            source: @image-url("../icons/scissors-line-dashed.svg");
                            colorize: Theme.clip-amber;
                            width: 20px;
                            height: 20px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }

                    clip-hover := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            clip-captured();
                        }
                    }
                }

                // Go live
                Rectangle {
                    width: 40px;
                    Rectangle {
                        width: 40px;
                        height: 40px;
                        border-radius: 8px;
                        background: go-live-hover.has-hover ? (Theme.dark ? #FFFFFF1A : #0000000D) : transparent;
                        y: (parent.height - self.height) / 2;
                        Image {
                            source: @image-url("../icons/broadcast.svg");
                            colorize: is-hosting ? Theme.accent
                                : go-live-hover.has-hover ? Theme.accent
                                : Theme.text-secondary;
                            width: 20px;
                            height: 20px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }

                    go-live-hover := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { go-live-clicked(); }
                    }
                }

                ActionButton {
                    icon: mic-muted ? @image-url("../icons/mic-off.svg") : @image-url("../icons/mic.svg");
                    alert: in-voice && mic-muted;
                    clicked => {
                        mic-toggled();
                    }
                }

                ActionButton {
                    icon: deafened ? @image-url("../icons/headphone-off.svg") : @image-url("../icons/headphones.svg");
                    alert: in-voice && deafened;
                    clicked => {
                        deafen-toggled();
                    }
                }

                // Separator before settings
                Rectangle {
                    width: 9px;
                    Rectangle {
                        width: 1px;
                        height: 24px;
                        background: Theme.dark ? #FFFFFF14 : #00000014;
                        x: 4px;
                        y: (parent.height - self.height) / 2;
                    }
                }

                ActionButton {
                    icon: @image-url("../icons/settings.svg");
                    clicked => {
                        settings-clicked();
                    }
                }
            }
        }

        // --- Right: mic permission CTA (when no mic access) ---
        if !mic-permission-granted: HorizontalLayout {
            horizontal-stretch: 0;
            spacing: 12px;
            alignment: center;
            Text {
                text: mic-permission-denied ? "Microphone access denied — enable it in System Settings" : "Microphone access is needed for voice chat";
                font-family: Theme.font-mono;
                font-size: 11px;
                color: Theme.text-secondary;
                vertical-alignment: center;
            }

            Rectangle {
                width: mic-cta-row.preferred-width + 28px;
                height: 36px;
                border-radius: Theme.r-inner;
                background: Theme.accent;
                mic-cta-row := HorizontalLayout {
                    alignment: center;
                    spacing: 8px;
                    Text {
                        text: mic-permission-denied ? "Open Settings" : "Allow Microphone";
                        font-family: Theme.font-mono;
                        font-size: 12px;
                        font-weight: 600;
                        color: #FFFFFF;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "→";
                        font-size: 14px;
                        color: #FFFFFF;
                        vertical-alignment: center;
                    }
                }

                mic-btn-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        if (root.mic-permission-denied) {
                            root.open-mic-settings();
                        } else {
                            root.request-mic-permission();
                        }
                    }
                }
            }
        }
    }
}

export component Preview inherits Rectangle {
    width: 900px;
    height: 84px;
    background: #111114;
    ControlBar {
        width: parent.width;
        height: parent.height;
        user-name: "Navigator";
        user-initials: "N";
        user-tag: "#001";
        in-voice: true;
        voice-channel-name: "GENERAL";
        mic-muted: false;
        presence-status: 0;
        game-active: true;
        game-name: "Counter-Strike 2";
        game-short-name: "CS2";
        game-color: #DE9B35;
        can-stream: true;
        bar-state: 1;
    }
}
