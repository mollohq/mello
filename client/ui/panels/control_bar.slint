import { Theme } from "../theme.slint";

component ActionButton inherits Rectangle {
    in property <image> icon;
    in property <bool> active: false;
    in property <bool> alert: false;
    callback clicked();

    width: 48px;
    height: 48px;
    border-radius: Theme.r-inner;
    background: alert
        ? Theme.accent-bg
        : (active
            ? Theme.text-primary
            : (btn-hover.has-hover ? Theme.graphic-light : Theme.bg-app));
    border-width: Theme.dark ? 0px : 1px;
    border-color: alert
        ? Theme.accent-bg
        : (active ? Theme.text-primary : Theme.graphic-light);

    Image {
        source: icon;
        width: 20px;
        height: 20px;
        colorize: alert
            ? Theme.accent
            : (active
                ? Theme.surface
                : Theme.text-primary);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    btn-hover := TouchArea {
        clicked => { root.clicked(); }
    }
}

component MenuItem inherits Rectangle {
    in property <string> label;
    in property <color> dot-color: transparent;
    in property <bool> has-dot: false;
    in property <bool> checked: false;
    in property <bool> destructive: false;
    callback clicked();

    height: 36px;
    border-radius: Theme.r-inner;
    background: item-hover.has-hover ? Theme.hover-overlay : transparent;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: center;

        if has-dot: Rectangle {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: dot-color;
        }

        Text {
            text: label;
            font-size: Theme.font-md;
            font-weight: checked ? 600 : 400;
            color: destructive ? Theme.accent : Theme.text-primary;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }

        if checked: Text {
            text: "✓";
            font-size: Theme.font-md;
            color: Theme.accent-green;
            vertical-alignment: center;
        }
    }

    item-hover := TouchArea {
        clicked => { root.clicked(); }
    }
}

component MenuSeparator inherits Rectangle {
    height: 1px;
    background: Theme.graphic-light;
}

export component ControlBar inherits Rectangle {
    in property <string> user-name: "";
    in property <string> user-tag: "";
    in-out property <bool> mic-muted: false;
    in-out property <bool> deafened: false;
    // 0=online, 1=idle, 2=dnd, 3=invisible
    in-out property <int> presence-status: 0;

    callback mic-toggled();
    callback deafen-toggled();
    callback logout-clicked();
    callback presence-changed(int);
    callback theme-toggled();

    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.graphic-light;
    border-radius: Theme.r-outer;

    HorizontalLayout {
        padding: Theme.pad;
        spacing: Theme.spacing-lg;

        // --- Left: user identity (clickable for menu) ---
        Rectangle {
            width: avatar-row.preferred-width;
            height: parent.height;

            avatar-row := HorizontalLayout {
                spacing: 16px;
                alignment: center;

                Rectangle {
                    width: 44px;
                    height: 44px;
                    border-radius: 8px;
                    background: avatar-touch.has-hover ? Theme.graphic-light : Theme.bg-app;

                    Text {
                        text: {
                            if (user-name == "") {
                                "?"
                            } else {
                                user-name
                            }
                        }
                        font-weight: 600;
                        font-size: 14px;
                        color: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                        max-width: 40px;
                    }

                    // Presence dot on avatar
                    Rectangle {
                        x: parent.width - 12px;
                        y: parent.height - 12px;
                        width: 12px;
                        height: 12px;
                        border-radius: 6px;
                        background: Theme.surface;

                        Rectangle {
                            x: 2px;
                            y: 2px;
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: presence-status == 0 ? Theme.accent-green
                                : (presence-status == 1 ? #FFBD2E
                                : (presence-status == 2 ? Theme.accent
                                : Theme.graphic-med));
                        }
                    }
                }

                VerticalLayout {
                    alignment: center;

                    Text {
                        text: user-name != "" ? user-name : "Not connected";
                        font-size: Theme.font-md;
                        font-weight: 600;
                        color: Theme.text-primary;
                    }
                    if user-tag != "": Text {
                        text: user-tag;
                        font-family: Theme.font-mono;
                        font-size: Theme.font-xs;
                        color: Theme.text-secondary;
                    }
                }
            }

            avatar-touch := TouchArea {
                clicked => { user-menu.show(); }
            }

            user-menu := PopupWindow {
                x: 0;
                y: -306px;
                width: 220px;

                Rectangle {
                    background: Theme.surface;
                    border-radius: Theme.r-outer;
                    border-width: 1px;
                    border-color: Theme.graphic-light;
                    drop-shadow-blur: 16px;
                    drop-shadow-color: Theme.dark ? #00000080 : #00000020;
                    drop-shadow-offset-y: 4px;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 2px;

                        // Section label
                        Text {
                            text: "PRESENCE";
                            font-size: Theme.font-xs;
                            font-weight: 600;
                            letter-spacing: 1.2px;
                            color: Theme.text-tertiary;
                            height: 28px;
                            vertical-alignment: center;
                            x: 12px;
                        }

                        MenuItem {
                            label: "Online";
                            has-dot: true;
                            dot-color: Theme.accent-green;
                            checked: presence-status == 0;
                            clicked => { presence-status = 0; presence-changed(0); }
                        }
                        MenuItem {
                            label: "Idle";
                            has-dot: true;
                            dot-color: #FFBD2E;
                            checked: presence-status == 1;
                            clicked => { presence-status = 1; presence-changed(1); }
                        }
                        MenuItem {
                            label: "Do Not Disturb";
                            has-dot: true;
                            dot-color: Theme.accent;
                            checked: presence-status == 2;
                            clicked => { presence-status = 2; presence-changed(2); }
                        }
                        MenuItem {
                            label: "Invisible";
                            has-dot: true;
                            dot-color: Theme.graphic-med;
                            checked: presence-status == 3;
                            clicked => { presence-status = 3; presence-changed(3); }
                        }

                        MenuSeparator { }

                        MenuItem {
                            label: Theme.dark ? "Light Mode" : "Dark Mode";
                            clicked => { theme-toggled(); }
                        }

                        MenuSeparator { }

                        MenuItem {
                            label: "Log Out";
                            destructive: true;
                            clicked => { logout-clicked(); }
                        }
                    }
                }
            }
        }

        Rectangle { horizontal-stretch: 1; }

        // --- Right: action buttons ---
        HorizontalLayout {
            spacing: 16px;
            alignment: center;

            ActionButton {
                icon: @image-url("../icons/mic.svg");
                active: !mic-muted;
                clicked => {
                    mic-muted = !mic-muted;
                    mic-toggled();
                }
            }

            ActionButton {
                icon: @image-url("../icons/headphones.svg");
                active: false;
                clicked => {
                    deafened = !deafened;
                    deafen-toggled();
                }
            }

            ActionButton {
                icon: @image-url("../icons/settings.svg");
                clicked => { }
            }
        }
    }
}
