import { Theme } from "../theme.slint";
import { GameBadge } from "../components/game_badge.slint";

component ActionButton inherits Rectangle {
    in property <image> icon;
    in property <bool> active: false;
    in property <bool> alert: false;
    callback clicked();
    width: 36px;
    height: 36px;
    border-radius: Theme.r-inner;
    background: alert ? Theme.accent-bg : (active ? Theme.text-primary : (btn-hover.has-hover ? Theme.graphic-light : Theme.bg-app));
    border-width: Theme.dark ? 0px : 1px;
    border-color: alert ? Theme.accent-bg : (active ? Theme.text-primary : Theme.graphic-light);
    Image {
        source: icon;
        width: 18px;
        height: 18px;
        colorize: alert ? Theme.accent : (active ? Theme.surface : Theme.text-primary);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    btn-hover := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component ReactionButton inherits Rectangle {
    in property <image> icon;
    in property <color> icon-color;
    in property <color> bg;
    in property <color> border-clr;
    callback clicked();
    width: 42px;
    height: 42px;
    border-radius: Theme.r-inner;
    background: react-hover.has-hover ? border-clr : bg;
    border-width: 1px;
    border-color: border-clr;
    Image {
        source: icon;
        width: 22px;
        height: 22px;
        colorize: icon-color;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    react-hover := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component MenuItem inherits Rectangle {
    in property <string> label;
    in property <color> dot-color: transparent;
    in property <bool> has-dot: false;
    in property <bool> checked: false;
    in property <bool> destructive: false;
    callback clicked();
    height: 36px;
    border-radius: Theme.r-inner;
    background: item-hover.has-hover ? Theme.hover-overlay : transparent;
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: start;
        if has-dot: Rectangle {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: dot-color;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: label;
            font-size: Theme.font-md;
            font-weight: checked ? 600 : 400;
            color: destructive ? Theme.accent : Theme.text-primary;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }

        if checked: Text {
            text: "✓";
            font-size: Theme.font-md;
            color: Theme.accent-green;
            vertical-alignment: center;
        }
    }

    item-hover := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

component MenuSeparator inherits Rectangle {
    height: 1px;
    background: Theme.graphic-light;
}

export component ControlBar inherits Rectangle {
    in property <string> user-name: "";
    in property <string> user-initials: "";
    in property <image> user-avatar;
    in property <bool> has-user-avatar: false;
    in property <string> user-tag: "";
    in-out property <bool> mic-muted: false;
    in-out property <bool> deafened: false;
    in-out property <bool> in-voice: false;
    in property <bool> mic-permission-granted: true;
    in property <bool> mic-permission-denied: false;
    // 0=online, 1=idle, 2=dnd, 3=invisible
    in-out property <int> presence-status: 0;

    // Game sensing
    in property <bool> game-active: false;
    in property <string> game-name: "";
    in property <string> game-short-name: "";
    in property <color> game-color: #2a2a30;
    in property <bool> can-stream: false;
    // 0=idle, 1=now-playing, 2=post-game, 3=moment-input, 4=confirmed
    in-out property <int> bar-state: 0;
    callback mic-toggled();
    callback deafen-toggled();
    callback voice-toggled();
    callback logout-clicked();
    callback presence-changed(int);
    callback theme-toggled();
    callback settings-clicked();
    callback debug-toggled();
    callback request-mic-permission();
    callback open-mic-settings();

    // Game callbacks
    callback stream-requested();
    callback reaction-tapped(string);
    callback moment-submitted(string);
    callback moment-dismissed();

    // Clip
    callback clip-captured();
    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.graphic-light;
    border-radius: Theme.r-outer;
    HorizontalLayout {
        padding: Theme.pad;
        padding-left: 14px;
        padding-right: 14px;
        spacing: 12px;

        // --- Left: avatar (fixed 44x44) ---
        Rectangle {
            width: 44px;
            height: 44px;
            border-radius: 8px;
            background: avatar-touch.has-hover ? Theme.graphic-light : Theme.bg-app;
            clip: true;
            if has-user-avatar: Image {
                source: user-avatar;
                width: parent.width;
                height: parent.height;
                image-fit: contain;
            }
            if !has-user-avatar: Text {
                text: user-initials != "" ? user-initials : "?";
                font-weight: 600;
                font-size: 14px;
                color: Theme.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            Rectangle {
                x: parent.width - 12px;
                y: parent.height - 12px;
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: Theme.surface;
                Rectangle {
                    x: 2px;
                    y: 2px;
                    width: 8px;
                    height: 8px;
                    border-radius: 4px;
                    background: presence-status == 0 ? Theme.accent-green : (presence-status == 1 ? #FFBD2E : (presence-status == 2 ? Theme.accent : Theme.graphic-med));
                }
            }

            avatar-touch := TouchArea {
                clicked => {
                    user-menu.show();
                }
            }

            user-menu := PopupWindow {
                x: 0;
                y: -344px;
                width: 220px;
                Rectangle {
                    background: Theme.surface;
                    border-radius: Theme.r-outer;
                    border-width: 1px;
                    border-color: Theme.graphic-light;
                    drop-shadow-blur: 16px;
                    drop-shadow-color: Theme.dark ? #00000080 : #00000020;
                    drop-shadow-offset-y: 4px;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 2px;
                        Text {
                            text: "PRESENCE";
                            font-size: Theme.font-xs;
                            font-weight: 600;
                            letter-spacing: 1.2px;
                            color: Theme.text-tertiary;
                            height: 28px;
                            vertical-alignment: center;
                            x: 12px;
                        }

                        MenuItem {
                            label: "Online";
                            has-dot: true;
                            dot-color: Theme.accent-green;
                            checked: presence-status == 0;
                            clicked => {
                                presence-status = 0;
                                presence-changed(0);
                            }
                        }

                        MenuItem {
                            label: "Idle";
                            has-dot: true;
                            dot-color: #FFBD2E;
                            checked: presence-status == 1;
                            clicked => {
                                presence-status = 1;
                                presence-changed(1);
                            }
                        }

                        MenuItem {
                            label: "Do Not Disturb";
                            has-dot: true;
                            dot-color: Theme.accent;
                            checked: presence-status == 2;
                            clicked => {
                                presence-status = 2;
                                presence-changed(2);
                            }
                        }

                        MenuItem {
                            label: "Invisible";
                            has-dot: true;
                            dot-color: Theme.graphic-med;
                            checked: presence-status == 3;
                            clicked => {
                                presence-status = 3;
                                presence-changed(3);
                            }
                        }

                        MenuSeparator { }

                        MenuItem {
                            label: Theme.dark ? "Light Mode" : "Dark Mode";
                            clicked => {
                                theme-toggled();
                            }
                        }

                        MenuItem {
                            label: "Debug Audio";
                            clicked => {
                                debug-toggled();
                            }
                        }

                        MenuSeparator { }

                        MenuItem {
                            label: "Log Out";
                            destructive: true;
                            clicked => {
                                logout-clicked();
                            }
                        }
                    }
                }
            }
        }

        // --- Left: user name/tag ---
        VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            Text {
                text: user-name != "" ? user-name : "Not connected";
                font-size: Theme.font-md;
                font-weight: 600;
                color: Theme.text-primary;
                overflow: elide;
            }

            if user-tag != "": Text {
                text: user-tag;
                font-family: Theme.font-mono;
                font-size: Theme.font-xs;
                color: Theme.text-secondary;
                overflow: elide;
            }
        }

        // --- Left spacer: pushes center content to middle ---
        Rectangle {
            horizontal-stretch: 1;
        }

        // State 1: Now Playing
        if bar-state == 1: VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            Rectangle {
                background: Theme.bg-app;
                border-radius: Theme.r-inner;
                height: 44px;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 16px;
                    spacing: Theme.pad;
                    GameBadge {
                        short-name: game-short-name;
                        bg-color: game-color;
                        size: 32px;
                        y: (parent.height - self.height) / 2;
                    }

                    VerticalLayout {
                        spacing: 2px;
                        alignment: center;
                        Text {
                            text: "NOW PLAYING";
                            font-size: 10px;
                            color: Theme.text-tertiary;
                            letter-spacing: 1px;
                        }

                        Text {
                            text: game-name;
                            font-size: 13px;
                            color: Theme.text-secondary;
                            font-weight: 500;
                        }
                    }

                    if can-stream: Rectangle {
                        width: stream-label.preferred-width + 20px;
                        height: 24px;
                        border-radius: 6px;
                        background: Theme.accent;
                        y: (parent.height - self.height) / 2;
                        stream-label := Text {
                            text: "STREAM";
                            font-size: 10px;
                            font-weight: 700;
                            color: white;
                            letter-spacing: 0.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                stream-requested();
                            }
                        }
                    }
                }
            }
        }

        // State 2: Post-game prompt
        if bar-state == 2: VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            HorizontalLayout {
                spacing: 16px;
                GameBadge {
                    short-name: game-short-name;
                    bg-color: game-color;
                    size: 32px;
                }

                Text {
                    text: "How'd it go?";
                    font-size: 13px;
                    color: Theme.text-secondary;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    spacing: 10px;
                    ReactionButton {
                        icon: @image-url("../icons/trophy.svg");
                        icon-color: #4ade80;
                        bg: #1e2a1e;
                        border-clr: #2d4a2d;
                        clicked => {
                            reaction-tapped("win");
                        }
                    }

                    ReactionButton {
                        icon: @image-url("../icons/sad-face.svg");
                        icon-color: #f87171;
                        bg: #2a1e1e;
                        border-clr: #4a2d2d;
                        clicked => {
                            reaction-tapped("loss");
                        }
                    }

                    ReactionButton {
                        icon: @image-url("../icons/star.svg");
                        icon-color: #fbbf24;
                        bg: #2a2418;
                        border-clr: #4a3d1d;
                        clicked => {
                            reaction-tapped("highlight");
                        }
                    }
                }
            }
        }

        // State 3: Moment text input
        if bar-state == 3: VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            HorizontalLayout {
                spacing: 10px;
                Rectangle {
                    horizontal-stretch: 1;
                    height: 36px;
                    border-radius: Theme.r-inner;
                    background: Theme.bg-app;
                    border-width: 1px;
                    border-color: Theme.graphic-light;
                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 8px;
                        alignment: start;
                        Image {
                            source: @image-url("../icons/star.svg");
                            width: 16px;
                            height: 16px;
                            colorize: #fbbf24;
                            y: (parent.height - self.height) / 2;
                        }

                        moment-input := TextInput {
                            font-size: 13px;
                            color: Theme.text-primary;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            accepted => {
                                if self.text != "" {
                                    moment-submitted(self.text);
                                    self.text = "";
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: Theme.r-inner;
                    background: Theme.accent;
                    Image {
                        source: @image-url("../icons/arrow-right.svg");
                        width: 16px;
                        height: 16px;
                        colorize: white;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }

                    TouchArea {
                        clicked => {
                            if moment-input.text != "" {
                                moment-submitted(moment-input.text);
                                moment-input.text = "";
                            }
                        }
                    }
                }
            }
        }

        // State 4: Confirmed
        if bar-state == 4: VerticalLayout {
            horizontal-stretch: 0;
            alignment: center;
            HorizontalLayout {
                spacing: 8px;
                Image {
                    source: @image-url("../icons/checkmark.svg");
                    width: 18px;
                    height: 18px;
                    colorize: #4ade80;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: "Moment shared with crew";
                    font-size: 13px;
                    color: #4ade80;
                    font-weight: 500;
                    vertical-alignment: center;
                }
            }
        }

        // --- Right spacer: pushes buttons to the right ---
        Rectangle {
            horizontal-stretch: 1;
        }

        // --- Right: action buttons ---
        if mic-permission-granted: HorizontalLayout {
            horizontal-stretch: 0;
            spacing: 6px;
            alignment: center;
            // Clip button (only when in voice)
            if in-voice: Rectangle {
                width: 40px;
                height: 40px;
                border-radius: 8px;
                background: clip-hover.has-hover ? #EB4D5F33 : #EB4D5F22;
                border-width: 1px;
                border-color: #EB4D5F44;

                Image {
                    source: @image-url("../icons/scissors.svg");
                    colorize: Theme.accent;
                    width: 18px;
                    height: 18px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }

                clip-hover := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        clip-captured();
                    }
                }
            }

            ActionButton {
                icon: @image-url("../icons/phone.svg");
                alert: in-voice;
                clicked => {
                    if in-voice {
                        voice-toggled();
                    }
                }
            }

            ActionButton {
                icon: @image-url("../icons/mic.svg");
                active: in-voice && !mic-muted;
                clicked => {
                    mic-toggled();
                }
            }

            ActionButton {
                icon: @image-url("../icons/headphones.svg");
                active: in-voice && !deafened;
                clicked => {
                    deafen-toggled();
                }
            }

            ActionButton {
                icon: @image-url("../icons/settings.svg");
                clicked => {
                    settings-clicked();
                }
            }
        }

        // --- Right: mic permission CTA (when no mic access) ---
        if !mic-permission-granted: HorizontalLayout {
            horizontal-stretch: 0;
            spacing: 12px;
            alignment: center;
            Text {
                text: mic-permission-denied ? "Microphone access denied — enable it in System Settings" : "Microphone access is needed for voice chat";
                font-family: Theme.font-mono;
                font-size: 11px;
                color: Theme.text-secondary;
                vertical-alignment: center;
            }

            Rectangle {
                width: mic-cta-row.preferred-width + 28px;
                height: 36px;
                border-radius: Theme.r-inner;
                background: Theme.accent;
                mic-cta-row := HorizontalLayout {
                    alignment: center;
                    spacing: 8px;
                    Text {
                        text: mic-permission-denied ? "Open Settings" : "Allow Microphone";
                        font-family: Theme.font-mono;
                        font-size: 12px;
                        font-weight: 600;
                        color: #FFFFFF;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "→";
                        font-size: 14px;
                        color: #FFFFFF;
                        vertical-alignment: center;
                    }
                }

                mic-btn-touch := TouchArea {
                    clicked => {
                        if (root.mic-permission-denied) {
                            root.open-mic-settings();
                        } else {
                            root.request-mic-permission();
                        }
                    }
                }
            }
        }
    }
}

export component Preview inherits Rectangle {
    width: 700px;
    height: 92px;
    background: #111114;
    ControlBar {
        width: parent.width;
        height: parent.height;
        user-name: "alice";
        user-initials: "AL";
        user-tag: "#7478";
        in-voice: true;
        mic-muted: false;
        presence-status: 0;
        game-active: true;
        game-name: "Counter-Strike 2";
        game-short-name: "CS2";
        game-color: #DE9B35;
        can-stream: true;
        bar-state: 1;
    }
}
