    invite-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { invite-clicked(); }
    }
}

// Dispatcher: renders the correct card based on card-type
component FeedSlot inherits Rectangle {
    in property <FeedCardData> card;
    in property <string> playing-path: "";
    in property <float> clip-progress: 0.0;
    in property <bool> clip-paused: false;
    in property <float> clip-anim-tick: 0.0;
    in property <string> clip-position-text: "";
    in property <string> clip-duration-text: "";
    callback play-clicked(string);
    callback seek-clip(float);

    // Real cards
    if card.card-type == "clip" && card.is-hero: HeroClipCard {
        width: parent.width; height: parent.height; card: root.card;
        is-playing: root.card.clip-path != "" && root.card.clip-path == root.playing-path;
        is-paused: root.clip-paused;
        progress: root.clip-progress;
        anim-tick: root.clip-anim-tick;
        position-text: root.clip-position-text;
        duration-text: root.clip-duration-text;
        play-clicked(id) => { root.play-clicked(id); }
        seek(v) => { root.seek-clip(v); }
    }
    if card.card-type == "clip" && !card.is-hero: ClipCard {
        width: parent.width; height: parent.height; card: root.card;
        is-playing: root.card.clip-path != "" && root.card.clip-path == root.playing-path;
        is-paused: root.clip-paused;
        progress: root.clip-progress;
        anim-tick: root.clip-anim-tick;
        position-text: root.clip-position-text;
        duration-text: root.clip-duration-text;
        play-clicked(id) => { root.play-clicked(id); }
    }
    if card.card-type == "recap": RecapCard {
        width: parent.width; height: parent.height; card: root.card;
    }
    if card.card-type == "session": SessionCard {
        width: parent.width; height: parent.height; card: root.card;
    }
    if card.card-type == "catchup": CatchupCard {
        width: parent.width; height: parent.height; card: root.card;
    }

    // Skeleton variants
    if card.card-type == "skeleton": SkeletonCard {
        width: parent.width; height: parent.height; card: root.card;
    }
    if card.card-type == "skeleton-hero": SkeletonHeroCard {
        width: parent.width; height: parent.height;
    }
    if card.card-type == "skeleton-recap": SkeletonRecapCard {
        width: parent.width; height: parent.height;
    }
    if card.card-type == "skeleton-clip": SkeletonClipCard {
        width: parent.width; height: parent.height;
    }
    if card.card-type == "skeleton-session": SkeletonSessionCard {
        width: parent.width; height: parent.height;
    }
    if card.card-type == "skeleton-catchup": SkeletonCatchupCard {
        width: parent.width; height: parent.height;
    }
    if card.card-type == "skeleton-now-playing": SkeletonNowPlayingCard {
        width: parent.width; height: parent.height;
    }
    if card.card-type == "skeleton-stream-clips": SkeletonStreamClipsCard {
        width: parent.width; height: parent.height;
    }
    if card.card-type == "skeleton-recent-games": SkeletonRecentGamesCard {
        width: parent.width; height: parent.height;
    }
}

export component CrewFeed inherits Rectangle {
    in property <[FeedCardData]> cards: [];
    in property <[StreamCardData]> stream-cards: [];
    in property <bool> is-cold-start: true;
    in property <string> crew-name: "";
    in property <int> clip-count: 0;
    in property <bool> is-hosting: false;
    in property <bool> is-watching: false;
    in property <string> active-streamer-id: "";
    in property <image> stream-frame;

    in property <string> clip-playing-path: "";
    in property <float> clip-progress: 0.0;
    in property <bool> clip-paused: false;
    in property <float> clip-anim-tick: 0.0;
    in property <string> clip-position-text: "";
    in property <string> clip-duration-text: "";

    callback go-live-clicked();
    callback card-clicked(string);
    callback invite-clicked();
    callback pause-clip();
    callback resume-clip();
    callback seek-clip(float);
    callback watch-stream-clicked(string, string, int, int);
    callback stop-stream-clicked();
    callback stop-watching-clicked();

    property <int> feed-start-index: stream-cards.length == 1 && cards.length > 0 ? 1 : 0;

    background: transparent;

    VerticalLayout {
        spacing: 0px;

        // Header
        Rectangle {
            height: 48px;
            background: transparent;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                spacing: 10px;

                HorizontalLayout {
                    spacing: 10px;
                    horizontal-stretch: 1;
                    alignment: start;

                    Text {
                        text: "Crew feed";
                        font-size: 15px;
                        font-weight: 500;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }

                    if clip-count > 0: Rectangle {
                        width: badge-text.preferred-width + 20px;
                        height: 22px;
                        border-radius: 11px;
                        background: Theme.card-border;
                        y: (parent.height - self.height) / 2;

                        badge-text := Text {
                            text: clip-count + " clips this week";
                            font-size: 11px;
                            color: Theme.text-sub;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    width: go-live-text.preferred-width + 36px;
                    height: 32px;
                    border-radius: 8px;
                    background: live-hover.has-hover ? Theme.dark ? #EB4D5F28 : #FF1E5618 : Theme.accent-bg;
                    border-width: 1px;
                    border-color: Theme.dark ? #EB4D5F33 : #FF1E5622;
                    y: (parent.height - self.height) / 2;

                    HorizontalLayout {
                        alignment: center;
                        spacing: 6px;

                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.accent;
                            y: (parent.height - self.height) / 2;
                        }

                        go-live-text := Text {
                            text: "GO LIVE";
                            font-size: 12px;
                            font-weight: 600;
                            color: Theme.accent;
                            vertical-alignment: center;
                        }
                    }

                    live-hover := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { go-live-clicked(); }
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.card-border;
        }

        // Scrollable feed area
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                padding: 16px;
                padding-left: 20px;
                padding-right: 20px;
                spacing: 12px;

                // Stream cards live in the feed flow, directly under the header.
                if stream-cards.length == 1 && cards.length > 0: HorizontalLayout {
                    height: 420px;
                    spacing: 12px;

                    Rectangle {
                        horizontal-stretch: 2;
                        height: parent.height;

                        ActiveStreamsPanel {
                            width: parent.width;
                            height: parent.height;
                            cards: root.stream-cards;
                            is-hosting: root.is-hosting;
                            is-watching: root.is-watching;
                            active-streamer-id: root.active-streamer-id;
                            stream-frame: root.stream-frame;
                            watch-stream-clicked(host-id, session-id, w, h) => {
                                root.watch-stream-clicked(host-id, session-id, w, h);
                            }
                            stop-stream-clicked => {
                                root.stop-stream-clicked();
                            }
                            stop-watching-clicked => {
                                root.stop-watching-clicked();
                            }
                        }
                    }

                    FeedSlot {
                        horizontal-stretch: 1;
                        card: cards[0];
                        playing-path: root.clip-playing-path;
                        clip-progress: root.clip-progress;
                        clip-paused: root.clip-paused;
                        clip-anim-tick: root.clip-anim-tick;
                        clip-position-text: root.clip-position-text;
                        clip-duration-text: root.clip-duration-text;
                        play-clicked(id) => { root.card-clicked(id); }
                        seek-clip(v) => { root.seek-clip(v); }
                    }
                }

                if stream-cards.length == 1 && cards.length == 0: ActiveStreamsPanel {
                    horizontal-stretch: 1;
                    height: 420px;
                    cards: root.stream-cards;
                    is-hosting: root.is-hosting;
                    is-watching: root.is-watching;
                    active-streamer-id: root.active-streamer-id;
                    stream-frame: root.stream-frame;
                    watch-stream-clicked(host-id, session-id, w, h) => {
                        root.watch-stream-clicked(host-id, session-id, w, h);
                    }
                    stop-stream-clicked => {
                        root.stop-stream-clicked();
                    }
                    stop-watching-clicked => {
                        root.stop-watching-clicked();
                    }
                }

                if stream-cards.length > 1: streams-grid := ActiveStreamsPanel {
                    horizontal-stretch: 1;
                    height: min(640px, self.panel-height);
                    cards: root.stream-cards;
                    is-hosting: root.is-hosting;
                    is-watching: root.is-watching;
                    active-streamer-id: root.active-streamer-id;
                    stream-frame: root.stream-frame;
                    watch-stream-clicked(host-id, session-id, w, h) => {
                        root.watch-stream-clicked(host-id, session-id, w, h);
                    }
                    stop-stream-clicked => {
                        root.stop-stream-clicked();
                    }
                    stop-watching-clicked => {
                        root.stop-watching-clicked();
                    }
                }

                // Row 1: Hero (2x) + top-right card (1x)
                if cards.length > root.feed-start-index: HorizontalLayout {
                    height: 420px;
                    spacing: 12px;

                    FeedSlot {
                        horizontal-stretch: 2;
                        card: cards[root.feed-start-index];
                        playing-path: root.clip-playing-path;
                        clip-progress: root.clip-progress;
                        clip-paused: root.clip-paused;
                        clip-anim-tick: root.clip-anim-tick;
                        clip-position-text: root.clip-position-text;
                        clip-duration-text: root.clip-duration-text;
                        play-clicked(id) => { root.card-clicked(id); }
                        seek-clip(v) => { root.seek-clip(v); }
                    }

                    if cards.length > root.feed-start-index + 1: FeedSlot {
                        horizontal-stretch: 1;
                        card: cards[root.feed-start-index + 1];
                        playing-path: root.clip-playing-path;
                        clip-progress: root.clip-progress;
                        clip-paused: root.clip-paused;
                        clip-anim-tick: root.clip-anim-tick;
                        clip-position-text: root.clip-position-text;
                        clip-duration-text: root.clip-duration-text;
                        play-clicked(id) => { root.card-clicked(id); }
                        seek-clip(v) => { root.seek-clip(v); }
                    }
                }

                // Row 2: Three 1x cards
                if cards.length > root.feed-start-index + 2: HorizontalLayout {
                    height: 210px;
                    spacing: 12px;

                    for rel-idx in [0, 1, 2]: FeedSlot {
                        property <int> card-idx: root.feed-start-index + 2 + rel-idx;
                        visible: cards.length > card-idx;
                        horizontal-stretch: 1;
                        card: cards.length > card-idx ? cards[card-idx] : { card-type: "" };
                        playing-path: root.clip-playing-path;
                        clip-progress: root.clip-progress;
                        clip-paused: root.clip-paused;
                        clip-anim-tick: root.clip-anim-tick;
                        clip-position-text: root.clip-position-text;
                        clip-duration-text: root.clip-duration-text;
                        play-clicked(id) => { root.card-clicked(id); }
                        seek-clip(v) => { root.seek-clip(v); }
                    }
                }

                // Row 3: card (1x) + wide card (2x)
                if cards.length > root.feed-start-index + 5: HorizontalLayout {
                    height: 210px;
                    spacing: 12px;

                    FeedSlot {
                        horizontal-stretch: 1;
                        card: cards[root.feed-start-index + 5];
                        playing-path: root.clip-playing-path;
                        clip-progress: root.clip-progress;
                        clip-paused: root.clip-paused;
                        clip-anim-tick: root.clip-anim-tick;
                        clip-position-text: root.clip-position-text;
                        clip-duration-text: root.clip-duration-text;
                        play-clicked(id) => { root.card-clicked(id); }
                        seek-clip(v) => { root.seek-clip(v); }
                    }

                    if cards.length > root.feed-start-index + 6: FeedSlot {
                        horizontal-stretch: 2;
                        card: cards[root.feed-start-index + 6];
                        playing-path: root.clip-playing-path;
                        clip-progress: root.clip-progress;
                        clip-paused: root.clip-paused;
                        clip-anim-tick: root.clip-anim-tick;
                        clip-position-text: root.clip-position-text;
                        clip-duration-text: root.clip-duration-text;
                        play-clicked(id) => { root.card-clicked(id); }
                        seek-clip(v) => { root.seek-clip(v); }
                    }
                }

                // Row 4+ for extra cards (cold start has 9 slots)
                if cards.length > root.feed-start-index + 7: HorizontalLayout {
                    height: 210px;
                    spacing: 12px;

                    for rel-idx in [0, 1]: FeedSlot {
                        property <int> card-idx: root.feed-start-index + 7 + rel-idx;
                        visible: cards.length > card-idx;
                        horizontal-stretch: 1;
                        card: cards.length > card-idx ? cards[card-idx] : { card-type: "" };
                        playing-path: root.clip-playing-path;
                        clip-progress: root.clip-progress;
                        clip-paused: root.clip-paused;
                        clip-anim-tick: root.clip-anim-tick;
                        clip-position-text: root.clip-position-text;
                        clip-duration-text: root.clip-duration-text;
                        play-clicked(id) => { root.card-clicked(id); }
                        seek-clip(v) => { root.seek-clip(v); }
                    }
                }

                if is-cold-start: InviteCard {
                    invite-clicked => { root.invite-clicked(); }
                }

                Rectangle { height: 20px; }
            }
        }
    }
}

