// Full cold start: brand new crew, no events at all
export component PreviewColdStart inherits Rectangle {
    width: 760px;
    height: 920px;
    background: Theme.bg-app;

    CrewFeed {
        width: parent.width;
        height: parent.height;
        clip-count: 0;
        is-cold-start: true;
        cards: [
            { id: "s1", card-type: "skeleton-hero", is-skeleton: true },
            { id: "s2", card-type: "skeleton-recap", is-skeleton: true },
            { id: "s3", card-type: "skeleton-now-playing", is-skeleton: true },
            { id: "s4", card-type: "skeleton-clip", is-skeleton: true },
            { id: "s5", card-type: "skeleton-session", is-skeleton: true },
            { id: "s6", card-type: "skeleton-catchup", is-skeleton: true },
            { id: "s7", card-type: "skeleton-recent-games", is-skeleton: true },
            { id: "s8", card-type: "skeleton-stream-clips", is-skeleton: true },
        ];
    }
}

