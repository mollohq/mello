// Normal feed with real data
export component Preview inherits Rectangle {
    width: 760px;
    height: 920px;
    background: Theme.bg-app;
    // Preview controls:
    // - stream-count: 0..3 (clamped)
    // - preview-watching: show selected watching state on the first stream card
    in-out property <int> stream-count: 1;
    in-out property <bool> preview-watching: false;
    in-out property <bool> preview-hosting: false;
    property <int> preview-stream-count: max(0, min(stream-count, 3));
    property <string> preview-active-streamer-id: !preview-hosting && preview-watching && preview-stream-count > 0 ? "alice-id" : "";
