import { Theme } from "../theme.slint";
import { FeedCardData, StreamCardData } from "../types.slint";
import { ActiveStreamsPanel } from "./active_streams_panel.slint";

component AvatarDot inherits Rectangle {
    in property <string> initials;
    in property <int> color-index: 0;

    width: 18px;
    height: 18px;
    border-radius: 4px;
    border-width: 2px;
    border-color: Theme.card-bg;
    background: color-index == 0 ? #EB4D5F :
                color-index == 1 ? #4a9eff :
                color-index == 2 ? #4ade80 :
                color-index == 3 ? #a78bfa : #f59e0b;

    Text {
        text: initials;
        font-size: 7px;
        font-weight: 600;
        color: white;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component ClipBadge inherits Rectangle {
    in property <bool> small: false;

    width: small ? 42px : 52px;
    height: small ? 20px : 22px;
    border-radius: small ? 4px : 5px;
    background: Theme.clip-amber;

    HorizontalLayout {
        alignment: center;
        spacing: 3px;

        Image {
            source: @image-url("../icons/scissors.svg");
            colorize: white;
            width: small ? 9px : 10px;
            height: small ? 9px : 10px;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: "CLIP";
            font-size: small ? 9px : 10px;
            font-weight: 700;
            color: white;
            letter-spacing: 0.5px;
            vertical-alignment: center;
        }
    }
}

component PlayButton inherits Rectangle {
    in property <bool> small: false;
    in property <bool> is-playing: false;
    in property <bool> is-paused: false;

    width: small ? 32px : 52px;
    height: small ? 32px : 52px;
    border-radius: small ? 16px : 26px;
    background: is-playing && !is-paused ? Theme.clip-amber : #00000055;

    if !is-playing || is-paused: Text {
        text: "▶";
        font-size: small ? 12px : 18px;
        color: is-playing ? Theme.clip-amber : white;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if is-playing && !is-paused: Image {
        source: @image-url("../icons/pause.svg");
        colorize: Theme.dark ? #000000 : #000000;
        width: small ? 12px : 18px;
        height: small ? 12px : 18px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

component NewBadge inherits Rectangle {
    width: new-text.preferred-width + 16px;
    height: 22px;
    border-radius: 5px;
    background: Theme.clip-amber;

    new-text := Text {
        text: "NEW";
        font-size: 10px;
        font-weight: 700;
        color: white;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component PlayingBadge inherits Rectangle {
    in property <bool> paused: false;

    width: paused ? 72px : 80px;
    height: 22px;
    border-radius: 5px;
    background: Theme.dark ? #F59E0B1A : #F59E0B22;
    border-width: 1px;
    border-color: Theme.dark ? #F59E0B4D : #F59E0B33;

    HorizontalLayout {
        alignment: center;
        spacing: 4px;

        if !paused: Image {
            source: @image-url("../icons/speaker.svg");
            colorize: Theme.clip-amber;
            width: 10px;
            height: 10px;
            y: (parent.height - self.height) / 2;
        }

        if paused: Image {
            source: @image-url("../icons/pause.svg");
            colorize: Theme.clip-amber;
            width: 10px;
            height: 10px;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: paused ? "PAUSED" : "PLAYING";
            font-size: 10px;
            font-weight: 700;
            color: Theme.clip-amber;
            vertical-alignment: center;
        }
    }
}

// Hero clip card (2x wide)
component HeroClipCard inherits Rectangle {
    in property <FeedCardData> card;
    in property <bool> is-playing: false;
    in property <bool> is-paused: false;
    in property <float> progress: 0.0;
    in property <float> anim-tick: 0.0;
    in property <string> position-text: "";
    in property <string> duration-text: "";
    callback play-clicked(string);
    callback seek(float);

    background: card-hover.has-hover ? Theme.card-bg-hover : Theme.card-bg;
    border-radius: 10px;
    border-width: 1px;
    border-color: card.is-new ? Theme.clip-amber :
                  is-playing ? Theme.clip-amber :
                  card-hover.has-hover ? Theme.graphic-med : Theme.card-border;
    opacity: card.is-new || is-playing ? 1.0 : (card-hover.has-hover ? 1.0 : 1.0);
    clip: true;

    VerticalLayout {
        // Thumbnail area
        Rectangle {
            vertical-stretch: 3;
            min-height: 180px;
            background: is-playing
                ? (Theme.dark
                    ? @linear-gradient(135deg, #1a1400 0%, #1a1000 40%, #151515 100%)
                    : @linear-gradient(135deg, #fef6e4 0%, #fef0d4 40%, #f0f0f0 100%))
                : (Theme.dark
                    ? @linear-gradient(135deg, #0d1a0d 0%, #0a1520 40%, #151525 100%)
                    : @linear-gradient(135deg, #e8ece8 0%, #dde8f0 40%, #e0e0ea 100%));

            // Game watermark
            Text {
                text: card.game-name != "" ? card.game-name : "";
                font-size: 48px;
                font-weight: 800;
                color: #ffffff06;
                letter-spacing: 6px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            // Animated waveform bars (playing) or static (default)
            HorizontalLayout {
                alignment: center;
                spacing: 3px;
                padding-left: 20px;
                padding-right: 20px;
                y: parent.height - 76px - 4px;
                height: 72px;
                width: parent.width;

                for entry in [
                    {h: 0.20, i: 0.0}, {h: 0.35, i: 1.0}, {h: 0.60, i: 2.0}, {h: 0.85, i: 3.0},
                    {h: 1.00, i: 4.0}, {h: 0.75, i: 5.0}, {h: 0.45, i: 6.0}, {h: 0.25, i: 7.0},
                    {h: 0.50, i: 8.0}, {h: 0.80, i: 9.0}, {h: 0.95, i: 10.0}, {h: 0.65, i: 11.0},
                    {h: 0.30, i: 12.0}, {h: 0.70, i: 13.0}, {h: 0.55, i: 14.0}, {h: 0.90, i: 15.0},
                    {h: 0.40, i: 16.0}, {h: 0.60, i: 17.0}, {h: 0.35, i: 18.0}, {h: 0.50, i: 19.0}
                ]: Rectangle {
                    width: 3px;

                    Rectangle {
                        property <float> wave-h: is-playing && !is-paused
                            ? 0.5 + 0.5 * sin((anim-tick + entry.i * 0.5) * 360deg)
                            : entry.h;
                        property <float> bar-progress: entry.i / 20.0;

                        width: parent.width;
                        height: 50px * wave-h;
                        y: (parent.height - self.height) / 2;
                        border-radius: 2px;
                        background: is-playing
                            ? (is-paused
                                ? (bar-progress <= progress ? Theme.clip-amber : Theme.text-dim)
                                : Theme.clip-amber)
                            : Theme.clip-amber;
                        opacity: is-playing && !is-paused
                            ? 0.6 + 0.4 * wave-h
                            : (is-paused ? (bar-progress <= progress ? 0.8 : 0.3) : 0.5 + entry.h * 0.5);
                    }
                }
            }

            if card.is-new: NewBadge {
                x: 12px;
                y: 12px;
            }

            if !card.is-new && !is-playing: ClipBadge {
                x: 12px;
                y: 12px;
            }

            if is-playing: PlayingBadge {
                paused: is-paused;
                x: 12px;
                y: 12px;
            }

            PlayButton {
                is-playing: root.is-playing;
                is-paused: root.is-paused;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }

            Rectangle {
                x: parent.width - self.width - 10px;
                y: parent.height - self.height - 10px;
                width: dur-text.preferred-width + 16px;
                height: 22px;
                border-radius: 4px;
                background: #000000aa;

                dur-text := Text {
                    text: is-playing ? position-text + " / " + duration-text : card.duration;
                    font-size: 11px;
                    color: is-playing ? Theme.clip-amber : white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // Scrub bar (only when playing/paused)
        if is-playing: Rectangle {
            height: 6px;
            background: Theme.card-bg-inset;

            Rectangle {
                x: 0;
                width: parent.width * progress;
                height: parent.height;
                background: Theme.clip-amber;
                border-radius: 0px;
            }

            // Scrub knob
            Rectangle {
                x: parent.width * progress - 4px;
                y: (parent.height - self.height) / 2;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: white;
                visible: scrub-area.has-hover || scrub-area.pressed;
            }

            scrub-area := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.seek(self.mouse-x / self.width);
                }
            }
        }

        // Card body
        VerticalLayout {
            padding: 12px;
            padding-left: 14px;
            padding-right: 14px;
            spacing: 6px;
            vertical-stretch: 0;

            Text {
                text: card.title != "" ? card.title : card.actor-name + " clipped that";
                font-size: 14px;
                font-weight: 500;
                color: Theme.text-primary;
            }

            HorizontalLayout {
                spacing: 8px;
                height: 20px;

                if card.participant-count > 0: HorizontalLayout {
                    spacing: -7px;
                    width: self.preferred-width;

                    AvatarDot { initials: card.actor-initials; color-index: 0; }
                    if card.participant-count > 1: AvatarDot { initials: ""; color-index: 1; }
                    if card.participant-count > 2: AvatarDot { initials: ""; color-index: 2; }
                }

                Text {
                    text: card.timestamp;
                    font-size: 11px;
                    color: Theme.text-sub;
                    vertical-alignment: center;
                }

                if card.game-name != "": Text {
                    text: "·";
                    font-size: 11px;
                    color: Theme.text-dim;
                    vertical-alignment: center;
                }

                if card.game-name != "": Text {
                    text: card.game-name;
                    font-size: 11px;
                    color: Theme.text-sub;
                    vertical-alignment: center;
                }
            }
        }
    }

    card-hover := TouchArea {
        mouse-cursor: pointer;
        clicked => { play-clicked(card.clip-path); }
    }
}

// Standard clip card (1x)
component ClipCard inherits Rectangle {
    in property <FeedCardData> card;
    in property <bool> is-playing: false;
    in property <bool> is-paused: false;
    in property <float> progress: 0.0;
    in property <float> anim-tick: 0.0;
    in property <string> position-text: "";
    in property <string> duration-text: "";
    callback play-clicked(string);

    background: clip-hover.has-hover ? Theme.card-bg-hover : Theme.card-bg;
    border-radius: 10px;
    border-width: 1px;
    border-color: card.is-new ? Theme.clip-amber :
                  is-playing ? Theme.clip-amber :
                  clip-hover.has-hover ? Theme.graphic-med : Theme.card-border;
    clip: true;

    VerticalLayout {
        // Waveform area
        Rectangle {
            vertical-stretch: 1;
            min-height: 60px;
            background: is-playing
                ? (Theme.dark ? #1a14001A : #fef6e41A)
                : Theme.card-bg-inset;
            border-radius: 4px;

            HorizontalLayout {
                alignment: center;
                spacing: 2px;
                padding-left: 12px;
                padding-right: 12px;

                for entry in [
                    {h: 0.35, i: 0.0}, {h: 0.70, i: 1.0}, {h: 1.00, i: 2.0}, {h: 0.50, i: 3.0},
                    {h: 0.90, i: 4.0}, {h: 0.40, i: 5.0}, {h: 0.80, i: 6.0}, {h: 0.25, i: 7.0},
                    {h: 0.65, i: 8.0}, {h: 1.00, i: 9.0}, {h: 0.45, i: 10.0}, {h: 0.75, i: 11.0},
                    {h: 0.30, i: 12.0}
                ]: Rectangle {
                    width: 2px;

                    Rectangle {
                        property <float> wave-h: is-playing && !is-paused
                            ? 0.5 + 0.5 * sin((anim-tick + entry.i * 0.5) * 360deg)
                            : entry.h;
                        property <float> bar-progress: entry.i / 13.0;

                        width: parent.width;
                        height: 30px * wave-h;
                        y: (parent.height - self.height) / 2;
                        border-radius: 1px;
                        background: is-playing
                            ? (is-paused
                                ? (bar-progress <= progress ? Theme.clip-amber : Theme.text-dim)
                                : Theme.clip-amber)
                            : Theme.clip-amber;
                        opacity: is-playing && !is-paused
                            ? 0.6 + 0.4 * wave-h
                            : (is-paused ? (bar-progress <= progress ? 0.8 : 0.3) : 0.5 + entry.h * 0.5);
                    }
                }
            }

            if card.is-new: NewBadge {
                x: 8px;
                y: 8px;
            }

            if !card.is-new && !is-playing: ClipBadge {
                small: true;
                x: 8px;
                y: 8px;
            }

            if is-playing: PlayingBadge {
                paused: is-paused;
                x: 8px;
                y: 8px;
            }

            PlayButton {
                small: true;
                is-playing: root.is-playing;
                is-paused: root.is-paused;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        // Card body
        VerticalLayout {
            padding: 10px;
            padding-left: 12px;
            padding-right: 12px;
            spacing: 4px;
            vertical-stretch: 0;

            HorizontalLayout {
                spacing: 4px;
                height: 14px;

                Image {
                    source: @image-url("../icons/scissors.svg");
                    colorize: Theme.clip-amber;
                    width: 10px;
                    height: 10px;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: is-playing
                        ? position-text + " / " + duration-text
                        : "VOICE CLIP · " + card.duration;
                    font-size: 10px;
                    font-weight: 700;
                    color: Theme.clip-amber;
                    vertical-alignment: center;
                }
            }

            Text {
                text: card.title != "" ? card.title : card.actor-name + " clipped that";
                font-size: 13px;
                font-weight: 500;
                color: Theme.text-primary;
                overflow: elide;
            }

            Text {
                text: card.timestamp + (card.game-name != "" ? " · " + card.game-name : "");
                font-size: 11px;
                color: Theme.text-sub;
            }
        }
    }

    clip-hover := TouchArea {
        mouse-cursor: pointer;
        clicked => { play-clicked(card.clip-path); }
    }
}

// Weekly recap card
component RecapCard inherits Rectangle {
    in property <FeedCardData> card;

    background: Theme.card-bg;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;
    clip: true;

    VerticalLayout {
        padding: 14px;
        padding-top: 16px;
        spacing: 0px;

        Text {
            text: "WEEKLY RECAP";
            font-size: 10px;
            font-weight: 700;
            color: Theme.accent;
            letter-spacing: 1.2px;
        }

        Rectangle { height: 8px; }

        Text {
            text: card.title;
            font-size: 28px;
            font-weight: 700;
            color: Theme.text-primary;
        }

        Text {
            text: "Total crew time";
            font-size: 11px;
            color: Theme.text-sub;
        }

        Rectangle { height: 10px; }

        Rectangle { height: 1px; background: Theme.card-border; }

        Rectangle { height: 8px; }

        // Stats rows
        VerticalLayout {
            spacing: 5px;

            if card.game-name != "": HorizontalLayout {
                Text { text: "Top game"; font-size: 11px; color: Theme.text-dim; horizontal-stretch: 1; }
                Text { text: card.game-name; font-size: 11px; color: Theme.text-value; }
            }

            if card.duration != "": HorizontalLayout {
                Text { text: "Longest sesh"; font-size: 11px; color: Theme.text-dim; horizontal-stretch: 1; }
                Text { text: card.duration; font-size: 11px; color: Theme.text-value; }
            }

            if card.subtitle != "": HorizontalLayout {
                Text { text: "Clips"; font-size: 11px; color: Theme.text-dim; horizontal-stretch: 1; }
                Text { text: card.subtitle; font-size: 11px; color: Theme.text-value; }
            }
        }

        Rectangle { height: 10px; }

        // MVP section with avatars
        if card.mvp-count > 0: Rectangle {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 0px;

                Rectangle { height: 1px; background: Theme.card-border; }
                Rectangle { height: 8px; }

                Text {
                    text: "MVPs";
                    font-size: 10px;
                    font-weight: 600;
                    color: Theme.skel-text;
                    letter-spacing: 0.8px;
                }

                Rectangle { height: 6px; }

                VerticalLayout {
                    spacing: 4px;

                    if card.mvp-count >= 1: HorizontalLayout {
                        spacing: 8px;
                        height: 22px;

                        AvatarDot { initials: card.mvp0-initials; color-index: 0; }
                        Text {
                            text: card.mvp0-name;
                            font-size: 12px;
                            font-weight: 500;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: card.mvp0-stat;
                            font-size: 11px;
                            color: Theme.text-sub;
                            vertical-alignment: center;
                        }
                    }

                    if card.mvp-count >= 2: HorizontalLayout {
                        spacing: 8px;
                        height: 22px;

                        AvatarDot { initials: card.mvp1-initials; color-index: 1; }
                        Text {
                            text: card.mvp1-name;
                            font-size: 12px;
                            font-weight: 500;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: card.mvp1-stat;
                            font-size: 11px;
                            color: Theme.text-sub;
                            vertical-alignment: center;
                        }
                    }

                    if card.mvp-count >= 3: HorizontalLayout {
                        spacing: 8px;
                        height: 22px;

                        AvatarDot { initials: card.mvp2-initials; color-index: 2; }
                        Text {
                            text: card.mvp2-name;
                            font-size: 12px;
                            font-weight: 500;
                            color: Theme.text-primary;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: card.mvp2-stat;
                            font-size: 11px;
                            color: Theme.text-sub;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

// Session card
component SessionCard inherits Rectangle {
    in property <FeedCardData> card;

    background: Theme.card-bg;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        Text {
            text: "SESSION";
            font-size: 10px;
            font-weight: 600;
            color: Theme.text-dim;
            letter-spacing: 0.8px;
        }

        HorizontalLayout {
            spacing: 8px;
            height: 36px;

            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                background: card.game-name == "Valorant" ? #ff4655 :
                            card.game-name == "Counter-Strike 2" ? #de9b35 :
                            Theme.accent;
                y: (parent.height - self.height) / 2;

                Text {
                    text: card.game-name == "Valorant" ? "VAL" :
                          card.game-name == "Counter-Strike 2" ? "CS2" :
                          card.game-name != "" ? card.game-name : "VC";
                    font-size: 10px;
                    font-weight: 800;
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 2px;

                Text {
                    text: card.game-name != "" ? card.game-name : card.title;
                    font-size: 13px;
                    font-weight: 500;
                    color: Theme.text-primary;
                    overflow: elide;
                }

                if card.duration != "": Text {
                    text: card.duration;
                    font-size: 11px;
                    color: Theme.text-sub;
                }
            }
        }

        if card.participant-count > 0: HorizontalLayout {
            spacing: -7px;
            height: 20px;

            AvatarDot { initials: card.actor-initials; color-index: 0; }
            if card.participant-count > 1: AvatarDot { initials: ""; color-index: 1; }
            if card.participant-count > 2: AvatarDot { initials: ""; color-index: 2; }
        }

        Rectangle { vertical-stretch: 1; }

        Text {
            text: card.timestamp + (card.subtitle != "" ? " · " + card.subtitle : "");
            font-size: 11px;
            color: Theme.skel-text;
        }
    }
}

// Catch-up card
component CatchupCard inherits Rectangle {
    in property <FeedCardData> card;

    background: Theme.card-bg;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        Text {
            text: "CATCH-UP";
            font-size: 10px;
            font-weight: 700;
            color: Theme.accent-green;
            letter-spacing: 1px;
        }

        Text {
            text: card.title;
            font-size: 13px;
            color: Theme.text-value;
            wrap: word-wrap;
            vertical-stretch: 1;
        }

        Text {
            text: card.timestamp;
            font-size: 11px;
            color: Theme.skel-text;
        }
    }
}

// Generic skeleton card
component SkeletonCard inherits Rectangle {
    in property <FeedCardData> card;

    background: Theme.card-bg-skel;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;

    VerticalLayout {
        alignment: center;
        spacing: 10px;
        padding: 24px;
        padding-left: 16px;
        padding-right: 16px;

        Image {
            source: @image-url("../icons/scissors.svg");
            colorize: Theme.skel-text;
            width: 28px;
            height: 28px;
            opacity: 0.3;
            x: (parent.width - self.width) / 2;
        }

        Text {
            text: card.title != "" ? card.title : "Your crew's clips show up here";
            font-size: 13px;
            font-weight: 500;
            color: Theme.skel-text;
            horizontal-alignment: center;
        }

        Text {
            text: card.subtitle != "" ? card.subtitle : "Tap the scissors during a voice call to save the last 30 seconds";
            font-size: 11px;
            color: Theme.skel-hint;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }
}

// Hero clip skeleton (2x, dashed play button)
component SkeletonHeroCard inherits Rectangle {
    background: Theme.card-bg-skel;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;
    clip: true;

    VerticalLayout {
        Rectangle {
            vertical-stretch: 3;
            min-height: 200px;
            background: Theme.card-bg-inset;

            Rectangle {
                x: 12px; y: 12px;
                width: badge-t.preferred-width + 20px;
                height: 22px;
                border-radius: 5px;
                border-width: 1px;
                border-color: Theme.skel-ghost;
                background: transparent;

                badge-t := Text {
                    text: "✂ CLIP";
                    font-size: 10px;
                    font-weight: 700;
                    color: Theme.skel-ghost;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    letter-spacing: 0.5px;
                }
            }

            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 48px;
                height: 48px;
                border-radius: 24px;
                border-width: 1.5px;
                border-color: Theme.skel-ghost;
                background: transparent;

                Text {
                    text: "▶";
                    font-size: 16px;
                    color: Theme.skel-ghost;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                x: parent.width - self.width - 10px;
                y: parent.height - self.height - 10px;
                width: dur-sk.preferred-width + 16px;
                height: 22px;
                border-radius: 4px;
                border-width: 1px;
                border-color: Theme.skel-ghost;
                background: transparent;

                dur-sk := Text {
                    text: "0:30";
                    font-size: 11px;
                    color: Theme.skel-ghost;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        VerticalLayout {
            padding: 12px;
            padding-left: 14px;
            spacing: 5px;
            vertical-stretch: 0;

            Text {
                text: "Your first clip goes here";
                font-size: 14px;
                font-weight: 500;
                color: Theme.skel-text;
            }

            Text {
                text: "Tap ✂ during a voice call to save the last 30 seconds. Your crew's best clips show up right here.";
                font-size: 11px;
                color: Theme.skel-hint;
                wrap: word-wrap;
            }
        }
    }
}

// Recap skeleton (fake stat bars)
component SkeletonRecapCard inherits Rectangle {
    background: Theme.card-bg-skel;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;

    VerticalLayout {
        alignment: center;
        spacing: 8px;
        padding: 16px;

        Rectangle {
            width: 40px; height: 40px;
            border-radius: 10px;
            background: Theme.skel-element;
            x: (parent.width - self.width) / 2;

            Image {
                source: @image-url("../icons/star.svg");
                colorize: Theme.skel-ghost;
                width: 18px; height: 18px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                opacity: 0.25;
            }
        }

        Text {
            text: "Weekly recap";
            font-size: 13px;
            font-weight: 500;
            color: Theme.skel-text;
            horizontal-alignment: center;
        }

        Text {
            text: "Your crew's stats will appear after your first week together";
            font-size: 11px;
            color: Theme.skel-hint;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        Rectangle { height: 4px; }

        VerticalLayout {
            spacing: 7px;

            for w in [55, 70, 40, 60]: HorizontalLayout {
                Rectangle { height: 7px; border-radius: 3px; background: Theme.skel-element; horizontal-stretch: 1; max-width: 1px * w; }
                Rectangle { horizontal-stretch: 1; }
                Rectangle { height: 7px; width: 30px; border-radius: 3px; background: Theme.skel-element; }
            }
        }
    }
}

// Voice clip skeleton (faint waveform)
component SkeletonClipCard inherits Rectangle {
    background: Theme.card-bg-skel;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.card-border;
    clip: true;

    VerticalLayout {
        Rectangle {
            min-height: 72px;
            vertical-stretch: 1;
            background: Theme.card-bg-inset;

            HorizontalLayout {
                alignment: center;
                spacing: 3px;
                padding-left: 20px;
                padding-right: 20px;

                for h in [0.35, 0.7, 1.0, 0.5, 0.9, 0.4, 0.8, 0.25, 0.65, 1.0, 0.45, 0.75, 0.3, 0.85, 0.55, 0.95, 0.35, 0.7]: Rectangle {
                    width: 3px;

                    Rectangle {
                        width: parent.width;
                        height: 40px * h;
                        y: (parent.height - self.height) / 2;
                        border-radius: 2px;
                        background: Theme.clip-amber;
                        opacity: 0.06;
                    }
                }
            }
        }

        VerticalLayout {
            padding: 10px;
            padding-left: 12px;
            spacing: 4px;
            vertical-stretch: 0;

            Text {
                text: "✂ VOICE CLIP · 0:30";
                font-size: 10px;
                font-weight: 700;
                color: Theme.skel-ghost;
            }

            Text {
                text: "Voice clips land here";
                font-size: 12px;
                font-weight: 500;
                color: Theme.skel-text;
            }

            Text {
                text: "Funny moment in voice? Clip it.";
                font-size: 11px;
                color: Theme.skel-hint;
            }
        }
    }
}

