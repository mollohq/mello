import { Theme } from "../theme.slint";
import { FeedCardData } from "../types.slint";

component WaveformBars inherits Rectangle {
    in property <bool> large: false;
    in property <bool> overlay: false;

    preferred-height: large ? 72px : 48px;
    background: overlay ? transparent : #1a1a22;
    border-radius: overlay ? 0px : 4px;

    HorizontalLayout {
        alignment: center;
        spacing: large ? 3px : 2px;
        padding-left: large ? 20px : 12px;
        padding-right: large ? 20px : 12px;

        for h in [0.35, 0.7, 1.0, 0.5, 0.9, 0.4, 0.8, 0.25, 0.65, 1.0, 0.45, 0.75, 0.3, 0.85, 0.55, 0.95, 0.35, 0.7, 0.2, 0.6]: Rectangle {
            width: large ? 3px : 2px;

            Rectangle {
                width: parent.width;
                height: (large ? 50px : 30px) * h;
                y: (parent.height - self.height) / 2;
                border-radius: large ? 2px : 1px;
                background: Theme.accent;
                opacity: 0.5 + h * 0.5;
            }
        }
    }
}

component AvatarDot inherits Rectangle {
    in property <string> initials;
    in property <int> color-index: 0;

    width: 18px;
    height: 18px;
    border-radius: 4px;
    border-width: 2px;
    border-color: #222226;
    background: color-index == 0 ? #EB4D5F :
                color-index == 1 ? #4a9eff :
                color-index == 2 ? #4ade80 :
                color-index == 3 ? #a78bfa : #f59e0b;

    Text {
        text: initials;
        font-size: 7px;
        font-weight: 600;
        color: white;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component ClipBadge inherits Rectangle {
    in property <bool> small: false;

    width: small ? 42px : 52px;
    height: small ? 20px : 22px;
    border-radius: small ? 4px : 5px;
    background: Theme.accent;

    HorizontalLayout {
        alignment: center;
        spacing: 3px;

        Image {
            source: @image-url("../icons/scissors.svg");
            colorize: white;
            width: small ? 9px : 10px;
            height: small ? 9px : 10px;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: "CLIP";
            font-size: small ? 9px : 10px;
            font-weight: 700;
            color: white;
            letter-spacing: 0.5px;
            vertical-alignment: center;
        }
    }
}

component PlayButton inherits Rectangle {
    in property <bool> small: false;

    width: small ? 32px : 52px;
    height: small ? 32px : 52px;
    border-radius: small ? 16px : 26px;
    background: #00000055;

    Text {
        text: "▶";
        font-size: small ? 12px : 18px;
        color: white;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// Hero clip card (2x wide)
component HeroClipCard inherits Rectangle {
    in property <FeedCardData> card;
    callback play-clicked(string);

    background: card-hover.has-hover ? #2a2a2e : #222226;
    border-radius: 10px;
    border-width: 1px;
    border-color: card-hover.has-hover ? #3a3a3e : #2a2a2e;
    clip: true;

    VerticalLayout {
        // Thumbnail area
        Rectangle {
            vertical-stretch: 3;
            min-height: 180px;
            background: @linear-gradient(135deg, #0d1a0d 0%, #0a1520 40%, #151525 100%);

            // Game watermark
            Text {
                text: card.game-name != "" ? card.game-name : "";
                font-size: 48px;
                font-weight: 800;
                color: #ffffff06;
                letter-spacing: 6px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            WaveformBars {
                large: true;
                overlay: true;
                y: parent.height - self.height - 4px;
                width: parent.width;
                opacity: 0.6;
            }

            ClipBadge {
                x: 12px;
                y: 12px;
            }

            PlayButton {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }

            Rectangle {
                x: parent.width - self.width - 10px;
                y: parent.height - self.height - 10px;
                width: dur-text.preferred-width + 16px;
                height: 22px;
                border-radius: 4px;
                background: #000000aa;

                dur-text := Text {
                    text: card.duration;
                    font-size: 11px;
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // Card body
        VerticalLayout {
            padding: 12px;
            padding-left: 14px;
            padding-right: 14px;
            spacing: 6px;
            vertical-stretch: 0;

            Text {
                text: card.title != "" ? card.title : card.actor-name + " clipped that";
                font-size: 14px;
                font-weight: 500;
                color: Theme.text-primary;
            }

            HorizontalLayout {
                spacing: 8px;
                height: 20px;

                if card.participant-count > 0: HorizontalLayout {
                    spacing: -7px;
                    width: self.preferred-width;

                    AvatarDot { initials: card.actor-initials; color-index: 0; }
                    if card.participant-count > 1: AvatarDot { initials: ""; color-index: 1; }
                    if card.participant-count > 2: AvatarDot { initials: ""; color-index: 2; }
                }

                Text {
                    text: card.timestamp;
                    font-size: 11px;
                    color: #888888;
                    vertical-alignment: center;
                }

                if card.game-name != "": Text {
                    text: "·";
                    font-size: 11px;
                    color: #555555;
                    vertical-alignment: center;
                }

                if card.game-name != "": Text {
                    text: card.game-name;
                    font-size: 11px;
                    color: #888888;
                    vertical-alignment: center;
                }
            }
        }
    }

    card-hover := TouchArea {
        mouse-cursor: pointer;
        clicked => { play-clicked(card.id); }
    }
}

// Standard clip card (1x)
component ClipCard inherits Rectangle {
    in property <FeedCardData> card;
    callback play-clicked(string);

    background: clip-hover.has-hover ? #2a2a2e : #222226;
    border-radius: 10px;
    border-width: 1px;
    border-color: clip-hover.has-hover ? #3a3a3e : #2a2a2e;
    clip: true;

    VerticalLayout {
        // Waveform area
        WaveformBars {
            large: false;
            vertical-stretch: 1;
            min-height: 60px;

            ClipBadge {
                small: true;
                x: 8px;
                y: 8px;
            }

            PlayButton {
                small: true;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        // Card body
        VerticalLayout {
            padding: 10px;
            padding-left: 12px;
            padding-right: 12px;
            spacing: 4px;
            vertical-stretch: 0;

            HorizontalLayout {
                spacing: 4px;
                height: 14px;

                Image {
                    source: @image-url("../icons/scissors.svg");
                    colorize: Theme.accent;
                    width: 10px;
                    height: 10px;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: "VOICE CLIP · " + card.duration;
                    font-size: 10px;
                    font-weight: 700;
                    color: Theme.accent;
                    vertical-alignment: center;
                }
            }

            Text {
                text: card.title != "" ? card.title : card.actor-name + " clipped that";
                font-size: 13px;
                font-weight: 500;
                color: Theme.text-primary;
                overflow: elide;
            }

            Text {
                text: card.timestamp + (card.game-name != "" ? " · " + card.game-name : "");
                font-size: 11px;
                color: #888888;
            }
        }
    }

    clip-hover := TouchArea {
        mouse-cursor: pointer;
        clicked => { play-clicked(card.id); }
    }
}

// Weekly recap card
component RecapCard inherits Rectangle {
    in property <FeedCardData> card;

    background: #222226;
    border-radius: 10px;
    border-width: 1px;
    border-color: #2a2a2e;

    VerticalLayout {
        padding: 16px;
        spacing: 0px;

        Text {
            text: "WEEKLY RECAP";
            font-size: 10px;
            font-weight: 700;
            color: Theme.accent;
            letter-spacing: 1.2px;
            height: 20px;
        }

        Rectangle { height: 12px; }

        Text {
            text: card.title;
            font-size: 28px;
            font-weight: 700;
            color: Theme.text-primary;
        }

        Text {
            text: "Total crew time";
            font-size: 12px;
            color: #888888;
        }

        Rectangle { height: 14px; }

        Rectangle {
            height: 1px;
            background: #2a2a2e;
        }

        Rectangle { height: 10px; }

        VerticalLayout {
            spacing: 6px;
            vertical-stretch: 1;

            if card.game-name != "": HorizontalLayout {
                Text { text: "Top game"; font-size: 12px; color: #666666; horizontal-stretch: 1; }
                Text { text: card.game-name; font-size: 12px; color: #cccccc; }
            }

            if card.duration != "": HorizontalLayout {
                Text { text: "Longest sesh"; font-size: 12px; color: #666666; horizontal-stretch: 1; }
                Text { text: card.duration; font-size: 12px; color: #cccccc; }
            }

            if card.subtitle != "": HorizontalLayout {
                Text { text: "Clips"; font-size: 12px; color: #666666; horizontal-stretch: 1; }
                Text { text: card.subtitle; font-size: 12px; color: #cccccc; }
            }

            if card.actor-name != "": HorizontalLayout {
                Text { text: "MVP"; font-size: 12px; color: #666666; horizontal-stretch: 1; }
                Text { text: card.actor-name; font-size: 12px; color: #cccccc; }
            }
        }
    }
}

// Session card
component SessionCard inherits Rectangle {
    in property <FeedCardData> card;

    background: #222226;
    border-radius: 10px;
    border-width: 1px;
    border-color: #2a2a2e;

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        Text {
            text: "SESSION";
            font-size: 10px;
            font-weight: 600;
            color: #666666;
            letter-spacing: 0.8px;
        }

        HorizontalLayout {
            spacing: 8px;
            height: 36px;

            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                background: card.game-name == "Valorant" ? #ff4655 :
                            card.game-name == "Counter-Strike 2" ? #de9b35 :
                            Theme.accent;
                y: (parent.height - self.height) / 2;

                Text {
                    text: card.game-name == "Valorant" ? "VAL" :
                          card.game-name == "Counter-Strike 2" ? "CS2" :
                          card.game-name != "" ? card.game-name : "VC";
                    font-size: 10px;
                    font-weight: 800;
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: 2px;

                Text {
                    text: card.game-name != "" ? card.game-name : card.title;
                    font-size: 13px;
                    font-weight: 500;
                    color: Theme.text-primary;
                    overflow: elide;
                }

                if card.duration != "": Text {
                    text: card.duration;
                    font-size: 11px;
                    color: #888888;
                }
            }
        }

        if card.participant-count > 0: HorizontalLayout {
            spacing: -7px;
            height: 20px;

            AvatarDot { initials: card.actor-initials; color-index: 0; }
            if card.participant-count > 1: AvatarDot { initials: ""; color-index: 1; }
            if card.participant-count > 2: AvatarDot { initials: ""; color-index: 2; }
        }

        Rectangle { vertical-stretch: 1; }

        Text {
            text: card.timestamp + (card.subtitle != "" ? " · " + card.subtitle : "");
            font-size: 11px;
            color: #555555;
        }
    }
}

// Catch-up card
component CatchupCard inherits Rectangle {
    in property <FeedCardData> card;

    background: #222226;
    border-radius: 10px;
    border-width: 1px;
    border-color: #2a2a2e;

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        Text {
            text: "CATCH-UP";
            font-size: 10px;
            font-weight: 700;
            color: #4ade80;
            letter-spacing: 1px;
        }

        Text {
            text: card.title;
            font-size: 13px;
            color: #cccccc;
            wrap: word-wrap;
            vertical-stretch: 1;
        }

        Text {
            text: card.timestamp;
            font-size: 11px;
            color: #555555;
        }
    }
}

// Skeleton card (cold-start placeholder)
component SkeletonCard inherits Rectangle {
    in property <FeedCardData> card;

    background: #1e1e22;
    border-radius: 10px;
    border-width: 1px;
    border-color: #333333;

    VerticalLayout {
        alignment: center;
        spacing: 10px;
        padding: 24px;
        padding-left: 16px;
        padding-right: 16px;

        Image {
            source: @image-url("../icons/scissors.svg");
            colorize: #555555;
            width: 28px;
            height: 28px;
            opacity: 0.3;
            x: (parent.width - self.width) / 2;
        }

        Text {
            text: card.title != "" ? card.title : "Your crew's clips show up here";
            font-size: 13px;
            font-weight: 500;
            color: #555555;
            horizontal-alignment: center;
        }

        Text {
            text: card.subtitle != "" ? card.subtitle : "Tap the scissors during a voice call to save the last 30 seconds";
            font-size: 11px;
            color: #444444;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }
}

// Invite CTA card
component InviteCard inherits Rectangle {
    callback invite-clicked();

    background: #EB4D5F14;
    border-radius: 10px;
    border-width: 1px;
    border-color: #EB4D5F33;

    VerticalLayout {
        alignment: center;
        spacing: 8px;
        padding: 20px;

        Text {
            text: "Invite your crew";
            font-size: 14px;
            font-weight: 600;
            color: Theme.accent;
            horizontal-alignment: center;
        }

        Text {
            text: "Everything here comes alive when your friends join. Get them in here.";
            font-size: 11px;
            color: #888888;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }

    invite-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { invite-clicked(); }
    }
}

export component CrewFeed inherits Rectangle {
    in property <[FeedCardData]> cards: [];
    in property <bool> is-cold-start: true;
    in property <string> crew-name: "";
    in property <int> clip-count: 0;

    callback go-live-clicked();
    callback card-clicked(string);
    callback invite-clicked();

    background: transparent;

    VerticalLayout {
        spacing: 0px;

        // Header
        Rectangle {
            height: 48px;
            background: transparent;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                spacing: 10px;

                HorizontalLayout {
                    spacing: 10px;
                    horizontal-stretch: 1;
                    alignment: start;

                    Text {
                        text: "Crew feed";
                        font-size: 15px;
                        font-weight: 500;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }

                    if clip-count > 0: Rectangle {
                        width: badge-text.preferred-width + 20px;
                        height: 22px;
                        border-radius: 11px;
                        background: #2a2a2e;
                        y: (parent.height - self.height) / 2;

                        badge-text := Text {
                            text: clip-count + " clips this week";
                            font-size: 11px;
                            color: #888888;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    width: go-live-text.preferred-width + 36px;
                    height: 32px;
                    border-radius: 8px;
                    background: live-hover.has-hover ? #EB4D5F28 : #EB4D5F14;
                    border-width: 1px;
                    border-color: #EB4D5F33;
                    y: (parent.height - self.height) / 2;

                    HorizontalLayout {
                        alignment: center;
                        spacing: 6px;

                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.accent;
                            y: (parent.height - self.height) / 2;
                        }

                        go-live-text := Text {
                            text: "GO LIVE";
                            font-size: 12px;
                            font-weight: 600;
                            color: Theme.accent;
                            vertical-alignment: center;
                        }
                    }

                    live-hover := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { go-live-clicked(); }
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #2a2a2e;
        }

        // Scrollable feed area
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                padding: 16px;
                padding-left: 20px;
                padding-right: 20px;
                spacing: 12px;

                // Row 1: Hero (2x) + card (1x)
                if cards.length > 0: HorizontalLayout {
                    height: 420px;
                    spacing: 12px;

                    if cards.length > 0 && cards[0].is-hero: HeroClipCard {
                        horizontal-stretch: 2;
                        card: cards[0];
                        play-clicked(id) => { root.card-clicked(id); }
                    }

                    if cards.length > 0 && !cards[0].is-hero: ClipCard {
                        horizontal-stretch: 2;
                        card: cards[0];
                        play-clicked(id) => { root.card-clicked(id); }
                    }

                    if cards.length > 1: VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 12px;

                        if cards[1].card-type == "recap": RecapCard { vertical-stretch: 1; card: cards[1]; }
                        if cards[1].card-type == "clip": ClipCard { vertical-stretch: 1; card: cards[1]; play-clicked(id) => { root.card-clicked(id); } }
                        if cards[1].card-type == "session": SessionCard { vertical-stretch: 1; card: cards[1]; }
                        if cards[1].card-type == "catchup": CatchupCard { vertical-stretch: 1; card: cards[1]; }
                        if cards[1].card-type == "skeleton": SkeletonCard { vertical-stretch: 1; card: cards[1]; }
                    }
                }

                // Row 2: Three 1x cards
                if cards.length > 2: HorizontalLayout {
                    height: 210px;
                    spacing: 12px;

                    for idx in [2, 3, 4]: Rectangle {
                        visible: cards.length > idx;
                        horizontal-stretch: 1;

                        if cards.length > idx && cards[idx].card-type == "clip": ClipCard {
                            card: cards[idx]; width: parent.width; height: parent.height;
                            play-clicked(id) => { root.card-clicked(id); }
                        }
                        if cards.length > idx && cards[idx].card-type == "session": SessionCard {
                            card: cards[idx]; width: parent.width; height: parent.height;
                        }
                        if cards.length > idx && cards[idx].card-type == "catchup": CatchupCard {
                            card: cards[idx]; width: parent.width; height: parent.height;
                        }
                        if cards.length > idx && cards[idx].card-type == "recap": RecapCard {
                            card: cards[idx]; width: parent.width; height: parent.height;
                        }
                        if cards.length > idx && cards[idx].card-type == "skeleton": SkeletonCard {
                            card: cards[idx]; width: parent.width; height: parent.height;
                        }
                    }
                }

                // Row 3: card (1x) + wide card (2x)
                if cards.length > 5: HorizontalLayout {
                    height: 210px;
                    spacing: 12px;

                    if cards.length > 5 && cards[5].card-type == "clip": ClipCard {
                        horizontal-stretch: 1; card: cards[5];
                        play-clicked(id) => { root.card-clicked(id); }
                    }
                    if cards.length > 5 && cards[5].card-type == "session": SessionCard { horizontal-stretch: 1; card: cards[5]; }
                    if cards.length > 5 && cards[5].card-type == "catchup": CatchupCard { horizontal-stretch: 1; card: cards[5]; }
                    if cards.length > 5 && cards[5].card-type == "skeleton": SkeletonCard { horizontal-stretch: 1; card: cards[5]; }

                    if cards.length > 6: Rectangle {
                        horizontal-stretch: 2;

                        if cards[6].card-type == "clip": ClipCard {
                            card: cards[6]; width: parent.width; height: parent.height;
                            play-clicked(id) => { root.card-clicked(id); }
                        }
                        if cards[6].card-type == "session": SessionCard { card: cards[6]; width: parent.width; height: parent.height; }
                        if cards[6].card-type == "catchup": CatchupCard { card: cards[6]; width: parent.width; height: parent.height; }
                        if cards[6].card-type == "skeleton": SkeletonCard { card: cards[6]; width: parent.width; height: parent.height; }
                    }
                }

                if is-cold-start: InviteCard {
                    invite-clicked => { root.invite-clicked(); }
                }

                Rectangle { height: 20px; }
            }
        }
    }
}

