import { Theme } from "../theme.slint";
import { MemberData } from "../types.slint";

export component StreamView inherits Rectangle {
    in property <[MemberData]> members: [];

    background: Theme.bg-secondary;
    border-radius: Theme.radius-md;

    VerticalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;

        // Header
        Text {
            text: "STREAM";
            font-size: Theme.font-xs;
            color: Theme.text-muted;
            letter-spacing: 1px;
        }

        // Video placeholder
        Rectangle {
            vertical-stretch: 1;
            background: Theme.bg-tertiary;
            border-radius: Theme.radius-sm;

            Text {
                text: "No active stream";
                color: Theme.text-muted;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Crew members bar
        if members.length > 0: HorizontalLayout {
            spacing: Theme.spacing-sm;
            height: 40px;

            for member in members: Rectangle {
                width: 36px;
                height: 36px;
                border-radius: 18px;
                background: Theme.bg-primary;
                border-width: 2px;
                border-color: member.online ? Theme.accent-green : Theme.border-light;

                Text {
                    text: member.name;
                    font-size: Theme.font-xs;
                    color: Theme.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                    max-width: 30px;
                }
            }
        }
    }
}
