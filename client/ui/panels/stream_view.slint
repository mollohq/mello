import { Theme } from "../theme.slint";
import { MemberData } from "../types.slint";

export component StreamView inherits Rectangle {
    in property <[MemberData]> members: [];
    in property <string> streamer-name: "k0ji_tech";
    in property <string> stream-label: "COUNTER-STRIKE 2";
    in property <bool> stream-live: true;

    vertical-stretch: 1;
    background: Theme.surface;
    border-radius: Theme.r-outer;
    border-width: 1px;
    border-color: Theme.graphic-light;

    VerticalLayout {
        padding: Theme.pad;
        spacing: 0px;

        // --- Stream header ---
        HorizontalLayout {
            height: 48px;
            spacing: 8px;

            VerticalLayout {
                horizontal-stretch: 1;
                alignment: start;

                Text {
                    text: "CREWMATE STREAM";
                    font-size: Theme.font-sm;
                    font-weight: 600;
                    letter-spacing: 1.3px;
                    color: Theme.text-secondary;
                }

                Rectangle { height: 4px; }

                Text {
                    text: streamer-name != "" ? streamer-name : "No stream";
                    font-size: Theme.font-xl;
                    font-weight: 500;
                    color: Theme.text-primary;
                }
            }

            // Live badge
            if stream-live: Rectangle {
                width: 110px;
                height: 28px;
                background: Theme.bg-app;
                border-radius: Theme.r-pill;
                y: 0;

                HorizontalLayout {
                    alignment: center;
                    spacing: 8px;

                    Rectangle {
                        width: 6px;
                        height: 6px;
                        border-radius: 3px;
                        background: Theme.accent;
                    }

                    Text {
                        text: "00:42:15";
                        font-family: Theme.font-mono;
                        font-size: Theme.font-sm;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 16px; }

        // --- Stream preview area ---
        Rectangle {
            vertical-stretch: 1;
            background: Theme.bg-app;
            border-radius: Theme.r-inner;
            clip: true;

            if stream-live: Image {
                source: @image-url("../../../designs/example-images/Counter-Strike-2.jpg");
                width: parent.width;
                height: parent.height;
                image-fit: cover;
            }

            // Placeholder art when no stream
            if !stream-live: Rectangle {
                width: parent.width * 60%;
                height: 4px;
                background: Theme.graphic-med;
                border-radius: 2px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
            if !stream-live: Rectangle {
                width: 64px;
                height: 4px;
                background: Theme.graphic-dark;
                border-radius: 2px;
                x: parent.width * 28%;
                y: parent.height / 2 - 32px;
            }
            if !stream-live: Rectangle {
                width: parent.width * 18%;
                height: 4px;
                background: Theme.graphic-light;
                border-radius: 2px;
                x: parent.width * 56%;
                y: parent.height / 2 + 28px;
            }
        }

        Rectangle { height: 16px; }

        // --- Stream footer ---
        HorizontalLayout {
            height: 20px;
            spacing: 16px;

            Text {
                text: stream-label;
                font-family: Theme.font-mono;
                font-size: Theme.font-lg;
                font-weight: 500;
                color: Theme.text-secondary;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            // Scrub bar
            if stream-live: Rectangle {
                width: 240px;
                height: 6px;
                background: Theme.bg-app;
                border-radius: 3px;
                y: (parent.height - self.height) / 2;

                Rectangle {
                    width: parent.width * 45%;
                    height: parent.height;
                    background: Theme.graphic-dark;
                    border-radius: 3px;
                }
            }
        }
    }
}
