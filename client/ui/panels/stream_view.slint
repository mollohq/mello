import { Theme } from "../theme.slint";
import { MemberData } from "../types.slint";

export component StreamView inherits Rectangle {
    in property <[MemberData]> members: [];
    in property <string> streamer-name: "";
    in property <string> stream-label: "";
    in property <bool> is-hosting: false;
    in property <bool> is-watching: false;
    in property <image> stream-frame;

    callback start-stream-clicked();
    callback stop-stream-clicked();
    callback stop-watching-clicked();

    property <bool> stream-active: is-hosting || is-watching;

    vertical-stretch: 1;
    background: Theme.surface;
    border-radius: Theme.r-outer;
    border-width: 1px;
    border-color: Theme.graphic-light;

    VerticalLayout {
        padding: Theme.pad;
        spacing: 0px;

        // --- Stream header ---
        HorizontalLayout {
            height: 48px;
            spacing: 8px;

            VerticalLayout {
                horizontal-stretch: 1;
                alignment: start;

                Text {
                    text: is-hosting ? "YOUR STREAM" : (is-watching ? "CREWMATE STREAM" : "STREAM");
                    font-size: Theme.font-sm;
                    font-weight: 600;
                    letter-spacing: 1.3px;
                    color: Theme.text-secondary;
                }

                Rectangle { height: 4px; }

                Text {
                    text: stream-active && streamer-name != "" ? streamer-name : "No active stream";
                    font-size: Theme.font-xl;
                    font-weight: 500;
                    color: Theme.text-primary;
                }
            }

            // Live badge (hosting or watching)
            if stream-active: Rectangle {
                width: live-row.preferred-width + 20px;
                height: 28px;
                background: Theme.bg-app;
                border-radius: Theme.r-pill;
                y: 0;

                live-row := HorizontalLayout {
                    alignment: center;
                    spacing: 8px;
                    padding-left: 10px;
                    padding-right: 10px;

                    Rectangle {
                        width: 6px;
                        height: 6px;
                        border-radius: 3px;
                        background: Theme.accent;
                    }

                    Text {
                        text: is-hosting ? "HOSTING" : "LIVE";
                        font-family: Theme.font-mono;
                        font-size: Theme.font-sm;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }
                }
            }

            // Stop button (visible when hosting or watching)
            if stream-active: Rectangle {
                width: stop-text.preferred-width + 24px;
                height: 28px;
                border-radius: Theme.r-pill;
                background: stop-ta.has-hover ? Theme.accent : Theme.bg-app;
                border-width: 1px;
                border-color: stop-ta.has-hover ? Theme.accent : Theme.graphic-light;
                y: 0;

                stop-text := Text {
                    text: is-hosting ? "STOP" : "LEAVE";
                    font-family: Theme.font-mono;
                    font-size: Theme.font-sm;
                    font-weight: 500;
                    color: stop-ta.has-hover ? #FFFFFF : Theme.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                stop-ta := TouchArea {
                    clicked => {
                        if is-hosting { stop-stream-clicked(); }
                        else { stop-watching-clicked(); }
                    }
                }
            }
        }

        Rectangle { height: 16px; }

        // --- Stream display area ---
        Rectangle {
            vertical-stretch: 1;
            background: Theme.bg-app;
            border-radius: Theme.r-inner;
            clip: true;

            // Live frame (watching another member's stream)
            if is-watching: Image {
                source: stream-frame;
                width: parent.width;
                height: parent.height;
                image-fit: contain;
            }

            // Hosting indicator (no self-preview)
            if is-hosting: VerticalLayout {
                alignment: center;
                spacing: 12px;

                Text {
                    text: "STREAMING";
                    font-family: Theme.font-mono;
                    font-size: 14px;
                    font-weight: 600;
                    letter-spacing: 2px;
                    color: Theme.accent;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Your crew can see your screen";
                    font-size: 13px;
                    color: Theme.text-secondary;
                    horizontal-alignment: center;
                }
            }

            // Idle state — no stream
            if !stream-active: VerticalLayout {
                alignment: center;
                spacing: 16px;

                Rectangle {
                    width: parent.width * 60%;
                    height: 4px;
                    background: Theme.graphic-med;
                    border-radius: 2px;
                    x: (parent.width - self.width) / 2;
                }

                // Start stream button
                Rectangle {
                    width: go-live-row.preferred-width + 32px;
                    height: 40px;
                    border-radius: 6px;
                    background: go-live-ta.has-hover ? Theme.accent : Theme.bg-app;
                    border-width: 1px;
                    border-color: go-live-ta.has-hover ? Theme.accent : Theme.graphic-light;
                    x: (parent.width - self.width) / 2;

                    go-live-row := HorizontalLayout {
                        alignment: center;
                        spacing: 8px;
                        padding-left: 16px;
                        padding-right: 16px;

                        Text {
                            text: "▶";
                            font-size: 11px;
                            color: go-live-ta.has-hover ? #FFFFFF : Theme.text-secondary;
                            vertical-alignment: center;
                        }

                        Text {
                            text: "GO LIVE";
                            font-family: Theme.font-mono;
                            font-size: 13px;
                            font-weight: 600;
                            letter-spacing: 1px;
                            color: go-live-ta.has-hover ? #FFFFFF : Theme.text-secondary;
                            vertical-alignment: center;
                        }
                    }

                    go-live-ta := TouchArea {
                        clicked => { start-stream-clicked(); }
                    }
                }
            }
        }

        Rectangle { height: 16px; }

        // --- Stream footer ---
        HorizontalLayout {
            height: 20px;
            spacing: 16px;

            Text {
                text: stream-label;
                font-family: Theme.font-mono;
                font-size: Theme.font-lg;
                font-weight: 500;
                color: Theme.text-secondary;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }
    }
}
