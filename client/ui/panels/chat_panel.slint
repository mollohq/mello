import { Theme, MelloTextInput } from "../theme.slint";
import { ChatMessageData, ChatLinkData, GifItemData, EmojiItemData, MentionMemberData } from "../types.slint";

component LinkPill inherits Rectangle {
    in property <string> url;
    in property <string> label;
    callback clicked(/* url */ string);

    property <length> pill-max-width: 260px;
    max-width: pill-max-width;

    border-radius: Theme.r-pill;
    background: pill-touch.has-hover
        ? (Theme.dark ? #FFFFFF14 : #0000000A)
        : (Theme.dark ? #FFFFFF0A : #00000006);
    border-width: 1px;
    border-color: Theme.dark ? #FFFFFF1A : Theme.graphic-light;

    pill-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(root.url); }
    }

    pill-layout := HorizontalLayout {
        max-width: root.pill-max-width;
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 5px;
        alignment: center;

        Text {
            text: "↗";
            font-size: 10px;
            font-weight: 600;
            color: Theme.accent;
            vertical-alignment: center;
        }

        Text {
            text: root.label;
            font-size: Theme.font-xs;
            font-weight: 500;
            color: Theme.text-primary;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
            min-width: 0;
        }
    }
}

component AvatarCircle inherits Rectangle {
    in property <string> initials;
    in property <image> avatar;
    in property <bool> has-avatar: false;
    width: 28px;
    height: 28px;
    border-radius: 14px;
    background: Theme.graphic-light;
    clip: true;

    if has-avatar: Image {
        source: avatar;
        width: parent.width;
        height: parent.height;
        image-fit: contain;
    }

    if !has-avatar: Text {
        text: initials;
        font-size: 10px;
        font-family: Theme.font-mono;
        font-weight: 600;
        color: Theme.text-secondary;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// PopupWindow lives in a component (not in `for`) so it can anchor to the ⋮ button.
component MessageMoreMenu inherits Rectangle {
    in property <bool> active: false;
    in property <bool> open-above: false;
    in property <bool> is-own-message: false;
    out property <bool> pointer-hover: more-touch.has-hover;

    callback toggled();
    callback edit-requested();
    callback delete-requested();
    callback copy-requested();

    width: 16px;
    height: 16px;
    border-radius: 4px;
    background: more-touch.has-hover ? Theme.bg-tertiary : Theme.surface;

    more-touch := TouchArea {
        width: parent.width;
        height: parent.height;
        mouse-cursor: pointer;
        clicked => { root.toggled(); }
    }

    Image {
        source: @image-url("../icons/more.svg");
        width: 12px;
        height: 12px;
        colorize: Theme.text-secondary;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    menu-popup := PopupWindow {
        x: 0px;
        y: open-above ? -menu-box.height - 8px : parent.height + 4px;
        width: 120px;

        menu-box := Rectangle {
            background: Theme.surface;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.graphic-light;
            drop-shadow-blur: 6px;
            drop-shadow-color: #00000030;

            VerticalLayout {
                padding: 4px;
                spacing: 2px;

                if is-own-message: Rectangle {
                    height: 28px;
                    background: menu-edit-touch.has-hover ? Theme.bg-tertiary : transparent;
                    border-radius: 4px;

                    Text {
                        text: "Edit";
                        font-size: Theme.font-sm;
                        color: Theme.text-secondary;
                        x: 8px;
                        vertical-alignment: center;
                    }

                    menu-edit-touch := TouchArea {
                        clicked => { root.edit-requested(); }
                    }
                }

                if is-own-message: Rectangle {
                    height: 28px;
                    background: menu-del-touch.has-hover ? Theme.bg-tertiary : transparent;
                    border-radius: 4px;

                    Text {
                        text: "Delete";
                        font-size: Theme.font-sm;
                        color: #E05555;
                        x: 8px;
                        vertical-alignment: center;
                    }

                    menu-del-touch := TouchArea {
                        clicked => { root.delete-requested(); }
                    }
                }

                Rectangle {
                    height: 28px;
                    background: menu-copy-touch.has-hover ? Theme.bg-tertiary : transparent;
                    border-radius: 4px;

                    Text {
                        text: "Copy text";
                        font-size: Theme.font-sm;
                        color: Theme.text-secondary;
                        x: 8px;
                        vertical-alignment: center;
                    }

                    menu-copy-touch := TouchArea {
                        clicked => { root.copy-requested(); }
                    }
                }
            }
        }
    }

    changed active => {
        if active {
            menu-popup.show();
        } else {
            menu-popup.close();
        }
    }
}

component PillButton inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <bool> active: false;
    callback clicked();

    height: 28px;
    width: pill-layout.preferred-width + 16px;
    border-radius: Theme.radius-sm;
    background: transparent;
    border-width: touch.has-hover ? 1px : 0px;
    border-color: Theme.accent;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    pill-layout := HorizontalLayout {
        spacing: 4px;
        padding-left: 8px;
        padding-right: 8px;
        alignment: center;

        Image {
            source: icon;
            width: 14px;
            height: 14px;
            colorize: active || touch.has-hover ? Theme.accent : Theme.text-tertiary;
            y: (parent.height - self.height) / 2;
        }

        Text {
            text: label;
            font-size: Theme.font-xs;
            font-weight: 500;
            color: active || touch.has-hover ? Theme.accent : Theme.text-tertiary;
            vertical-alignment: center;
        }
    }
}

component ChatClipCard inherits Rectangle {
    in property <string> sender-name;
    in property <string> clip-duration: "0:30";
    callback play-clicked();

    height: 72px;
    background: clip-touch.has-hover ? Theme.card-bg-hover : Theme.card-bg;
    border-radius: 8px;
    border-width: 1px;
    border-color: Theme.card-border;

    HorizontalLayout {
        spacing: 10px;
        padding: 10px;

        Rectangle {
            width: 52px;
            height: 52px;
            border-radius: 6px;
            background: Theme.dark
                ? @linear-gradient(135deg, #1a1a2a 0%, #2a1a2a 100%)
                : @linear-gradient(135deg, #e8e8f0 0%, #f0e8f0 100%);

            HorizontalLayout {
                alignment: center;
                spacing: 1px;
                padding-left: 8px;
                padding-right: 8px;

                for h in [0.4, 0.8, 0.5, 0.9, 0.3, 0.7, 0.6, 0.9, 0.4]: Rectangle {
                    width: 2px;
                    height: 24px * h;
                    border-radius: 1px;
                    background: Theme.clip-amber;
                    opacity: 0.6 + h * 0.4;
                }
            }

            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 22px;
                height: 22px;
                border-radius: 11px;
                background: #00000066;

                Text {
                    text: "▶";
                    font-size: 10px;
                    color: white;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        VerticalLayout {
            alignment: center;
            spacing: 3px;
            horizontal-stretch: 1;

            HorizontalLayout {
                spacing: 4px;

                Image {
                    source: @image-url("../icons/scissors.svg");
                    colorize: Theme.clip-amber;
                    width: 12px;
                    height: 12px;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: sender-name + " clipped that";
                    font-size: 12px;
                    font-weight: 500;
                    color: Theme.text-primary;
                    overflow: elide;
                }
            }

            Text {
                text: "Voice · " + clip-duration + " · Play";
                font-size: 11px;
                color: #888888;
            }
        }
    }

    clip-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { play-clicked(); }
    }
}

component GifPopover inherits Rectangle {
    in property <[GifItemData]> gifs: [];
    in property <bool> show: false;
    callback search(/* query */ string);
    callback gif-selected(/* gif_id */ string, /* url */ string, /* preview_url */ string, /* width */ int, /* height */ int);
    callback close();

    visible: show;
    height: 360px;
    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.graphic-light;
    border-radius: Theme.r-inner;
    clip: true;

    VerticalLayout {
        padding: 8px;
        spacing: 8px;

        Rectangle {
            height: 32px;
            background: Theme.bg-app;
            border-radius: Theme.radius-sm;
            border-width: 1px;
            border-color: Theme.graphic-light;

            gif-search := MelloTextInput {
                x: 10px;
                width: parent.width - 20px;
                height: parent.height;
                font-size: Theme.font-md;
                color: Theme.text-primary;
                vertical-alignment: center;

                edited => {
                    root.search(gif-search.text);
                }
            }

            if gif-search.text == "": Text {
                x: 10px;
                text: "Search GIFs";
                font-size: Theme.font-md;
                color: Theme.text-tertiary;
                vertical-alignment: center;
            }
        }

        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 4px;

                for row-start[row-idx] in [0, 3, 6, 9, 12, 15, 18]: HorizontalLayout {
                    spacing: 4px;

                    for col in [0, 1, 2]: Rectangle {
                        property <int> gif-index: row-start + col;
                        property <bool> in-range: gif-index < gifs.length;
                        visible: in-range;
                        horizontal-stretch: 1;
                        height: in-range ? self.width * 0.75 : 0;
                        border-radius: Theme.radius-sm;
                        clip: true;
                        background: in-range && !gifs[gif-index].has-preview ? Theme.bg-app : transparent;

                        if in-range && gifs[gif-index].has-preview: Image {
                            source: gifs[gif-index].preview;
                            width: parent.width;
                            height: parent.height;
                            image-fit: cover;
                        }

                        if in-range: Rectangle {
                            background: gif-cell-touch.has-hover ? #FFFFFF1A : transparent;

                            gif-cell-touch := TouchArea {
                                clicked => {
                                    if gif-index < gifs.length {
                                        root.gif-selected(
                                            gifs[gif-index].gif-id,
                                            gifs[gif-index].url,
                                            gifs[gif-index].preview-url,
                                            gifs[gif-index].width,
                                            gifs[gif-index].height,
                                        );
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Text {
            text: "Powered by GIPHY";
            font-size: Theme.font-xs;
            color: Theme.text-tertiary;
            horizontal-alignment: center;
            height: 16px;
        }
    }
}

export component ChatPanel inherits Rectangle {
    in property <[ChatMessageData]> messages: [];
    in property <int> messages-this-week: 0;
    in property <string> user-name: "";
    in property <string> user-id: "";
    in property <bool> loading-history: false;

    // GIF popover
    in property <[GifItemData]> gif-results: [];
    in-out property <bool> gif-popover-open: false;

    // Reply mode state
    in-out property <bool> reply-mode: false;
    in-out property <string> reply-to-id: "";
    in-out property <string> reply-to-name: "";

    // Edit mode state
    in-out property <bool> edit-mode: false;
    in-out property <string> edit-message-id: "";

    // New messages pill state
    in-out property <bool> has-new-messages: false;
    in-out property <bool> scroll-to-bottom-request: false;
    in property <int> history-prepended-rows: 0;
    in property <[MentionMemberData]> mention-members: [];
    in property <[MentionMemberData]> mention-suggestions: [];
    in property <[EmojiItemData]> emoji-list: [];

    in-out property <bool> emoji-popover-open: false;
    in-out property <string> more-menu-message-id: "";
    in-out property <string> delete-confirm-message-id: "";

    callback message-submitted(/* text */ string);
    callback chat-viewport-changed(/* at_bottom */ bool);
    callback scroll-to-bottom-done();
    callback link-clicked(/* url */ string);
    callback copy-message-text(/* text */ string);
    callback mention-selected(/* user_id */ string, /* display_name */ string);
    callback chat-input-changed(/* text */ string);
    callback history-prepended-done();
    in-out property <string> chat-input-text: "";
    in-out property <int> composer-line-count: 1;
    in-out property <bool> composer-multiline: false;
    in-out property <bool> pending-newline: false;
    callback message-submitted-with-reply(/* text */ string, /* reply_to */ string);
    callback request-history();
    callback gif-pill-clicked();
    callback gif-search(/* query */ string);
    callback gif-selected(/* gif_id */ string, /* url */ string, /* preview_url */ string, /* width */ int, /* height */ int);
    callback gif-hovered(/* preview_url */ string);
    callback emoji-pill-clicked();
    callback edit-message(/* message_id */ string, /* new_body */ string);
    callback delete-message(/* message_id */ string);
    callback reply-to-message(/* message_id */ string, /* sender_name */ string);

    background: Theme.surface;
    border-width: 0px;
    border-radius: 0px;

    VerticalLayout {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        padding: 0px;
        spacing: 0px;

        // --- Header (matches crew_feed.slint on Theme.bg-app) ---
        Rectangle {
            width: parent.width;
            height: 48px;
            background: Theme.bg-app;

            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                padding-left: 12px;
                padding-right: 12px;

                HorizontalLayout {
                    spacing: 10px;
                    height: parent.height;
                    horizontal-stretch: 1;
                    alignment: start;

                    Text {
                        text: "Crew chat";
                        font-size: 15px;
                        font-weight: 500;
                        color: Theme.text-primary;
                        vertical-alignment: center;
                    }

                    if root.messages-this-week > 0: Rectangle {
                        width: msg-badge-text.preferred-width + 20px;
                        height: 22px;
                        border-radius: 11px;
                        background: Theme.card-border;
                        y: (parent.height - self.height) / 2;

                        msg-badge-text := Text {
                            text: root.messages-this-week == 1
                                ? "1 message this week"
                                : root.messages-this-week + " messages this week";
                            font-size: 11px;
                            color: Theme.text-sub;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.card-border;
        }

        // Header strip = bg-app (crew feed); messages + composer = surface.
        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 0px;

        // --- Chat feed container (for overlay pill) ---
        Rectangle {
            vertical-stretch: 1;

        feed := Flickable {
            // feed id visible to scroll handlers below
            width: parent.width;
            height: parent.height;

            property <bool> at-bottom: feed.viewport-height <= feed.height
                || (-feed.viewport-y + feed.height) >= (feed.viewport-height - 32px);

            flicked => {
                root.chat-viewport-changed(at-bottom);
                if feed.viewport-y >= 0px && !root.loading-history {
                    root.request-history();
                }
                if root.more-menu-message-id != "" {
                    root.more-menu-message-id = "";
                }
            }

            changed viewport-y => {
                root.chat-viewport-changed(at-bottom);
            }

            VerticalLayout {
                width: feed.width;
                spacing: 0px;
                padding-top: 12px;
                padding-bottom: 8px;
                alignment: end;

                if root.loading-history: Rectangle {
                    height: 32px;
                    Text {
                        text: "Loading...";
                        font-size: Theme.font-sm;
                        color: Theme.text-tertiary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if messages.length == 0 && !root.loading-history: Rectangle {
                    vertical-stretch: 1;

                    Text {
                        text: "No messages yet";
                        font-size: Theme.font-md;
                        color: Theme.text-tertiary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                for msg[idx] in messages: VerticalLayout {
                    width: feed.width;
                    padding-top: msg.is-unread-divider ? 8px : (msg.is-group-start && idx > 0 ? 16px : 2px);

                    // Unread divider — stretch wrappers for lines; inner rect centers 1px rule (y ignored on HL children)
                    if msg.is-unread-divider: HorizontalLayout {
                        width: parent.width;
                        height: 20px;
                        spacing: 8px;
                        padding-left: 8px;
                        padding-right: 8px;
                        padding-bottom: 8px;

                        Rectangle {
                            horizontal-stretch: 1;

                            Rectangle {
                                height: 1px;
                                width: parent.width;
                                y: (parent.height - self.height) / 2;
                                background: Theme.accent;
                                opacity: 0.5;
                            }
                        }

                        Text {
                            text: "New messages";
                            font-size: Theme.font-xs;
                            font-weight: 600;
                            color: Theme.accent;
                            horizontal-stretch: 0;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            horizontal-stretch: 1;

                            Rectangle {
                                height: 1px;
                                width: parent.width;
                                y: (parent.height - self.height) / 2;
                                background: Theme.accent;
                                opacity: 0.5;
                            }
                        }
                    }

                    // System message
                    if msg.is-system && !msg.is-unread-divider: HorizontalLayout {
                        padding-left: 36px;
                        padding-right: 8px;
                        padding-top: 4px;
                        padding-bottom: 4px;

                        Text {
                            text: msg.text;
                            font-size: Theme.font-sm;
                            color: Theme.text-tertiary;
                            font-italic: true;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }

                    // Group start header — full feed width; spacer pushes timestamp right (no alignment:)
                    if !msg.is-system && !msg.is-unread-divider && msg.is-group-start: HorizontalLayout {
                        width: parent.width;
                        padding-right: 12px;
                        spacing: 8px;

                        Rectangle {
                            width: 28px;
                            height: 28px;
                            horizontal-stretch: 0;

                            AvatarCircle {
                                initials: msg.sender-initials;
                                avatar: msg.sender-avatar;
                                has-avatar: msg.has-sender-avatar;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                        }

                        Text {
                            text: msg.sender-name;
                            font-size: Theme.font-md;
                            font-weight: 600;
                            color: msg.sender-name == root.user-name ? Theme.accent : Theme.text-primary;
                            vertical-alignment: center;
                            horizontal-stretch: 0;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        if msg.display-time != "": Text {
                            text: msg.display-time;
                            font-family: Theme.font-mono;
                            font-size: Theme.font-xs;
                            color: Theme.text-tertiary;
                            vertical-alignment: center;
                            horizontal-stretch: 0;
                        }
                    }

                    // Message row: left gutter (hover actions) + content
                    if !msg.is-system && !msg.is-unread-divider: HorizontalLayout {
                        spacing: 8px;
                        width: feed.width;
                        alignment: start;
                        property <length> actions-y: 0px;
                        property <bool> body-hovered: body-hover.has-hover
                            || hover-bar-hover.has-hover
                            || reply-touch.has-hover
                            || more-menu.pointer-hover
                            || root.more-menu-message-id == msg.message-id;

                        // Gutter column for hover actions (avatar is in header row above)
                        Rectangle {
                            width: 28px;

                            hover-bar-hover := TouchArea {
                                x: 0;
                                y: actions-y;
                                width: 28px;
                                height: 24px;

                                HorizontalLayout {
                                    width: parent.width;
                                    height: 24px;
                                    opacity: body-hovered ? 1 : 0;
                                    spacing: 2px;
                                    alignment: center;

                                    Rectangle {
                                        width: 16px;
                                        height: 16px;
                                        border-radius: 4px;
                                        background: reply-touch.has-hover ? Theme.bg-tertiary : Theme.surface;

                                        Image {
                                            source: @image-url("../icons/reply.svg");
                                            width: 12px;
                                            height: 12px;
                                            colorize: Theme.text-secondary;
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                        }

                                        reply-touch := TouchArea {
                                            clicked => {
                                                root.reply-mode = true;
                                                root.reply-to-id = msg.message-id;
                                                root.reply-to-name = msg.sender-name;
                                            }
                                        }
                                    }

                                    more-menu := MessageMoreMenu {
                                        active: root.more-menu-message-id == msg.message-id;
                                        open-above: feed.at-bottom && idx >= messages.length - 2;
                                        is-own-message: msg.sender-id == root.user-id;
                                        toggled => {
                                            root.more-menu-message-id =
                                                root.more-menu-message-id == msg.message-id ? "" : msg.message-id;
                                        }
                                        edit-requested => {
                                            root.edit-mode = true;
                                            root.edit-message-id = msg.message-id;
                                            chat-input.text = msg.text;
                                            chat-input.focus();
                                            root.more-menu-message-id = "";
                                        }
                                        delete-requested => {
                                            root.delete-confirm-message-id = msg.message-id;
                                            root.more-menu-message-id = "";
                                        }
                                        copy-requested => {
                                            root.copy-message-text(msg.text);
                                            root.more-menu-message-id = "";
                                        }
                                    }
                                }
                            }
                        }

                        // Message content
                        Rectangle {
                            horizontal-stretch: 1;
                            background: msg.mentions-self ? (Theme.dark ? #6C5CE714 : #6C5CE720) : transparent;
                            border-radius: Theme.radius-sm;

                            body-hover := TouchArea {
                                width: parent.width;
                                height: parent.height;
                            }

                            if root.more-menu-message-id != "": TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => { root.more-menu-message-id = ""; }
                            }

                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 4px;

                            // Reply quote block
                            if msg.reply-to-id != "": HorizontalLayout {
                                spacing: 0px;

                                Rectangle {
                                    width: 3px;
                                    background: Theme.accent;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                    background: Theme.bg-tertiary;
                                    border-radius: 4px;

                                    VerticalLayout {
                                        padding: 6px;
                                        spacing: 2px;

                                        Text {
                                            text: "Replying to " + msg.reply-to-name;
                                            font-size: Theme.font-xs;
                                            font-weight: 600;
                                            color: Theme.accent;
                                        }

                                        Text {
                                            text: msg.reply-preview-text;
                                            font-size: Theme.font-xs;
                                            color: Theme.text-tertiary;
                                            wrap: word-wrap;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }

                            // Body text (shown for text messages, or GIF + text)
                            if msg.text != "" && !msg.is-deleted: HorizontalLayout {
                                spacing: 6px;

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 6px;

                                    StyledText {
                                        text: msg.display-styled;
                                        default-color: Theme.text-secondary;
                                        default-font-size: Theme.font-md;
                                        horizontal-stretch: 1;
                                    }

                                    if msg.links.length > 0: HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;

                                        for link[idx] in msg.links: LinkPill {
                                            url: msg.links[idx].url;
                                            label: msg.links[idx].label;
                                            clicked(url) => { root.link-clicked(url); }
                                        }
                                    }
                                }

                                if msg.is-edited: Text {
                                    text: "(edited)";
                                    font-size: Theme.font-xs;
                                    color: Theme.text-tertiary;
                                    vertical-alignment: bottom;
                                }
                            }

                            if msg.is-deleted: Text {
                                text: "[message deleted]";
                                font-size: Theme.font-md;
                                color: Theme.text-tertiary;
                                font-italic: true;
                                wrap: word-wrap;
                            }

                            // Clip inline card
                            if msg.is-clip: ChatClipCard {
                                sender-name: msg.sender-name;
                                clip-duration: msg.clip-duration;
                                width: 280px;
                            }

                            // GIF inline preview
                            if msg.is-gif: Rectangle {
                                property <float> aspect: msg.gif-height > 0 ? msg.gif-width / msg.gif-height : 1.33;
                                property <length> max-w: 300px;
                                width: max-w;
                                height: max-w / aspect;
                                border-radius: Theme.radius-sm;
                                clip: true;
                                background: msg.has-gif-image ? transparent : Theme.bg-app;

                                if msg.has-gif-image: Image {
                                    source: msg.gif-image;
                                    width: parent.width;
                                    height: parent.height;
                                    image-fit: cover;
                                }

                                if !msg.has-gif-image: Text {
                                    text: "Loading GIF…";
                                    font-size: Theme.font-xs;
                                    color: Theme.text-tertiary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                gif-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    moved => {
                                        root.gif-hovered(msg.gif-preview-url);
                                    }
                                }
                            }
                            }
                        }
                    }
                }

                // Bottom spacer so the last message isn't clipped above the composer
                if messages.length > 0: Rectangle {
                    height: 24px;
                    width: parent.width;
                }
            }
        }

        // --- "New messages" floating pill ---
        if root.has-new-messages: Rectangle {
            x: (parent.width - self.width) / 2;
            y: parent.height - self.height - 8px;
            width: 140px;
            height: 28px;
            border-radius: Theme.r-pill;
            background: Theme.accent;
            drop-shadow-blur: 4px;
            drop-shadow-color: #00000040;

            new-msg-touch := TouchArea {
                clicked => {
                    root.scroll-to-bottom-request = true;
                }
            }

            Text {
                text: "New messages ↓";
                font-size: Theme.font-sm;
                font-weight: 600;
                color: #FFFFFF;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        scroll-timer := Timer {
            interval: 1ms;
            running: root.scroll-to-bottom-request;
            triggered => {
                feed.viewport-y = -(feed.viewport-height - feed.height);
                root.scroll-to-bottom-request = false;
                root.has-new-messages = false;
                root.scroll-to-bottom-done();
            }
        }

        history-timer := Timer {
            interval: 1ms;
            running: root.history-prepended-rows > 0;
            triggered => {
                feed.viewport-y = feed.viewport-y + root.history-prepended-rows * 56px;
                root.history-prepended-done();
            }
        }
        } // close feed container Rectangle

        Rectangle {
            height: 1px;
            background: Theme.graphic-light;
        }

        // --- Composer block (inset padding; panel shell is edge-to-edge) ---
        VerticalLayout {
            spacing: 4px;
            padding-left: 8px;
            padding-right: 8px;
            padding-bottom: 8px;

        // --- Reply bar ---
        if root.reply-mode: HorizontalLayout {
            height: 28px;
            spacing: 8px;
            padding-left: 12px;
            padding-right: 8px;

            Text {
                text: "Replying to " + root.reply-to-name;
                font-size: Theme.font-sm;
                color: Theme.accent;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 20px;
                height: 20px;
                border-radius: 4px;
                background: close-reply-touch.has-hover ? Theme.bg-tertiary : transparent;
                y: (parent.height - self.height) / 2;

                Image {
                    source: @image-url("../icons/x.svg");
                    width: 12px;
                    height: 12px;
                    colorize: Theme.text-tertiary;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }

                close-reply-touch := TouchArea {
                    clicked => {
                        root.reply-mode = false;
                        root.reply-to-id = "";
                        root.reply-to-name = "";
                    }
                }
            }
        }

        // --- Edit bar ---
        if root.edit-mode: HorizontalLayout {
            height: 28px;
            spacing: 8px;
            padding-left: 12px;
            padding-right: 8px;

            Text {
                text: "Editing message";
                font-size: Theme.font-sm;
                color: Theme.accent;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 20px;
                height: 20px;
                border-radius: 4px;
                background: close-edit-touch.has-hover ? Theme.bg-tertiary : transparent;
                y: (parent.height - self.height) / 2;

                Image {
                    source: @image-url("../icons/x.svg");
                    width: 12px;
                    height: 12px;
                    colorize: Theme.text-tertiary;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }

                close-edit-touch := TouchArea {
                    clicked => {
                        root.edit-mode = false;
                        root.edit-message-id = "";
                        chat-input.text = "";
                    }
                }
            }
        }

        // --- Delete confirmation ---
        if root.delete-confirm-message-id != "": Rectangle {
            height: 36px;
            background: Theme.bg-tertiary;
            border-radius: Theme.radius-sm;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                spacing: 8px;

                Text {
                    text: "Delete this message?";
                    font-size: Theme.font-sm;
                    color: Theme.text-secondary;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    width: 56px;
                    height: 24px;
                    border-radius: 4px;
                    background: del-cancel-touch.has-hover ? Theme.graphic-light : transparent;

                    Text {
                        text: "Cancel";
                        font-size: Theme.font-xs;
                        color: Theme.text-tertiary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    del-cancel-touch := TouchArea {
                        clicked => { root.delete-confirm-message-id = ""; }
                    }
                }

                Rectangle {
                    width: 56px;
                    height: 24px;
                    border-radius: 4px;
                    background: del-ok-touch.has-hover ? #C0392B : #E05555;

                    Text {
                        text: "Delete";
                        font-size: Theme.font-xs;
                        font-weight: 600;
                        color: white;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    del-ok-touch := TouchArea {
                        clicked => {
                            root.delete-message(root.delete-confirm-message-id);
                            root.delete-confirm-message-id = "";
                        }
                    }
                }
            }
        }

        // --- @mention autocomplete (suggestions from Rust) ---
        if root.mention-suggestions.length > 0: Rectangle {
            height: min(120px, root.mention-suggestions.length * 32px + 8px);
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.graphic-light;
            border-radius: Theme.r-inner;
            clip: true;

            Flickable {
                width: parent.width;
                height: parent.height;

                VerticalLayout {
                    padding: 4px;
                    for m in root.mention-suggestions: Rectangle {
                        height: 30px;
                        background: mention-row-touch.has-hover ? Theme.bg-tertiary : transparent;
                        border-radius: 4px;

                        HorizontalLayout {
                            padding-left: 8px;
                            spacing: 8px;

                            Text {
                                text: m.initials;
                                font-size: 10px;
                                font-family: Theme.font-mono;
                                font-weight: 600;
                                color: Theme.text-secondary;
                                vertical-alignment: center;
                            }

                            Text {
                                text: m.display-name;
                                font-size: Theme.font-sm;
                                color: Theme.text-primary;
                                vertical-alignment: center;
                            }
                        }

                        mention-row-touch := TouchArea {
                            clicked => {
                                root.mention-selected(m.user-id, m.display-name);
                            }
                        }
                    }
                }
            }
        }

        // --- Emoji popover ---
        if root.emoji-popover-open: Rectangle {
            height: 200px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.graphic-light;
            border-radius: Theme.r-inner;
            clip: true;

            Flickable {
                width: parent.width;
                height: parent.height;

                VerticalLayout {
                    padding: 8px;
                    spacing: 4px;

                    for row-start[row-idx] in [0, 8, 16, 24, 32, 40, 48, 56, 64, 72, 80, 88, 96, 104, 112, 120, 128, 136, 144, 152]: HorizontalLayout {
                        spacing: 2px;

                        for col in [0, 1, 2, 3, 4, 5, 6, 7]: Rectangle {
                            property <int> emoji-index: row-start + col;
                            property <bool> in-range: emoji-index < emoji-list.length;
                            visible: in-range;
                            width: 32px;
                            height: 32px;
                            border-radius: 4px;
                            clip: true;

                            if in-range: Rectangle {
                                width: parent.width;
                                height: parent.height;
                                background: emoji-cell-touch.has-hover ? Theme.bg-tertiary : transparent;

                                Text {
                                    text: emoji-list[emoji-index].emoji;
                                    font-size: 18px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                emoji-cell-touch := TouchArea {
                                    clicked => {
                                        chat-input.text += emoji-list[emoji-index].emoji;
                                        chat-input.focus();
                                        root.emoji-popover-open = false;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // --- GIF popover ---
        if root.gif-popover-open: GifPopover {
            show: root.gif-popover-open;
            gifs: root.gif-results;
            search(query) => { root.gif-search(query); }
            gif-selected(gif-id, url, preview-url, w, h) => {
                root.gif-selected(gif-id, url, preview-url, w, h);
                root.gif-popover-open = false;
            }
            close => { root.gif-popover-open = false; }
        }

        // --- Action pills row ---
        HorizontalLayout {
            height: 28px;
            spacing: 4px;
            padding-left: 0px;

            PillButton {
                icon: @image-url("../icons/gif.svg");
                label: "GIF";
                active: root.gif-popover-open;
                clicked => {
                    root.gif-popover-open = !root.gif-popover-open;
                    if root.gif-popover-open {
                        root.gif-pill-clicked();
                    }
                }
            }

            PillButton {
                icon: @image-url("../icons/smile.svg");
                label: "Emoji";
                active: root.emoji-popover-open;
                clicked => {
                    root.emoji-popover-open = !root.emoji-popover-open;
                    if root.emoji-popover-open {
                        root.emoji-pill-clicked();
                    }
                }
            }
        }

        // --- Chat input (compact single-line; multiline only after Shift+Enter) ---
        Rectangle {
            property <length> box-height: root.composer-multiline
                ? min(120px, 32px + root.composer-line-count * 20px)
                : 40px;
            height: box-height;

            background: Theme.bg-app;
            border-radius: Theme.r-inner;
            border-width: 1px;
            border-color: Theme.graphic-light;

            newline-timer := Timer {
                interval: 0ms;
                running: root.pending-newline;
                triggered => {
                    root.pending-newline = false;
                    root.chat-input-text += "\n";
                    chat-input.set-selection-offsets(
                        root.chat-input-text.character-count,
                        root.chat-input-text.character-count,
                    );
                }
            }

            chat-input := MelloTextInput {
                text <=> root.chat-input-text;
                x: 18px;
                y: 0;
                width: parent.width - 36px;
                height: parent.height;
                font-size: Theme.font-md;
                color: Theme.text-primary;
                single-line: !root.composer-multiline;
                wrap: root.composer-multiline ? word-wrap : no-wrap;
                vertical-alignment: root.composer-multiline ? top : center;
                edited => { root.chat-input-changed(self.text); }

                key-pressed(event) => {
                    if event.text == Key.Return {
                        if event.modifiers.shift {
                            if !root.composer-multiline {
                                root.composer-multiline = true;
                            }
                            root.pending-newline = true;
                            accept
                        } else {
                            if root.chat-input-text != "" {
                                if root.edit-mode {
                                    root.edit-message(root.edit-message-id, root.chat-input-text);
                                    root.edit-mode = false;
                                    root.edit-message-id = "";
                                } else if root.reply-mode {
                                    root.message-submitted-with-reply(root.chat-input-text, root.reply-to-id);
                                    root.reply-mode = false;
                                    root.reply-to-id = "";
                                    root.reply-to-name = "";
                                } else {
                                    root.message-submitted(root.chat-input-text);
                                }
                                root.chat-input-text = "";
                                root.composer-multiline = false;
                                root.composer-line-count = 1;
                            }
                            accept
                        }
                    } else {
                        reject
                    }
                }
            }

            if root.chat-input-text == "" && !root.edit-mode: Text {
                x: 18px;
                y: root.composer-multiline ? 10px : (parent.height - self.height) / 2;
                color: Theme.text-tertiary;
                font-size: Theme.font-md;
                text: "Message crewmates...";
            }
        }
        } // composer block
            } // chat-body VerticalLayout
        } // chat-body Rectangle
    }

    // Full-height left edge (crew panel style); on top so bg-app header does not cover it.
    Rectangle {
        x: 0;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Theme.graphic-light;
    }
}

// --- Slint Live Preview (open this file → Preview component) ---
export component Preview inherits ChatPanel {
    width: 400px;
    height: 820px;
    user-name: "bobdev";
    user-id: "u1";
    messages-this-week: 12;
