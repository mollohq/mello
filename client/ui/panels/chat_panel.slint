import { Theme } from "../theme.slint";
import { ChatMessageData } from "../types.slint";

export component ChatPanel inherits Rectangle {
    in property <[ChatMessageData]> messages: [];
    in property <string> user-name: "";
    callback message-submitted(string);

    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.graphic-light;
    border-radius: Theme.r-outer;

    VerticalLayout {
        padding: Theme.pad;
        spacing: 0px;

        // --- Header kicker ---
        Text {
            text: "CREW CHAT";
            font-size: Theme.font-sm;
            font-weight: 600;
            letter-spacing: 1.3px;
            color: Theme.text-secondary;
            height: 16px;
        }

        // --- Chat feed ---
        Flickable {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 20px;
                padding-top: 12px;
                alignment: end;

                if messages.length == 0: Rectangle {
                    vertical-stretch: 1;

                    Text {
                        text: "No messages yet";
                        font-size: Theme.font-md;
                        color: Theme.text-tertiary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                for msg in messages: VerticalLayout {
                    spacing: 4px;

                    // Meta row: sender + timestamp
                    HorizontalLayout {
                        spacing: 8px;

                        Text {
                            text: msg.sender-name;
                            font-size: Theme.font-md;
                            font-weight: 600;
                            color: msg.sender-name == root.user-name ? Theme.accent : Theme.text-primary;
                            horizontal-stretch: 1;
                        }

                        Text {
                            text: msg.timestamp;
                            font-family: Theme.font-mono;
                            font-size: Theme.font-xs;
                            color: Theme.text-tertiary;
                            vertical-alignment: center;
                        }
                    }

                    // Message body
                    Text {
                        text: msg.text;
                        font-size: Theme.font-md;
                        color: Theme.text-secondary;
                        wrap: word-wrap;
                    }
                }
            }
        }

        // --- Separator ---
        Rectangle {
            height: 1px;
            background: Theme.graphic-light;
        }

        Rectangle { height: 4px; }

        // --- Chat input ---
        Rectangle {
            height: 48px;
            background: Theme.bg-app;
            border-radius: Theme.r-inner;
            border-width: 1px;
            border-color: Theme.graphic-light;

            chat-input := TextInput {
                x: 18px;
                width: parent.width - 36px;
                height: parent.height;
                font-size: Theme.font-md;
                color: Theme.text-primary;
                vertical-alignment: center;
                accepted => {
                    if chat-input.text != "" {
                        message-submitted(chat-input.text);
                        chat-input.text = "";
                    }
                }
            }
            if chat-input.text == "": Text {
                x: 18px;
                color: Theme.text-tertiary;
                font-size: Theme.font-md;
                vertical-alignment: center;
                text: "Message crewmates...";
            }
        }
    }
}
