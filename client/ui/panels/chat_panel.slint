        { emoji: "😀", name: "grinning" },
        { emoji: "👍", name: "thumbsup" },
        { emoji: "🔥", name: "fire" },
        { emoji: "❤️", name: "heart" },
    ];
    mention-members: [
        { user-id: "u2", display-name: "oweboweob", initials: "OW" },
        { user-id: "u3", display-name: "k0ji", initials: "K0" },
    ];
    messages: [
        // Grouped messages (continuation)
        {
            message-id: "p1", sender-id: "u2", sender-name: "oweboweob",
            sender-initials: "OW", text: "hey crew, stream at 8?",
            display-text: "hey crew, stream at 8?",
            display-styled: @markdown("hey crew, stream at 8?"),
            timestamp: "May 19, 8:02 PM", display-time: "Yesterday",
            is-group-start: true,
        },
        {
            message-id: "p2", sender-id: "u2", sender-name: "oweboweob",
            sender-initials: "OW", text: "bring snacks",
            display-text: "bring snacks",
            display-styled: @markdown("bring snacks"),
            timestamp: "May 19, 8:03 PM", display-time: "",
            is-group-start: false, is-continuation: true,
        },
        // Markdown + link
        {
            message-id: "p3", sender-id: "u1", sender-name: "bobdev",
            sender-initials: "B0", text: "Check **bold**, *italic*, and https://slint.dev",
            display-text: "Check **bold**, *italic*, and",
            display-styled: @markdown("Check **bold**, *italic*, and"),
            links: [{ url: "https://slint.dev/releases/1.16", label: "slint.dev/releases/1.16" }],
            timestamp: "May 19, 8:05 PM", display-time: "8:05 PM",
            is-group-start: true,
        },
        // @mention highlight (self)
        {
            message-id: "p4", sender-id: "u3", sender-name: "k0ji",
            sender-initials: "K0", text: "yo @bobdev you in?",
            display-text: "yo @bobdev you in?",
            display-styled: @markdown("yo **@bobdev** you in?"),
            timestamp: "May 19, 8:06 PM", display-time: "8:06 PM",
            is-group-start: true, mentions-self: true,
        },
        // Reply quote
        {
            message-id: "p5", sender-id: "u1", sender-name: "bobdev",
            sender-initials: "B0", text: "yeah omw",
            display-text: "yeah omw",
            display-styled: @markdown("yeah omw"),
            timestamp: "May 19, 8:07 PM", display-time: "8:07 PM",
            is-group-start: true,
            reply-to-id: "p1", reply-to-name: "oweboweob",
            reply-preview-text: "hey crew, stream at 8?",
        },
        // Edited message
        {
            message-id: "p6", sender-id: "u1", sender-name: "bobdev",
            sender-initials: "B0", text: "actually 8:30 — traffic",
            display-text: "actually 8:30 — traffic",
            display-styled: @markdown("actually 8:30 — traffic"),
            timestamp: "May 19, 8:08 PM", display-time: "8:08 PM",
            is-group-start: false, is-continuation: true, is-edited: true,
        },
        // Unread divider
        {
            message-id: "__unread__", is-unread-divider: true,
        },
        // GIF placeholder
        {
            message-id: "p7", sender-id: "u2", sender-name: "oweboweob",
            sender-initials: "OW", text: "",
            display-text: "", display-styled: @markdown(""),
            timestamp: "May 19, 8:10 PM", display-time: "8:10 PM",
            is-group-start: true, is-gif: true,
            gif-preview-url: "https://media.giphy.com/media/example.gif",
            gif-width: 320, gif-height: 240,
        },
        // Clip card
        {
            message-id: "p8", sender-id: "u3", sender-name: "k0ji",
            sender-initials: "K0", text: "",
            display-text: "", display-styled: @markdown(""),
            timestamp: "May 19, 8:12 PM", display-time: "8:12 PM",
            is-group-start: true, is-clip: true,
            clip-duration: "1:42", clip-id: "clip-preview",
        },
        // Deleted message
        {
            message-id: "p9", sender-id: "u2", sender-name: "oweboweob",
            sender-initials: "OW", text: "oops wrong channel",
            display-text: "", display-styled: @markdown(""),
            timestamp: "May 19, 8:13 PM", display-time: "8:13 PM",
            is-group-start: true, is-deleted: true,
        },
        // System message
        {
            message-id: "p10", sender-id: "sys", sender-name: "",
            sender-initials: "", text: "k0ji joined the crew",
            display-text: "k0ji joined the crew",
            display-styled: @markdown("k0ji joined the crew"),
            is-system: true,
        },
        // Own message (Edit/Delete in ⋮ menu — hover to test)
        {
            message-id: "p11", sender-id: "u1", sender-name: "bobdev",
            sender-initials: "B0",
            text: "Preview: hover for reply / ⋮ menu. Click outside to dismiss menu.",
            display-text: "Preview: hover for reply / ⋮ menu. Click outside to dismiss menu.",
            display-styled: @markdown("Preview: hover for reply / ⋮ menu. Click outside to dismiss menu."),
            timestamp: "May 19, 8:15 PM", display-time: "just now",
            is-group-start: true,
        },
    ];
}
